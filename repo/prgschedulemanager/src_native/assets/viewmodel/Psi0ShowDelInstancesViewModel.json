{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-list-filter.directive",
        "js/aw-default-cell.directive",
        "js/aw-panel-body.directive"
    ],
    "actions": {
        "searchDeliverableInstance": {
            "actionType": "JSFunction",
            "method": "getDeliverableInstances",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "policy": {
                "types": [{
                    "name": "WorkspaceObject",
                    "properties": [{
                            "name": "object_name"
                        },
                        {
                            "name": "object_desc"
                        },
                        {
                            "name": "object_type"
                        }
                    ]
                }]
            },
            "events": {
                "failure": [{
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                }]
            },
            "outputData": {
                "searchResults": "searchResults",
                "totalFound": "totalFound",
                "totalLoaded": "totalLoaded"
            },
            "deps": "js/ShowDeliverableInstances"
        }
    },
    "dataProviders": {
        "deliverableInstanceSearch": {
            "action": "searchDeliverableInstance",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "totalLoaded": "{{data.totalLoaded}}",
            "selectionModelMode": "single",
            "commands": {
                "Awp0ShowObjectCell": {
                    "id": "cmdOpen",
                    "areas": [
                        "com.siemens.splm.clientfx.ui.modelObjectListActionCommands"
                    ],
                    "priorities": [
                        300
                    ],
                    "dependencies": [
                        "js/showObjectCommandHandler"
                    ],
                    "displayOption": "ON_HOVER_AND_SELECTION",
                    "position": "TOP_RIGHT"
                },
                "Awp0ShowObjectCellDataset": {
                    "id": "cmdOpen",
                    "areas": [
                        "com.siemens.splm.clientfx.ui.modelObjectListActionCommands"
                    ],
                    "priorities": [ 300 ],
                    "dependencies": [ "js/showObjectDatasetCommandHandler" ],
                    "displayOption": "ON_HOVER_AND_SELECTION",
                    "position": "TOP_RIGHT"
                }
            }
        }
    },
    "data": {
        "filterBox": {
            "displayName": "MyFilter",
            "type": "STRING",
            "dbValue": ""
        }
    },
    "onEvent": [
    {
        "eventId": "Psi0ShowDelInstances.contentLoaded",
        "action": "deliverableInstanceSearch"
    }
    ],
    "functions":
    {
      "getDeliverableInstances":
        {
            "functionName": "getDeliverableInstances",
            "parameters":
            [
                "{{data}}",
                "{{ctx}}"
            ]
        }
    },

    "i18n": {
        "deliverables": ["ScheduleManagerMessages"]
    }

}
