{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel-body.directive",
        "js/aw-xrt.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive"
    ],
    "actions": {
        "startEditNative": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2012-10-DataManagement",
            "method": "loadDataForEditing",
            "inputData": {
                "inputs": [
                    {
                        "obj": "{{data.vmo}}",
                        "propertyNames": "{{data.propertyNamesRetrieved}}",
                        "isPessimisticLock": false
                    }
                ]
            },
            "outputData": {
                "lsd": "outputs[0].objLsds"
            },
            "policy": {
                "types": [
                    {
                        "name": "{{data.vmo.type}}",
                        "modifiers": [
                            {
                                "name": "includeIsModifiable",
                                "Value": "true"
                            }
                        ],
                        "properties": "{{data.propertyPolicyRetrieved}}"
                    }
                ]
            },
            "events": {
                "success": [
                    {
                        "name": "startEditNative.success",
                        "eventData": {
                            "context": "INFO_PANEL_CONTEXT",
                            "source": "toolAndInfoPanel"
                        }
                    }
                ],
                "failure": [
                    {
                        "name": "startEditNative.fail",
                        "eventData": {
                            "context": "INFO_PANEL_CONTEXT",
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            }
        },
        "saveEditNative": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2012-10-DataManagement",
            "method": "saveEditAndSubmitToWorkflow",
            "inputData": {
                "inputs": [
                    {
                        "object": "{{data.vmo}}",
                        "objLsds": "{{data.lsd}}",
                        "propertyNameValues": "{{function:getAllModifiedValues}}",
                        "isPessimisticLock": false,
                        "workflowData": {}
                    }
                ]
            },
            "events": {
                "success": [
                    {
                        "name": "saveEditNative.success",
                        "eventData": {
                            "context": "INFO_PANEL_CONTEXT",
                            "source": "toolAndInfoPanel"
                        }
                    }
                ],
                "failure": [
                    {
                        "name": "saveEditNative.fail",
                        "eventData": {
                            "context": "INFO_PANEL_CONTEXT",
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "deps": "js/declUtils"
        },
        "startEdit": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "objInfo.startEdit"
                    }
                ]
            }
        },
        "save": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "objInfo.saveEdit"
                    }
                ]
            }
        }
    },
    "functions": {
        "getAllModifiedValues": {
            "functionName": "getAllModifiedValues",
            "parameters": [
                "{{data.vmo}}"
            ]
        }
    },
    "messages": {
        "confirmLeave": {
            "messageType": "WARNING",
            "messageText": "{{i18n.navigationConfirmationSingle}}",
            "messageTextParams": [
                "{{data.vmo.props.object_string.dbValue}}"
            ],
            "navigationOptions": [
                {
                    "option": "Discard",
                    "text": "{{i18n.discard}}",
                    "action": ""
                },
                {
                    "option": "Save",
                    "text": "{{i18n.save}}",
                    "action": "save"
                }
            ]
        }
    },
    "conditions": {
        "isEditButtonVisible": {
            "expression": "ctx['INFO_PANEL_CONTEXT'] && ctx['INFO_PANEL_CONTEXT'].canStartEdit() && !ctx['INFO_PANEL_CONTEXT'].editInProgress()"
        },
        "isSaveButtonVisible": {
            "expression": "ctx['INFO_PANEL_CONTEXT'] && ctx['INFO_PANEL_CONTEXT'].editInProgress()"
        }
    },
    "i18n": {
        "Awp0EditGroup": [
            "ZeroCompileCommandBaseMessages"
        ],
        "save": [
            "XRTMessages"
        ],
        "navigationConfirmationSingle": [
            "XRTMessages"
        ],
        "discard": [
            "XRTMessages"
        ]
    }
}