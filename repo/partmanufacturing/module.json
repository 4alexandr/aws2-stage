{
  "name": "partmanufacturing",
  "description": "",
  "type": [
    "native"
  ],
  "srcDir": "src_native",
  "pathOffset": ".",
  "skipAudit": true,
  "skipTest": true,
  "version": "5.1.0",
  "author": "Siemens Product Lifecycle Management Software Inc.",
  "aliasRegistry": {
    "typeCMMInspection48": [
      "Mfg0CMMInspMEOP"
    ],
    "typeCMMInspectionRevision48": [
      "Mfg0CMMInspMEOPRevision"
    ],
    "typeMEAMActivity48": [
      "Mea0MEFixPlaneActivity"
    ],
    "typeMEAMOperation48": [
      "Mea0MEFixPlaneOP"
    ],
    "typeMEAMOperationRevision48": [
      "Mea0MEFixPlaneOPRevision"
    ],
    "typeMEAMOutputFiles48": [
      "Mea0MEFixPlaneOutputFiles"
    ],
    "typeMECMMProgram48": [
      "Mfg0CMMProgram"
    ],
    "typeMENCMachine48": [
      "Mfg0MENCMachine"
    ],
    "typeMENCMachineRevision48": [
      "Mfg0MENCMachineRevision"
    ],
    "typeMENCMachining48": [
      "MENCMachining"
    ],
    "typeMENCMachiningRevision48": [
      "MENCMachining Revision"
    ],
    "typeMENCProgram48": [
      "MENCProgram"
    ],
    "typeMENCTool48": [
      "Mfg0MENCTool"
    ],
    "typeMENCToolActivity48": [
      "MENCToolActivity"
    ],
    "typeMENCToolRevision48": [
      "Mfg0MENCToolRevision"
    ]
  },
  "commandsViewModel": {
    "commands": {
      "Pm1DatasetTypeFilter": {
        "iconId": "cmdfilter",
        "isGroup": false,
        "title": "{{i18n.Pm1DatasetTypeFiltersTitle}}",
        "description": "{{i18n.Pm1DatasetTypeFilterDesc}}"
      },
      "Pm1OccTypeFilter": {
        "iconId": "cmdfilter",
        "title": "{{i18n.Pm1OccTypeFiltersTitle}}",
        "description": "{{i18n.Pm1DatasetTypeFilterDesc}}"
      },
      "Pm1AddResource": {
        "iconId": "cmdAdd",
        "title": "{{i18n.Pm1AddResourceTitle}}",
        "description": "{{i18n.Pm1AddResourceTooltip}}"
      },
      "Pm1SetPin": {
        "iconId": "cmdPin",
        "isGroup": false,
        "title": "{{i18n.Pm1PinButtonToolTip}}",
        "description": "{{i18n.panelPinButtonDesc}}"
      },
      "Pm1SetUnPin": {
        "iconId": "cmdUnpin",
        "isGroup": false,
        "title": "{{i18n.Pm1UnpinButtonToolTip}}",
        "description": "{{i18n.panelUnPinButtonDesc}}"
      }
    },
    "commandHandlers": {
      "Pm1DatasetTypeFilterCommandHandler": {
        "id": "Pm1DatasetTypeFilter",
        "action": "launchDatasetTypeFilterPanel",
        "activeWhen": true,
        "visibleWhen": {
          "condition": "conditions.Pm1ShowDSFilterCommandVisibility"
        }
      },
      "Pm1OccTypeFilterCommandHandler": {
        "id": "Pm1OccTypeFilter",
        "action": "launchOccTypeFilterPanel",
        "activeWhen": true,
        "visibleWhen": {
          "condition": "conditions.Pm1ShowOTFilterCommandVisibility"
        }
      },
      "Pm1AddResourceCommandHandler": {
        "id": "Pm1AddResource",
        "action": "launchAddResourcePanel",
        "activeWhen": {
          "condition": "conditions.Pm1IsAddResourceCommandSupported"
        },
        "visibleWhen": {
          "condition": "conditions.Pm1IsAddResourceCommandSupported"
        },
        "enableWhen": {
          "condition": "conditions.Pm1IsOpenedPartMfgOperationValid"
        }
      },
      "Pm1StartEditSummaryCommandHandler": {
        "id": "Awp0StartEditSummary",
        "action": "actionPm1StartEditSummary",
        "activeWhen": {
          "condition": "conditions.Pm1IsPartMfgSummaryEditConditionActive"
        },
        "visibleWhen": {
          "condition": "conditions.Pm1IsPartMfgSummaryEditConditionActive"
        }
      },
      "Pm1SetPinCommandHandler": {
        "id": "Pm1SetPin",
        "action": "actionPm1SetPin",
        "activeWhen": {
          "condition": "conditions.isPm1PanelPinned"
        },
        "visibleWhen": {
          "condition": "conditions.isPm1PanelPinned"
        }
      },
      "Pm1SetUnPinCommandHandler": {
        "id": "Pm1SetUnPin",
        "action": "actionPm1SetUnPin",
        "activeWhen": {
          "condition": "conditions.isPm1PanelUnPinned"
        },
        "visibleWhen": {
          "condition": "conditions.isPm1PanelUnPinned"
        }
      },
      "Pm1ShowResourceCommandHandler": {
        "id": "Awp0ShowObject",
        "action": "actionPm1ShowResource",
        "activeWhen": {
          "condition": "conditions.Pm1IsPartManufacturingResource"
        },
        "visibleWhen": {
          "condition": "conditions.cmdOpenBaseVisibleCondition"
        }
      },
      "Pm1HideAddChildElementHandler": {
        "id": "Awb0AddChildElementDeclarative",
        "activeWhen": {
          "condition": "conditions.isPm1PartManufacturingSublocation"
        },
        "visibleWhen": false
      },
      "Pm1HideSelectAllHandler": {
        "id": "Awp0SelectAll",
        "activeWhen": {
          "condition": "conditions.isPm1PartManufacturingSublocation"
        },
        "visibleWhen": false
      },
      "Pm1HideEnableMultiSelectHandler": {
        "id": "Awp0EnableMultiSelect",
        "activeWhen": {
          "condition": "conditions.isPm1PartManufacturingSublocation"
        },
        "visibleWhen": false
      },
      "Pm1HideSaveWorkingContextHandler": {
        "id": "Awb0SaveWorkingContext",
        "activeWhen": {
          "condition": "conditions.Pm1IsSaveWorkingContextCommandSupported"
        },
        "enableWhen": false,
        "visibleWhen": false
      },
      "Pm1HideImportFromExcelHandler": {
        "id": "Awb0ImportFromExcel",
        "activeWhen": {
          "condition": "conditions.Pm1IsImportFromExcelCommandSupported"
        },
        "enableWhen": false,
        "visibleWhen": false
      },
      "Pm1HidePasteHandler": {
        "id": "Awp0Paste",
        "activeWhen": {
          "condition": "conditions.isPm1PartManufacturingSublocation"
        },
        "visibleWhen": false
      }
    },
    "commandPlacements": {
      "Pm1DatasetTypeFilterCmdDisplay": {
        "id": "Pm1DatasetTypeFilter",
        "uiAnchor": "aw_primaryWorkArea",
        "priority": 640
      },
      "Pm1OccTypeFilterCmdDisplay": {
        "id": "Pm1OccTypeFilter",
        "uiAnchor": "aw_primaryWorkArea",
        "priority": 740
      },
      "Pm1AddResourceCommandPlacementRW": {
        "id": "Pm1AddResource",
        "uiAnchor": "aw_rightWall",
        "priority": 100,
        "parentGroupId": "Awp0NewGroup"
      },
      "Pm1AddResourceCommandPlacementPWA": {
        "id": "Pm1AddResource",
        "uiAnchor": "aw_primaryWorkArea",
        "priority": 750
      },
      "Pm1SetPinPlacement": {
        "id": "Pm1SetPin",
        "uiAnchor": "Pm1_oneStepPinCommands",
        "priority": 100
      },
      "Pm1SetUnPinPlacement": {
        "id": "Pm1SetUnPin",
        "uiAnchor": "Pm1_oneStepPinCommands",
        "priority": 100
      }
    },
    "actions": {
      "launchDatasetTypeFilterPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Pm1DatasetTypeFilter",
          "location": "aw_navigation"
        }
      },
      "launchOccTypeFilterPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Pm1OccTypeFilter",
          "location": "aw_navigation"
        }
      },
      "launchAddResourcePanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Pm1AddResource",
          "location": "aw_toolsAndInfo"
        }
      },
      "actionPm1StartEditSummary": {
        "actionType": "JSFunction",
        "method": "updateHandlerAndStartEdit",
        "inputData": {
          "context": "NONE"
        },
        "deps": "js/occurrenceTypesService"
      },
      "actionPm1SetPin": {
        "actionType": "Event",
        "method": "Event",
        "inputData": {
          "events": [
            {
              "name": "addResource.Pm1SetPin",
              "eventData": {
                "data": "{{commandContext}}"
              }
            }
          ]
        }
      },
      "actionPm1SetUnPin": {
        "actionType": "Event",
        "method": "Event",
        "inputData": {
          "events": [
            {
              "name": "addResource.Pm1SetUnPin",
              "eventData": {
                "data": "{{commandContext}}"
              }
            }
          ]
        }
      },
      "actionPm1ShowResource": {
        "actionType": "Navigate",
        "navigateTo": "com_siemens_splm_clientfx_tcui_xrt_showObject",
        "navigationParams": {
          "uid": "{{ctx.selected.props.awb0UnderlyingObject.dbValues[0]}}"
        }
      }
    },
    "conditions": {
      "Pm1ShowDSFilterCommandVisibility": {
        "expression": "ctx.sublocation && ( ctx.sublocation.clientScopeURI === 'Pm1PartManufacturing' ) && ctx.PartMfg.activeTabIndex === 1 && ctx.visibleServerCommands.Pm1DatasetTypeFilter"
      },
      "Pm1ShowOTFilterCommandVisibility": {
        "expression": "ctx.sublocation && ( ctx.sublocation.clientScopeURI === 'Pm1PartManufacturing' ) && ctx.PartMfg.activeTabIndex === 0 && ctx.visibleServerCommands.Pm1OccTypeFilter && ( ctx.ViewModeContext.ViewModeContext === 'TableSummaryView' || ctx.ViewModeContext.ViewModeContext === 'TableView' )"
      },
      "Pm1IsAddResourceCommandSupported": {
        "expression": "ctx.tcSessionData.tcMajorVersion >= 13 && ctx.sublocation && ( ctx.sublocation.clientScopeURI === 'Pm1PartManufacturing' ) && ctx.PartMfg.activeTabIndex === 0 && ctx.selected.uid === ctx.locationContext.modelObject.uid"
      },
      "isPm1PanelPinned": {
        "expression": "ctx.tcSessionData.tcMajorVersion >= 13 && commandContext.pinnedToForm.dbValue"
      },
      "isPm1PanelUnPinned": {
        "expression": "ctx.tcSessionData.tcMajorVersion >= 13 && commandContext.unpinnedToForm.dbValue"
      },
      "isPm1PartManufacturingSublocation": {
        "expression": "ctx.sublocation && ( ctx.sublocation.clientScopeURI === 'Pm1PartManufacturing' )"
      },
      "Pm1IsSaveWorkingContextCommandSupported": {
        "expression": "conditions.isCreateSWCCommandVisible && conditions.Pm1IsPartManufacturingResource"
      },
      "Pm1IsImportFromExcelCommandSupported": {
        "expression": "conditions.enableImportBOMCommand && conditions.Pm1IsPartManufacturingResource"
      },
      "Pm1IsPartManufacturingResource": {
        "expression": "ctx.sublocation && ( ctx.sublocation.clientScopeURI === 'Pm1PartManufacturing' ) && (ctx.selected.modelType.typeHierarchyArray.indexOf( 'Awb0Element' ) > -1)"
      },
      "Pm1IsOpenedPartMfgOperationValid": {
        "expression": "conditions.Pm1IsAddResourceCommandSupported && ctx.locationContext.modelObject.props.is_modifiable.dbValues[0] === '1'"
      },
      "Pm1IsPartMfgSummaryEditConditionActive": {
        "expression": "conditions.isStartEditSummaryAllowed && conditions.Pm1IsPartManufacturingResource"
      }
    },
    "i18n": {
      "Pm1DatasetTypeFiltersTitle": [
        "partmanufacturingMessages"
      ],
      "Pm1OccTypeFiltersTitle": [
        "partmanufacturingMessages"
      ],
      "Pm1DatasetTypeFilterDesc": [
        "partmanufacturingMessages"
      ],
      "Pm1AddResourceTitle": [
        "partmanufacturingMessages"
      ],
      "Pm1AddResourceTooltip": [
        "partmanufacturingMessages"
      ],
      "Pm1_oneStepPinCommands": [
        "partmanufacturingMessages"
      ],
      "Pm1PinButtonToolTip": [
        "partmanufacturingMessages"
      ],
      "Pm1UnpinButtonToolTip": [
        "partmanufacturingMessages"
      ]
    }
  },
  "states": {
    "PartManufacturingLocation": {
      "data": {
        "browserTitle": {
          "source": "/i18n/partmanufacturingMessages",
          "key": "PartManufacturingLocationBrowserTitle"
        },
        "browserSubTitle": {
          "source": "/i18n/partmanufacturingMessages",
          "key": "PartManufacturingLocationBrowserSubTitle"
        },
        "headerTitle": {
          "source": "/i18n/partmanufacturingMessages",
          "key": "PartManufacturingLocationHeaderTitle"
        },
        "propertyPolicy": "/policies/PartManufacturingLocationPropertyPolicy.json"
      },
      "type": "location"
    },
    "PartManufacturingSubLocation": {
      "controller": "NativeSubLocationCtrl",
      "data": {
        "priority": 0,
        "label": {
          "source": "/i18n/partmanufacturingMessages",
          "key": "partMfgTitle"
        },
        "clientScopeURI": "Pm1PartManufacturing",
        "nameToken": "PartManufacturing",
        "viewBase": "PartManufacturing",
        "propertyPolicy": "/policies/PartManufacturingLocationPropertyPolicy.json"
      },
      "dependencies": [
        "js/aw.native.sublocation.controller"
      ],
      "params": {
        "filter": null
      },
      "parent": "PartManufacturingLocation",
      "reloadOnSearch": false,
      "templateUrl": "/html/aw.native.sublocation.html",
      "type": "subLocation",
      "url": "/partmanufacturing"
    }
  }
}
