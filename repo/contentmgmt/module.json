    "actions": {
      "Ctm1DownloadDataset": {
        "actionType": "JSFunction",
        "method": "downloadDataset",
        "inputData": {
          "data": "{{data.eventData}}"
        },
        "events": {
          "success": [
            {
              "name": "complete",
              "eventData": {
                "source": "toolAndInfoPanel"
              }
            }
          ]
        },
        "deps": "js/Ctm1ContentMgmtService"
      },
      "Ctm1ShowImportTranslationAction": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1ImportTranslation",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ExportTranslationAction": {
        "actionType": "TcSoaService",
        "serviceName": "Core-2007-09-DataManagement",
        "method": "expandGRMRelationsForPrimary",
        "inputData": {
          "primaryObjects": [
            {
              "uid": "{{ctx.selected.uid}}",
              "type": "{{ctx.selected.type}}"
            }
          ],
          "pref": {
            "expItemRev": false,
            "returnRelations": true,
            "info": [
              {
                "relationTypeName": "IMAN_specification"
              }
            ]
          }
        },
        "outputData": {
          "otherSideObject": "output[0].relationshipData[0].relationshipObjects[0].otherSideObject"
        },
        "events": {
          "success": [
            {
              "name": "ctm1.translationReady",
              "eventData": {
                "dataset": "{{data.otherSideObject}}"
              }
            }
          ]
        },
        "deps": "js/Att1DatasetService"
      },
      "Ctm1ShowNewTransOrder": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1AddTransOrder",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1OrderIsDelivered": {
        "actionType": "TcSoaService",
        "serviceName": "Core-2007-09-DataManagement",
        "method": "expandGRMRelationsForPrimary",
        "inputData": {
          "primaryObjects": [
            {
              "uid": "{{ctx.selected.uid}}",
              "type": "{{ctx.selected.type}}"
            }
          ],
          "pref": {
            "expItemRev": false,
            "returnRelations": true,
            "info": [
              {
                "relationTypeName": "ResultsInR"
              }
            ]
          }
        },
        "outputData": {
          "numberOfRelations": "output[0].relationshipData[0].relationshipObjects.length"
        },
        "events": {
          "success": [
            {
              "condition": "data.numberOfRelations < 1",
              "name": "ctm1.okayToDeliver"
            }
          ]
        },
        "actionMessages": {
          "success": [
            {
              "condition": "data.numberOfRelations > 0",
              "message": "deliveryAlreadyCreatedWarning"
            }
          ]
        }
      },
      "Ctm1ShowNewTransDelivery": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1AddTransDelivery",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ShowExportPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1Export",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ShowPublishPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1Publish",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ShowImportGraphicPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1ImportGraphic",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ShowImportTopicPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1ImportTopic",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1ShowImportDitaMapPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Ctm1ImportDitaMap",
          "location": "aw_toolsAndInfo"
        }
      },
      "Ctm1OpenInXMetaLAction": {
        "actionType": "JSFunction",
        "method": "openInXMetaL",
        "deps": "js/Ctm1ContentMgmtService",
        "inputData": {
          "uid": "{{ctx.selected.uid}}",
          "itemId": "{{ctx.selected.props.object_string.dbValues[0]}}"
        }
      },
      "Ctm1OpenInXMetaLFromContentAction": {
        "actionType": "JSFunction",
        "method": "openInXMetaL",
        "deps": "js/Ctm1ContentMgmtService",
        "inputData": {
          "uid": "{{ctx.mselected[0].props.awb0UnderlyingObject.dbValues[0]}}",
          "itemId": "{{ctx.mselected[0].props.awb0UnderlyingObject.uiValues[0]}}"
        }
      },
      "openPublishNotification": {
        "actionType": "JSFunction",
        "method": "openLineItem",
        "inputData": {
          "notificationObject": "{{commandContext.lineItem}}"
        },
        "events": {
          "success": [
            {
              "name": "NotificationMessage.markRead"
            }
          ]
        },
        "deps": "js/Ctm1ContentMgmtService"
      }
    },
    "functions": {},
    "onEvent": [
      {
        "eventId": "ctm1.translationReady",
        "action": "Ctm1DownloadDataset",
        "cacheEventData": true
      },
      {
        "eventId": "ctm1.okayToDeliver",
        "action": "Ctm1ShowNewTransDelivery"
      }
    ],
    "messages": {
      "deliveryAlreadyCreatedWarning": {
        "messageType": "ERROR",
        "messageText": "{{i18n.deliveryAlreadyCreate}}"
      }
    },
    "conditions": {
      "ctm1VersionCondition12": {
        "expression": "ctx.tcSessionData.tcMajorVersion === 12 && ctx.tcSessionData.tcMinorVersion > 2"
      },
      "ctm1VersionCondition13": {
        "expression": "ctx.tcSessionData.tcMajorVersion > 12"
      },
      "importTranslationSoaAvailable": {
        "expression": "conditions.ctm1VersionCondition12 || conditions.ctm1VersionCondition13"
      },
      "importTranslationVisible": {
        "expression": "conditions.objectIsAnyTopic && conditions.importTranslationSoaAvailable"
      },
      "objectIsCtm1Topic": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'Ctm1Topic' ) > -1"
      },
      "objectIsTopic": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'DC_TopicRevision' ) > -1"
      },
      "objectIsAnyTopic": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'Ctm1Topic' ) > -1 || ctx.selected.modelType.typeHierarchyArray.indexOf( 'DC_TopicRevision' ) > -1"
      },
      "objectIsTranslationOrder": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'TranslationOrderRevision' ) > -1"
      },
      "objectIsTranslationDelivery": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'TranslatnDelvryRevision' ) > -1"
      },
      "objectIsTranslation": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'DCt_TranslationRevision' ) > -1"
      },
      "oneObjectIsSelected": {
        "expression": "!ctx.mselected || ctx.mselected.length === 1"
      },
      "canOpenInXMetaL": {
        "expression": "conditions.objectIsTopic || conditions.objectIsTranslation"
      },
      "canOpenInXMetaLFromContent": {
        "expression": "conditions.objectIsCtm1Topic && conditions.oneObjectIsSelected"
      },
      "ctm1IsShowingArm0GenerateTraceabilityMatrix": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.ctm1IsCreateTracelinkCommandVisible",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "conditions.objectIsAnyTopic",
              "$query": {
                "$eq": true
              }
            }
          ]
        }
      },
      "enableOpenPublishNotification": {
        "expression": "commandContext.group.groupName==='CONTMGMT'"
      },
      "ctm1IsShowingAqc0AddCharRepresentation": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.ctm1IsAddCharRepVisible",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "conditions.objectIsAnyTopic",
              "$query": {
                "$eq": true
              }
            }
          ]
        }
      },
      "ctm1IsShowingAtt1SetFreezePoint": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.ctm1setFreezePointCommandVisibilityCond",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "conditions.objectIsAnyTopic",
              "$query": {
                "$eq": true
              }
            }
          ]
        }
      },
      "ctm1IsShowingEvm1CreateRecipe": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.ctm1createRecipeFromBomSelection",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "conditions.objectIsAnyTopic",
              "$query": {
                "$eq": true
              }
            }
          ]
        }
      },
      "ctm1setFreezePointCommandVisibilityCond": {
        "expression": "conditions.ctm1IsTcReleaseAtLeast123 && conditions.ctm1InAceContext && ctx.selected.modelType.typeHierarchyArray.indexOf( 'Awb0Element' ) > -1  && conditions.ctm1projectModelNotSelected"
      },
      "ctm1IsTcReleaseAtLeast123": {
        "expression": "ctx.tcSessionData.tcMajorVersion > 12 || ctx.tcSessionData.tcMajorVersion === 12 && ctx.tcSessionData.tcMinorVersion >= 3"
      },
      "ctm1InAceContext": {
        "expression": "ctx.occmgmtContext.modelObject.modelType.typeHierarchyArray.indexOf('Awb0Element') > -1"
      },
      "ctm1projectModelNotSelected": {
        "expression": "ctx.occmgmtContext.modelObject.modelType.typeHierarchyArray.indexOf('Uml1ModelElement') === -1 && ctx.pselected.modelType.typeHierarchyArray.indexOf( 'Uml1ModelElement' ) === -1"
      },
      "ctm1createRecipeFromBomSelection": {
        "expression": "ctx.occmgmtContext && ctx.occmgmtContext.selectedModelObjects && ctx.occmgmtContext.selectedModelObjects.length > 0 && ctx.aceActiveContext.context.topElement.modelType.typeHierarchyArray.indexOf('Fgf0ApplicationModel') === -1  && conditions.ctm1isTcReleaseAtLeast122Version"
      },
      "ctm1isTcReleaseAtLeast122Version": {
        "expression": "ctx.tcSessionData.tcMajorVersion > 12 || ( ctx.tcSessionData.tcMajorVersion === 12 && ctx.tcSessionData.tcMinorVersion >= 2 )"
      },
      "ctm1IsAddCharRepVisible": {
        "expression": "ctx.mselected.length === 1 && conditions.ctm1IsOccStructure"
      },
      "ctm1IsOccStructure": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'Awb0Element' ) > -1 && ctx.sublocation.nameToken === 'com.siemens.splm.client.occmgmt:OccurrenceManagementSubLocation'"
      },
      "ctm1IsCreateTracelinkCommandVisible": {
        "expression": "(conditions.ctm1IsCreateTracelinkCommandVisibleAce || conditions.ctm1IsCreateTracelinkCommandVisibleNonAce)"
      },
      "ctm1IsCreateTracelinkCommandVisibleAce": {
        "expression": "ctx.occmgmtContext  && (ctx.selected.modelType.typeHierarchyArray.indexOf( 'Awb0ConditionalElement' ) > -1 || ctx.selected.modelType.typeHierarchyArray.indexOf( 'ItemRevision' ) > -1)"
      },
      "ctm1IsCreateTracelinkCommandVisibleNonAce": {
        "expression": "!ctx.occmgmtContext && ctx.visibleServerCommands.Arm0CreateTraceLink"
      }
    },
