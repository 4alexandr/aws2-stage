{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-include.directive",
        "js/aw-popup2.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/enable-when.directive"
    ],
    "data":{
        "boTypeName": "{{subPanelContext.boTypeName}}",
        "exclusionBOTypeNames": "{{subPanelContext.exclusionBOTypeNames}}",
        "objectTypesToSearch":"{{subPanelContext.objectTypesToSearch}}",
        "buttonName":"{{subPanelContext.buttonName}}",
        "placeHolderForSearch":"{{subPanelContext.placeHolderForSearch}}",
        "SourceTileContext":"{{subPanelContext.tileInfo}}",
        "revisionRuleListWidgetKey": {
            "key": "revisionRuleListElement"
        },
        "revisionRuleListElement": {
            "dbValue": ""
        }
    },
    "onEvent": [
    ],
    "actions": {
        "closePopupWindow": {
            "actionType": "JSFunction",
            "method": "hide",
            "inputData": {
                "popupId": "{{data.popupId}}"
            },
            "deps": "js/popupService"
        },
        "addObject": {
            "actionType": "JSFunction",
            "method": "addObject",
            "inputData": {
                "data": "{{data}}",
                "selectedObject":"{{data.inputObject}}",
                "revisionRule":"{{data.revisionRuleListElement}}"
            },
            "deps": "js/epAddObjectService"
        }
    },
    "conditions": {
        "isObjectSelectedToAdd": {
            "expression": "data.inputObject.selectedObjects"
        }
    },
    "lifecycleHooks": {
    },
    "i18n": {
        "cancel": ["EPMessages"]
    }
}
