{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-popup-panel2.directive",
        "js/aw-list-filter.directive",
        "js/exist-when.directive"
    ],
    "actions": {
        "search": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "",
                    "clientScopeURI": "",
                    "columnsToExclude": [],
                    "hostingClientName": "",
                    "operationType": ""
                },
                "saveColumnConfigData": {
                    "columnConfigId": "",
                    "clientScopeURI": "",
                    "columns": [],
                    "scope": "",
                    "scopeName": ""
                },
                "searchInput": {
                    "internalPropertyName": "",
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Awp0FullTextSearchProvider",
                    "searchCriteria":
                    {
                       "searchString": "**{{data.stxFilterBox.dbValue}}*"
                    },
                    "searchFilterFieldSortType": "Priority",
                    "searchFilterMap6": {
                        "WorkspaceObject.object_type": [{
                        "searchFilterType": "StringFilter",
                        "stringValue": "Mes0MESTXElementRevision",
                        "selected": false,
                        "stringDisplayValue": "",
                        "startDateValue": "",
                        "endDateValue": "",
                        "startNumericValue": 0,
                        "endNumericValue": 0,
                        "count": 0,
                        "startEndRange": ""
                        }]
                    },
                    "searchSortCriteria": [],
                    "startIndex": "{{data.dataProviders.performSearch.startIndex}}"
                }
            },
            "policy": {
                "types":
                [
                    {
                        "name": "Mes0MESTXElementRevision",
                        "properties": [{
                            "name": "epw0body_cleartext"
                        },
                        {
                            "name": "epw0mes0WIStrings"
                        }]
                    }
                ]
            },
            "outputData": {
                "searchResults": "{{function:getStandardTextElementRevisionList}}"
            },
            "deps": "js/wiStandardText.service"
        },
        "addSelectedStandardText": {
            "actionType": "JSFunction",
            "method": "addSelectedStandardText",
            "inputData": {
                "data": "{{data.eventData.selectedObjects}}"
            },
            "deps": "js/wiStandardText.service"
        },
        "updateData": {
            "actionType": "JSFunction",
            "method": "updateData",
            "inputData": {
                "data": "{{data}}",
                "objectToUpdate": "isPopupPositionUpdated",
                "value": true
            },
            "deps": "js/wiStandardText.service"
        }
    },

    "data": {
        "stxFilterBox": {
            "displayName": "MyFilter",
            "type": "STRING",
            "autofocus": "true",
            "requiredText": "{{i18n.filterMessage}}"
        },
        "isPopupPositionUpdated":false
    },

    "dataProviders": {
        "performSearch": {
            "action": "search",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.searchResults.length}}"
        }
    },
    "onEvent": [ {
            "eventId": "performSearch.selectionChangeEvent",
            "action": "addSelectedStandardText",
            "cacheEventData": true
        },
        {
            "eventId": "wi.standardTextPopupPositionUpdated",
            "action": "updateData"
        }
    ],
    "i18n": {
        "filterMessage": [
            "InstructionsEditorMessages"
        ]
    }
}
