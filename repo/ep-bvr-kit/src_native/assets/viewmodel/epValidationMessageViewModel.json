{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-include.directive"
    ],
     "ports": {
        "epValidationMessage_inputObject": {
            "onChangeAction": "setInputObject",
            "syncObject": {}
        }
    },
    "actions": {
        "setInputObject": {
            "actionType": "JSFunction",
            "method": "setInputObject",
            "inputData": {
                "objectsSelected": "{{ports.epValidationMessage_inputObject.syncObject}}"
            },
            "deps": "js/epValidationTableService"
        }
    },
    "data": {
        "messages": {
            "runValidationsMessage": [ {
                "text": "{{i18n.runValidationsMessage}}",
                "iconId": "cmdPlay"
            } ]
        },
        "inputObject": "{{ports.epValidationMessage_inputObject.syncObject[0]}}"
    },
    "i18n": {
        "runValidationsMessage": [ "epValidationMessages" ]
    }
}
