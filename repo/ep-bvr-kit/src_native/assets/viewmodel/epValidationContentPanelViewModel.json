{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-flex-column.directive",
        "js/aw-flex-row.directive",
        "js/aw-command-bar.directive",
        "js/aw-advanced-bar.directive",
        "js/aw-include.directive"
    ],
    "actions": {
        "init": {
            "actionType": "JSFunction",
            "method": "initEpValidationContentPanel",
            "inputData": {
                "tabs": "{{subPanelContext.tabs}}",
                "data": "{{data}}"
            },
            "deps": "js/epValidationUtil"
        }
    },
    "lifecycleHooks": {
        "onInit": "init"
    }
}
