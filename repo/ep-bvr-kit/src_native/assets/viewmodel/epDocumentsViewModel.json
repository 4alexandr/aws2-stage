{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-include.directive",
        "js/aw-flex-row.directive",
        "js/aw-flex-column.directive",
        "js/aw-separator.directive",
        "js/aw-list.directive",
        "js/aw-scrollpanel.directive"
    ],

    "ports": {
        "epDocuments_inputObject": {
            "onChangeAction": "handleInput",
            "syncObject": {}
        },
        "epDocuments_selectedObjects": {
            "syncObject": {}
        }
    },

    "data": {
        "subPanelContextForInformation": {
            "xrtType": "{{subPanelContext.xrtType}}",
            "noElementSelectedMessageForXRT": {
                "text": "{{i18n.noFileSelected}}"
            }
        },
        "messages": {
            "noInput": [{
                "text": "{{i18n.selectProcessOrOperation}}",
                "textParams": [
                    "{{i18n.documents}}"
                ]
            }],
            "noItems": [
                {
                    "text": "{{i18n.noAssigned}}",
                    "textParams": [
                        "{{i18n.documents}}"
                    ]
                }
            ]
        }
    },

    "actions": {
        "handleInput": {
            "actionType": "batchJob",
            "steps": [
                {
                    "action": "handleNewInputForSingleObject"
                },
                {
                    "action": "getDocumentItems",
                    "condition": "conditions.isInputObjectUpdated"
                },
                {
                    "action": "initCommandContext",
                    "condition": "conditions.isInputObjectUpdated"
                },
                {
                    "action": "updateTabDisplayNameQuantity",
                    "condition": "conditions.isInputObjectUpdated"
                },
                {
                    "action": "setSelection",
                    "condition": "conditions.hasItems"
                },
                {
                    "action": "setSelectionForSubPanel",
                    "condition": "conditions.hasItems"
                }
            ]
        },

        "handleNewInputForSingleObject": {
            "actionType": "JSFunction",
            "method": "handleNewInputForSingleObject",
            "inputData": {
                "data": "{{data}}",
                "input": "{{ports.epDocuments_inputObject.syncObject}}"
            },
            "deps": "js/mfeSyncUtils"
        },

        "getDocumentItems": {
            "actionType": "dataProvider",
            "method": "documentItemsList"
        },

        "getDocumentItemsList": {
            "actionType": "JSFunction",
            "method": "loadDataFromLoadedResponse",
            "inputData": {
                "objUid": "{{data.inputObject.uid}}",
                "loadType": "getProperties",
                "propertiesToLoad": ["mbc0AssignedDocuments"]
            },
            "outputData": {
                "documentItemsRowsObjects": "rowsObjects",
                "documentItemsTotalRows": "totalRows"
            },
            "deps": "js/epTableService"
        },

        "setSelection": {
            "actionType": "JSFunction",
            "method": "setSelection",
            "inputData": {
                "dataProvider": "{{data.dataProviders.documentItemsList}}",
                "objectsToSelect": "{{data.documentItemsRowsObjects[0]}}"
            },
            "deps": "js/mfeSyncUtils"
        },

        "setSelectionForSubPanel": {
            "actionType": "JSFunction",
            "method": "setValueInViewModel",
            "inputData": {
                "object": "{{data}}",
                "key": "subPanelContextForInformation",
                "value": {
                    "scopeObject": "{{data.documentItemsRowsObjects[0]}}",
                    "xrtType": "{{subPanelContext.xrtType}}"
                }
            },
            "deps": "js/mfeViewModelUtils"
        },

        "updateSelectionPort": {
            "actionType": "Sync",
            "inputData": {
                "port": "epDocuments_selectedObjects",
                "syncObject": "{{data.eventData.selectedObjects}}"
            }
        },

        "initCommandContext": {
            "actionType": "JSFunction",
            "method": "setCommandContext",
            "inputData": {
                "tabModel": "{{subPanelContext}}",
                "commandContext": {
                    "inputObject": "{{data.inputObject}}",
                    "selection": "{{[]}}",
                    "contentCount": "{{data.dataProviders.documentItemsList.viewModelCollection.loadedVMObjects.length}}"
                }
            },
            "deps": "js/mfeContentPanelUtil"
        },

        "updateTabDisplayNameQuantity": {
            "actionType": "JSFunction",
            "method": "setTabDisplayNameWithQuantity",
            "inputData": {
                "tabData": "{{subPanelContext}}"
            },
            "deps": "js/epTabsService"
        },

        "updateCommandContext": {
            "actionType": "JSFunction",
            "method": "setCommandContext",
            "inputData": {
                "tabModel": "{{subPanelContext}}",
                "commandContext": {
                    "inputObject": "{{data.inputObject}}",
                    "selection": "{{data.eventData.selectedObjects}}"
                }
            },
            "deps": "js/mfeContentPanelUtil"
        },

        "updateSelectionPortAndCommandContext": {
            "actionType": "batchJob",
            "steps": [
                {
                    "action": "updateSelectionPort"
                },
                {
                    "action": "updateCommandContext"
                }
            ]
        },

        "handleSaveEvents": {
            "actionType": "batchJob",
            "steps": [
                {
                    "action": "handleAddRemoveSaveEvents"
                },
                {
                    "action": "initCommandContext"
                },
                {
                    "action": "getDocumentItems",
                    "condition": "conditions.noDocumentItemsLoaded"
                },
                {
                    "action": "updateTabDisplayNameQuantity"
                },
                {
                    "action": "setSelection",
                    "condition": "conditions.isFirstDocument"
                },
                {
                    "action": "setSelectionForSubPanel",
                    "condition": "conditions.isFirstDocument"
                }
            ]
        },

        "handleAddRemoveSaveEvents": {
            "actionType": "JSFunction",
            "method": "handleAddRemoveSaveEvents",
            "inputData": {
                "saveEvents": "{{data.eventData}}",
                "relationName": ["mbc0AssignedDocuments",
                                 "Mfg0sub_elements",
                                 "Mbc0EPDocument"],
                "dataProvider": "{{data.dataProviders.documentItemsList}}",
                "inputObjectUid": "{{data.inputObject.uid}}"
            },
            "deps": "js/epTableService"
        }
    },

    "dataProviders": {
        "documentItemsList": {
            "action": "getDocumentItemsList",
            "response": "{{data.documentItemsRowsObjects}}",
            "totalFound": "{{data.documentItemsTotalRows}}",
            "selectionModelMode": "single"
        }
    },

    "conditions": {
        "isInputObjectUpdated": {
            "expression": "data.isInputObjectUpdated"
        },
        "hasInput":
        {
            "expression":"data.inputObject.uid"
        },
        "hasItems":
        {
            "expression":"data.dataProviders.documentItemsList.viewModelCollection.loadedVMObjects.length > 0"
        },
        "noDocumentItemsLoaded": {
            "expression": "data.dataProviders.documentItemsList.viewModelCollection.totalObjectsLoaded === 0"
        },
        "isInputObjectUpdatedAndHasItems": {
            "expression": "conditions.isInputObjectUpdated && conditions.hasItems"
        },
        "isFirstDocument": {
            "expression": "data.dataProviders.documentItemsList.viewModelCollection.loadedVMObjects.length === 1"
        }
    },

    "onEvent": [
        {
            "eventId": "documentItemsList.selectionChangeEvent",
            "action": "updateSelectionPortAndCommandContext",
            "cacheEventData": true
        },
        {
            "eventId": "ep.addRemoveEvents",
            "cacheEventData": true,
            "action": "handleSaveEvents"
        }
    ],

    "i18n": {
        "selectProcessOrOperation": [ "DetailsMessages" ],
        "documents": ["DetailsMessages"],
        "noAssigned": [ "DetailsMessages" ],


        "noFileSelected": [ "DetailsMessages" ]
    }
}
