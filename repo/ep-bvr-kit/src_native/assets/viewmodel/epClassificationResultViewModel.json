{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive"
    ],
    "actions": {
        "doArrangeEvent" : {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "resetColumnConfig" : {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [{
                    "scope": "LoginUser",
                    "scopeName": "",
                    "clientName": "AWClient",
                    "resetColumnConfig": true,
                    "columnConfigQueryInfos":
                        [{
                            "clientScopeURI": "Awp0SearchResults",
                            "operationType": "intersection",
                            "typeNames": "{{function:getTypeNames}}",
                            "columnsToExclude": []
                        }],
                    "businessObjects": [{}]
                }]
            },
            "outputData": {
                "dataProviders.gridDataProviders.resetColumnConfigs": "columnConfigurations"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2016-03-UiConfig",
            "method": "saveUIColumnConfigs",
            "inputData": {
                "columnConfigurations": [
                    {
                        "clientScopeURI" : "Awp0SearchResults",
                        "columnConfigId" : "{{data.dataProviders.gridDataProviders.columnConfig.columnConfigId}}",
                        "columns": "{{data.dataProviders.gridDataProviders.newColumns}}",
                        "scope" : "LoginUser",
                        "scopeName": ""
                    }
                ]
            },
            "outputData": {}
        },
        "saveColumnConfigLoadData": {
            "actionType": "JSFunctionAsync",
            "method": "loadData",
            "inputData": {
                "data": "{{data}}",
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "{{data.eventMap['columnArrange'].operationType}}",
                    "clientScopeURI": "Awp0SearchResults"
                },
                "saveColumnConfigData": {
                    "clientScopeURI" : "Awp0SearchResults",
                    "columnConfigId" : "{{data.dataProviders.gridDataProviders.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.gridDataProviders.newColumns}}",
                    "scope" : "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Awp0FullTextSearchProvider",
                    "searchCriteria": "{{function:getClsSearchCriteria}}",
                    "searchFilterFieldSortType": "{{ctx.search.sortType}}",
                    "searchFilterMap": "{{function:getBulkFilterMap}}",
                    "searchSortCriteria": "{{data.columnProviders.clientScopeUI.sortCriteria}}",
                    "cursor": {
                        "startIndex": "{{data.dataProviders.gridDataProviders.startIndex}}"
                    }
                }
            },
            "outputData": {
                "totalResponse": "",
                "totalFound": "totalFound",
                "searchResults": "searchResults",
                "dataProviders.gridDataProviders.columnConfig": "columnConfig",
                "ctx.search.totalFound": "totalFound",
                "ctx.search.totalLoaded": "totalLoaded",
                "ctx.search.filterMap": "searchFilterMap5",
                "ctx.search.filterCategories": "searchFilterCategories",
                "ctx.search.objectsGroupedByProperty": "objectsGroupedByProperty",
                "ctx.searchResponseInfo.searchFilterCategories": "searchFilterCategories",
                "ctx.searchResponseInfo.searchFilterMap": "searchFilterMap5",
                "ctx.searchResponseInfo.objectsGroupedByProperty": "objectsGroupedByProperty",
                "ctx.searchResponseInfo.columnConfig": "columnConfig",
                "ctx.searchResponseInfo.propDescriptors": "propDescriptors"
            },
            "deps": "js/classifySearchService"
        },
        "updateSelected":{
            "actionType": "JSFunction",
            "method": "selectionChanged",
            "inputData": {
                "eventData": "{{data.eventData.selectedObjects}}"
            },
         
            "deps": "js/classificationResourceService"
        },
        "loadListView": {
            "actionType": "dataProvider",
            "method": "listDataProvider"
        },
        "searchSelectedClassTableMode11": {
            "actionType": "JSFunctionAsync",
            "method": "loadData",
            "inputData": {
                "data": "{{data}}",
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "Awp0SearchResults",
                    "operationType": "{{data.dataProviders.gridDataProviders.columnConfig.operationType}}"
                },
                "saveColumnConfigData": {
                    "columnConfigId": "",
                    "clientScopeURI": "",
                    "columns": [],
                    "scope": "",
                    "scopeName": ""
                },
                "searchInput": {
                    "internalPropertyName": "",
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Awp0FullTextSearchProvider",
                    "searchFilterMap6": "",
                    "searchCriteria": "{{function:getClsSearchCriteria}}",
                    "searchSortCriteria": "{{function:getSearchSortCriteria}}",
                    "cursor": {
                        "startIndex": "{{data.dataProviders.gridDataProviders.startIndex}}"
                    }
                }
            },
            "outputData": {
                "totalResponse": "",
                "totalFound": "totalFound",
                "searchResults": "searchResults",
                "dataProviders.gridDataProviders.columnConfig": "columnConfig",
                "ctx.search.totalFound": "totalFound",
                "ctx.search.totalLoaded": "totalLoaded",
                "ctx.search.filterMap": "searchFilterMap5",
                "ctx.search.filterCategories": "searchFilterCategories",
                "ctx.search.objectsGroupedByProperty": "objectsGroupedByProperty",
                "originalInputCategories": "{{function:setOriginalInputCategories}}",
                "ctx.searchResponseInfo.searchFilterCategories": "searchFilterCategories",
                "ctx.searchResponseInfo.unpopulatedSearchFilterCategories": "searchFilterCategoriesUnpopulated",
                "ctx.searchResponseInfo.searchFilterMap": "searchFilterMap5",
                "ctx.searchResponseInfo.objectsGroupedByProperty": "objectsGroupedByProperty",
                "ctx.searchResponseInfo.columnConfig": "columnConfig",
                "ctx.searchResponseInfo.propDescriptors": "propDescriptors",
                "ctx.search.filterString": "{{function:getActiveFilterString}}",
                "ctx.search.saveSearchFilterMap": "{{function:getSaveSearchFilterMap}}",
                "ctx.searchChart.categoryToChartOn": "{{function:getEmptyString}}",
                "ctx.search.currentHighlightedCategory": "objectsGroupedByProperty.internalPropertyName",
                "ctx.searchResponseInfo.defaultFilterFieldDisplayCount": "defaultFilterFieldDisplayCount"
            },
            "deps": "js/classifySearchService",
            "events": {
                "success": [ {
                    "name": "LoadFiltersForEasyPlanOnly"
                } ]
            }
        },
        "searchSelectedClassListMode": {
            "actionType": "JSFunctionAsync",
            "method": "loadData",
            "inputData": {
                "data": "{{data}}",
                "columnConfigInput": {},
                "saveColumnConfigData": {},
                "searchInput": {
                    "attributesToInflate": [ "object_name", "checked_out_user", "object_desc", "release_status_list", "fnd0InProcess" ],
                    "internalPropertyName": "",
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Awp0FullTextSearchProvider",
                    "searchCriteria": "{{function:getClsSearchCriteria}}",
                    "searchFilterFieldSortType": "Priority",
                    "cursor": {
                        "startIndex": "{{data.dataProviders.listDataProvider.startIndex}}"
                    },
                    "searchFilterMap": "{{function:getBulkFilterMap}}",
                    "searchSortCriteria": []
                }
            },
            "outputData": {
                "totalResponse": "",
                "totalFound": "totalFound",
                "searchResults": "searchResults",
                "dataProviders.gridDataProviders.columnConfig": "columnConfig",
                "ctx.search.totalFound": "totalFound",
                "ctx.search.totalLoaded": "totalLoaded",
                "ctx.search.filterMap": "searchFilterMap5",
                "ctx.search.filterCategories": "searchFilterCategories",
                "ctx.search.objectsGroupedByProperty": "objectsGroupedByProperty",
                "originalInputCategories": "{{function:setOriginalInputCategories}}",
                "ctx.searchResponseInfo.searchFilterCategories": "searchFilterCategories",
                "ctx.searchResponseInfo.unpopulatedSearchFilterCategories": "searchFilterCategoriesUnpopulated",
                "ctx.searchResponseInfo.searchFilterMap": "searchFilterMap5",
                "ctx.searchResponseInfo.objectsGroupedByProperty": "objectsGroupedByProperty",
                "ctx.searchResponseInfo.columnConfig": "columnConfig",
                "ctx.searchResponseInfo.propDescriptors": "propDescriptors",
                "ctx.search.filterString": "{{function:getActiveFilterString}}",
                "ctx.search.saveSearchFilterMap": "{{function:getSaveSearchFilterMap}}",
                "ctx.searchChart.categoryToChartOn": "{{function:getEmptyString}}",
                "ctx.search.currentHighlightedCategory": "objectsGroupedByProperty.internalPropertyName",
                "ctx.searchResponseInfo.defaultFilterFieldDisplayCount": "defaultFilterFieldDisplayCount"
            },
            "deps": "js/classifySearchService",
            "events": {
                "success": [ {
                    "name": "LoadFiltersForEasyPlanOnly"
                } ]
            }
        },
        "typesTableDoSearch": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [ {
                    "name": "gridView.plTable.reload"
                } ]
            }
        }

    },
    "functions": {
        "getSearchSortCriteria": {
            "functionName": "getSearchSortCriteria",
            "parameters": [
                "{{data.columnProviders.clientScopeUI.sortCriteria}}"
            ]
        },
        "getBulkFilterMap": {
            "functionName": "getBulkFilterMap",
            "parameters": [
               "{{ctx.bulkFiltersMap}}"
            ]
        },
        "getClsSearchCriteria": {
            "functionName": "getClsSearchCriteria",
            "parameters": []
        },
        "getTypeNames":
        {
            "functionName": "getTypeNames",
            "parameters":
            [
                "{{ctx.searchResponseInfo.searchFilterMap}}"
            ]
        }
    },

    "onEvent": [
        {
            "eventId": "getClassTableSummary.selectionChangeEvent",         
            "action": "typesTableDoSearch"
        },
        {
            "eventId": "gridDataProviders.selectionChangeEvent",
            "action": "updateSelected",
            "cacheEventData": true
        },
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        }
    ],
    "dataProviders": {
        "gridDataProviders": {
            "action": "searchSelectedClassTableMode11",
            "editContext": "TABLE_CONTEXT",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "multiple",
            "inputData": {
                "selectionModel": "{{data.dataProviders.gridDataProviders.selectionModel}}"
            }
        },
        "listDataProvider": {
            "action": "searchSelectedClassListMode",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "inputData": {
                "selectionModel": "{{data.dataProviders.listDataProvider.selectionModel}}"
            }
        }
    },
    "columnProviders": {
        "clientScopeUI": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "saveColumnAction": "saveColumnConfig",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "grids": {
        "gridView": {
            "dataProvider": "gridDataProviders",
            "columnProvider": "clientScopeUI",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableGridMenu": true
            }
        }
    }
}
