{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel.directive",
        "js/aw-row.directive",
        "js/aw-splm-table.directive"
    ],
    "onEvent": [
        {
            "eventId": "editHandlerStateChange",
            "cacheEventData": true,
            "action": "myAction"
        },
        {
            "eventId": "gridView.initialized",
            "action": "doGridDataProvider"
        },
        {
            "eventId": "Aut0UserSettings.contentLoaded",
            "action": "initializeTabledata",
            "cacheEventData": true
        }
    ],
    "actions": {  
        "reveal":
        {
            "actionType": "JSFunction",
            "method": "checkVersionSupportForGroupRole",
            "inputData": {
                "major": "12",
                "minor": "2",
                "qrm": "0"
            },
            "outputData":
            {
                "isVersionSupported": ""
            },
            "deps": "js/aw.UserSettings.Service"
        },
        "revealGroupRoleSettings": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-Administration-2019-06-UserManagement",
            "method": "getGroupRoleViewModelRows",
            "inputData": {
                "input": {
                    "userObject": "{{ctx.selected}}",
                    "startIndex": 0,
                    "pageSize": 50
                }
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{function:getGroupRoleViewModelRows}}"
            },
            "deps": "js/aw.UserSettings.Service"
        },
        "roleAction": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2006-03-Session",
            "method": "getGroupMembership",
            "inputData": {
                "getRoles": "{{function:getListofRoles}}"
            },
            "policy": {
                "types": [
                    {
                        "name": "Group",
                        "properties": [
                            {
                                "name": "object_full_name"
                            }
                        ]
                    },
                    {
                        "name": "Role",
                        "properties": [
                            {
                                "name": "role_name"
                            }
                        ]
                    },
                    {
                        "name": "GroupMember",
                        "properties": [
                            {
                                "name": "status"
                            },
                            {
                                "name": "group"
                            },
                            {
                                "name": "role"
                            },
                            {
                                "name": "default_role"
                            }
                        ]
                    }
                ]
            },
            "outputData": {
                "uniqueRoles": "{{function:getRoles}}",
                "rolesFound": "uniqueRoles.length"
            },
            "deps": "js/aw.UserSettings.Service"
        },
        "myAction": {
            "actionType": "JSFunction",
            "method": "updateState",
            "inputData": {
                "input": "{{data.dataProviders.gridDataProvider}}",
                "eventData": "{{data.eventData}}",
                "context": "{{ctx}}"
            },
            "deps": "js/aw.UserSettings.Service"
        },
        "initializeTabledata": {
            "actionType": "JSFunction",
            "method": "initializeTabledata",
            "inputData": {
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/aw.UserSettings.Service"
        },
        "doGridDataProvider": {
            "actionType": "dataProvider",
            "method": "gridDataProvider"
        }
    },
    "functions": {
        "getListofRoles": {
            "functionName": "getListofRoles",
            "parameters": [
                "{{prop}}"
            ]
        }
    },
    "i18n": {
        "Group": [
            "UsermanagementMessages"
        ],
        "DefaultRole": [
            "UsermanagementMessages"
        ]
    },
    "dataProviders": {
        "gridDataProvider": {
            "action": "revealGroupRoleSettings",
            "editContext": "TABLE_CONTEXT",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}"
        },
        "regionProvider": {
            "dataProviderType": "Action",
            "action": "roleAction",
            "response": "{{data.uniqueRoles}}",
            "totalFound": "{{data.rolesFound}}"
        }
    },
    "columnProviders": {
        "defaultGroupRoleEditColProvider": {
            "frozenColumnIndex": -1,
            "loadColumnAction": "f",
            "columns": [
                {
                    "name": "group",
                    "displayName": "{{i18n.Group}}",
                    "minWidth": 100,
                    "width": 355,
                    "enableColumnMenu": false,
                    "enableColumnMoving": false,
                    "pinnedLeft": false
                },
                {
                    "name": "default_role",
                    "displayName": "{{i18n.DefaultRole}}",
                    "minWidth": 100,
                    "width": 490,
                    "enableColumnMenu": true,
                    "enableColumnMoving": false,
                    "pinnedLeft": false
                }
            ]
        }
    },
    "grids": {
        "groupRoleEditTable": {
            "dataProvider": "gridDataProvider",
            "columnProvider": "defaultGroupRoleEditColProvider",
            "addIconColumn": false,
            "gridOptions": {
                "enableGridMenu": false,
                "enablePinning": false,
                "enableSorting": false
            }
        }
    }
}