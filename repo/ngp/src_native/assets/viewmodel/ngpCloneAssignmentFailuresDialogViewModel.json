{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-popup2.directive",
        "js/aw-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-include.directive",
        "js/aw-repeat.directive",
        "js/aw-flex-column.directive",
        "js/aw-image.directive"

    ],
    "data": {
        "errorIcon": "assets/image/indicatorError16.svg"
    },
    "actions": {

        "closeDialog": {
            "actionType": "JSFunction",
            "method": "hide",
            "inputData": {
                "popupId": "{{data.popupId}}"
            },
            "deps": "js/popupService"
        },
        "initDialog": {
            "actionType": "JSFunction",
            "method": "prepareMessageForTitleNumOfFailures",
            "inputData": {
                "assignmentMappingFailures": "{{subPanelContext}}"
            },
            "outputData": {
                "totalAssignmentFailures": ""
            },
            "deps": "js/services/ngpUiCloneService"
        }
    },
    "lifecycleHooks": {
        "onInit": "initDialog"
    },
    "i18n": {
        "failedToMapAssignments": [ "NgpCloneMgmtMessages" ],
        "close": [ "NgpCloneMgmtMessages" ]

    }
}
