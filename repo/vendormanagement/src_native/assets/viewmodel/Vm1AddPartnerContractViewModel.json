{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive",
        "js/aw-panel-footer.directive",
        "js/aw-form.directive",
        "js/aw-xrt.directive",
        "js/aw-panel-body.directive",
        "js/aw-command-panel.directive",
        "js/aw-panel-section.directive",
        "js/aw-command-panel-section.directive",
        "js/aw-widget.directive",
        "js/aw-list.directive",
        "js/aw-type-cell.directive",
        "js/aw-panel-header.directive",
        "js/aw-back-button.directive"

    ],
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "getContactsList",
            "inputData": {
                "data": "{{data}}"
            },
            "events": {
                "success": [
                    {
                        "name": "registerSelectedPCType"
                    },
                    {
                        "name": "enablePartnerContractTypesProviderEvent"
                    },
                    {
                        "name": "enableAllContactsDataProviderEvent"
                    }
                ]
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "validateContractDates": {
            "actionType": "JSFunction",
            "method": "validateNewContractDates",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "createVendorContractObject": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2016-09-DataManagement",
            "method": "createAttachAndSubmitObjects",
            "inputData": {
                "inputs": "{{function:getCreateInput}}"
            },
            "outputData": {
                "createdMainObject": "output[0].objects[0]",
                "createdObject": "{{function:getCreatedObject}}",
                "createdPartnerContractRevision": "output[0].objects[2]"
            },
            "events": {
                "success": [
                    {
                        "name": "vm1.createRelationsEvent"
                    },
                    {
                        "name": "getPartnerQualificationTemplateName"
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/addObjectUtils"
        },
        "createRelation_PartnerContractAndVendor": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2006-03-DataManagement",
            "method": "createRelations",
            "inputData": {
                "input": [
                    {
                        "primaryObject": "{{ctx.selected}}",
                        "secondaryObject": "{{data.createdPartnerContractRevision}}",
                        "relationType": "Vm0UsesPrtnrContract",
                        "clientId": "",
                        "userData": {
                            "uid": "AAAAAAAAAAAAAA",
                            "type": "unknownType"
                        }
                    }
                ]
            },
            "events": {
                "success": [
                    {
                        "name": "vm1.createContract_ContactsRelationEvent"
                    },
                    {
                        "name": "vm1.createContract_LocationsRelationEvent"
                    },
                    {
                        "name": "vm1.startPartnerContractQulificationWorkflow"
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            }
        },
        "closePanel": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            }
        },
        "createPartnerContractAndContactsRelation": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2006-03-DataManagement",
            "method": "createRelations",
            "inputData": {
                "input": "{{function:getInputForContacts}}"
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "createPartnerContractAndLocationsRelation": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2006-03-DataManagement",
            "method": "createRelations",
            "inputData": {
                "input": "{{function:getInputForLocations}}"
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "startPartnerContractQulificationWorkflow": {
            "actionType": "TcSoaService",
            "serviceName": "Workflow-2008-06-Workflow",
            "method": "createInstance",
            "inputData": {
                "startImmediately": false,
                "observerKey": "",
                "name": "{{data.createdPartnerContractRevision.props.object_string.dbValues[0]}}",
                "subject": "",
                "description": "",
                "contextData": {
                    "processTemplate": "{{ctx.partnerContractRevWorkflowName}}",
                    "attachmentCount": 1,
                    "attachments": [
                        "{{data.createdPartnerContractRevision.uid}}"
                    ],
                    "attachmentTypes": [
                        1
                    ]
                }
            },
            "events": {
                "success": [
                    {
                        "name": "cdm.relatedModified",
                        "eventData": {
                            "relatedModified": [
                                "{{ctx.selected}}"
                            ],
                            "refreshLocationFlag": true
                        }
                    },
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "getCreatablePartnerContractTypeAction": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "{{ctx.sublocation.clientScopeURI}}"
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Awp0TypeSearchProvider",
                    "searchCriteria": {
                        "searchString": "*",
                        "typeSelectorId": "PartnerContractCreate",
                        "listOfIncludeObjectTypes": "Vm0PrtnrContract",
                        "loadSubTypes": "true"
                    },
                    "attributesToInflate": [
                        "parent_types",
                        "type_name",
                        "object_string"
                    ],
                    "startIndex": "{{data.dataProviders.getCreatablePartnerContractTypes.startIndex}}"
                },
                "inflateProperties": true
            },
            "policy": {
                "types": [
                    {
                        "name": "ImanType",
                        "properties": [
                            {
                                "name": "type_name"
                            },
                            {
                                "name": "fnd0InternalName"
                            },
                            {
                                "name": "object_string"
                            }
                        ]
                    }
                ]
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResponse": "{{json:searchResultsJSON}}"
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "enablePartnerContractTypesProvider": {
            "actionType": "dataProvider",
            "method": "getCreatablePartnerContractTypes"
        },
        "enableAllContactsDataProvider": {
            "actionType": "dataProvider",
            "method": "allContactsDataProvider"
        },
        "handlePCTypeSelection": {
            "actionType": "JSFunction",
            "method": "handlePCTypeSelectionJs",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "selectIfOnlyOnePCTypeAction": {
            "actionType": "JSFunction",
            "method": "setSelection",
            "inputData": {
                "selectionModel": "{{data.dataProviders.getCreatablePartnerContractTypes.selectionModel}}",
                "newSelection": "{{data.dataProviders.getCreatablePartnerContractTypes.viewModelCollection.loadedVMObjects[0]}}"
            },
            "events": {
                "success": [
                    {
                        "name": "registerSelectedPCType"
                    }
                ]
            },
            "deps": "js/selectionModelFactory"
        },
        "selectIfOnlyOneContactAction" :{
            "actionType": "JSFunction",
            "method": "selectFirstContact",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "checkIfSingleType": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "selectIfOnlyOnePCTypeEvent",
                        "condition": "data.dataProviders.getCreatablePartnerContractTypes.viewModelCollection.totalFound === 1"
                    }
                ]
            }
        },
        "checkIfSingleContactAvailable": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "selectIfOnlyOneContactEvent",
                        "condition": "data.dataProviders.allContactsDataProvider.viewModelCollection.totalFound === 1"
                    }
                ]
            }
        },
        "clearSelectedPCType": {
            "actionType": "JSFunction",
            "method": "clearSelectedPCType",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1AddPartnerContactService"
        },
        "getPartnerQualificationTemplateName": {
            "actionType": "JSFunction",
            "method": "getPartnerQualificationTemplateName",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1AddPartnerContactService"
        }
    },
    "functions": {
        "getCreateInput": {
            "functionName": "getCreateInput",
            "parameters": [
                "{{data}}"
            ]
        },
        "getInputForContacts": {
            "functionName": "getInputForContacts",
            "parameters": [
                "{{data}}"
            ]
        },
        "getInputForLocations": {
            "functionName": "getInputForLocations",
            "parameters": [
                "{{data}}"
            ]
        }
    },
    "data": {
        "allContactsData": {
            "displayName": "{{i18n.companyContacts}}",
            "type": "STRINGARRAY",
            "isArray": true,
            "dataProvider": "allContactsDataProvider",
            "isRequired": "true"
        },
        "allLocationsData": {
            "displayName": "{{i18n.companyLocations}}",
            "type": "STRINGARRAY",
            "isArray": true,
            "dataProvider": "allLocationsDataProvider"
        },
        "selectedPCType": {
            "type": "STRING",
            "dbValue": ""
        }
    },
    "onEvent": [
        {
            "eventId": "vm1.inputsDataValidated",
            "action": "createVendorContractObject"
        },
        {
            "eventId": "vm1.createRelationsEvent",
            "action": "createRelation_PartnerContractAndVendor"
        },
        {
            "eventId": "awPanel.reveal",
            "action": "reveal"
        },
        {
            "eventId": "vm1.createContract_ContactsRelationEvent",
            "action": "createPartnerContractAndContactsRelation"
        },
        {
            "eventId": "vm1.createContract_LocationsRelationEvent",
            "action": "createPartnerContractAndLocationsRelation"
        },
        {
            "eventId": "vm1.startPartnerContractQulificationWorkflow",
            "action": "startPartnerContractQulificationWorkflow"
        },
        {
            "eventId": "gwt.SubLocationContentSelectionChangeEvent",
            "action": "closePanel"
        },
        {
            "eventId": "enablePartnerContractTypesProviderEvent",
            "action": "enablePartnerContractTypesProvider"
        },
        {
            "eventId": "enableAllContactsDataProviderEvent",
            "action": "enableAllContactsDataProvider"
        },
        {
            "eventId": "getCreatablePartnerContractTypes.selectionChangeEvent",
            "action": "handlePCTypeSelection"
        },
        {
            "eventId": "getCreatablePartnerContractTypes.modelObjectsUpdated",
            "action": "checkIfSingleType"
        },
        {
            "eventId": "allContactsDataProvider.modelObjectsUpdated",
            "action": "checkIfSingleContactAvailable"
        },
        {
            "eventId": "selectIfOnlyOnePCTypeEvent",
            "action": "selectIfOnlyOnePCTypeAction"
        },
        {
            "eventId": "selectIfOnlyOneContactEvent",
            "action": "selectIfOnlyOneContactAction"
        },
        {
            "eventId": "registerSelectedPCType",
            "action": "handlePCTypeSelection"
        },
        {
            "eventId": "getPartnerQualificationTemplateName",
            "action": "getPartnerQualificationTemplateName"
        }
    ],
    "conditions": {
        "isPCTypeSelected": {
            "expression": "data.selectedPCType.dbValue =='' "
        }
    },
    "messages": {
        "soaOperationFailure": {
            "messageType": "ERROR",
            "messageText": "{{errorCode}}"
        }
    },
    "i18n": {
        "add": [
            "VendorManagementMessages"
        ],
        "companyContacts": [
            "VendorManagementMessages"
        ],
        "companyLocations": [
            "VendorManagementMessages"
        ],
        "invalidStartEndDate": [
            "VendorManagementMessages"
        ],
        "vm1PartnerDetails": [
            "VendorManagementMessages"
        ],
        "objectType": [
            "VendorManagementMessages"
        ]
    },
    "dataProviders": {
        "getCreatablePartnerContractTypes": {
            "action": "getCreatablePartnerContractTypeAction",
            "response": "{{data.searchResponse}}",
            "totalFound": "{{data.totalFound}}",
            "preSelection": false,
            "selectionModelMode": "single"
        },
        "allContactsDataProvider": {
            "response": "{{data.allContactsList}}",
            "moreValuesExist": false
        },
        "allLocationsDataProvider": {
            "response": "{{data.allLocationsList}}",
            "moreValuesExist": false
        }
    }
}
