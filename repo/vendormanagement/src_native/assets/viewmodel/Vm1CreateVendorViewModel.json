{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-command-sub-panel.directive",
        "js/visible-when.directive",
        "js/aw-init.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "initializeCreateVendorPanel",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Vm1CreateVendorService"
        },
        "closePanel": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            }
        },
        "clearPCTypeSelectionInCtx": {
            "actionType": "JSFunction",
            "method": "unRegisterCtx",
            "inputData": {
                "name": "isPCTypeNotSelected"
            },
            "deps": "js/appCtxService"
        }
    },
    "onEvent": [
        {
            "eventId": "gwt.SubLocationContentSelectionChangeEvent",
            "action": "closePanel"
        }
    ],
    "lifecycleHooks": {
        "onUnmount": "clearPCTypeSelectionInCtx"
    },
    "i18n": {
        "createVendor": [
            "VendorManagementMessages"
        ]
    }
}
