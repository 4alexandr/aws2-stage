{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive",
        "js/aw-panel-footer.directive",
        "js/aw-list-filter.directive",
        "js/aw-panel-body.directive",
        "js/aw-command-panel.directive",
        "js/aw-panel-section.directive",
        "js/aw-default-cell.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "dataProvider",
            "method": "getRelevantCompanyContacts"
        },
        "searchValidCompanyContacts": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2007-09-DataManagement",
            "method": "expandGRMRelationsForSecondary",
            "inputData": {
                "secondaryObjects": [
                    {
                        "uid": "{{ctx.selected.uid}}",
                        "type": ""
                    }
                ],
                "pref": {
                    "expItemRev": true,
                    "returnRelations": true,
                    "info": [
                        {
                            "relationTypeName": "Vm0UsesPrtnrContract",
                            "otherSideObjectTypes": [
                                "Vendor"
                            ]
                        }
                    ]
                }
            },
            "outputData": {
                "relatedVendorObj": "output[0].relationshipData[0].relationshipObjects[0].otherSideObject",
                "FilteredContacts": "{{function:getAllTheValidCompanyContacts}}"
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1GetValidCompanyContactService"
        },
        "createVendorContractObjectRelation": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2006-03-DataManagement",
            "method": "createRelations",
            "inputData": {
                "input": "{{function:getCreateRelationData}}"
            },
            "events": {
                "success": [
                    {
                        "name": "cdm.relatedModified",
                        "eventData": {
                            "refreshLocationFlag": true,
                            "relations": "",
                            "relatedModified": [
                                "{{ctx.selected}}"
                            ]
                        }
                    },
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1GetValidCompanyContactService"
        }
    },
    "functions": {
        "getAllTheValidCompanyContacts": {
            "functionName": "getAllTheValidCompanyContacts",
            "parameters": [
                "{{data}}",
                "{{ctx}}"
            ]
        },
        "getCreateRelationData": {
            "functionName": "getCreateRelationData",
            "parameters": [
                "{{ctx}}",
                "{{data}}"
            ]
        }
    },
    "data": {
        "filterBox": {
            "displayName": "MyFilter",
            "type": "STRING",
            "dbValue": ""
        }
    },
    "onEvent": [
        {
            "eventId": "dataProvider.reset",
            "action": "reveal"
        }
    ],
    "conditions": {
        "isCompanyContactSelected": {
            "expression": "data.dataProviders.getRelevantCompanyContacts.selectedObjects.length > 0"
        },
        "checkSelectionChange": {
            "expression": "name == 'selected'"
        }
    },
    "i18n": {
        "vm1Assign": [
            "VendorManagementMessages"
        ],
        "vm1AddContractCommandTitle": [
            "VendorManagementMessages"
        ],
        "Vm1AddContactToContract": [
            "VendorManagementMessages"
        ],
        "Vm1companyContacts": [
            "VendorManagementMessages"
        ],
        "Vm1AddCompanyContact": [
            "VendorManagementMessages"
        ],
        "add":[
            "VendorManagementMessages"
        ]
    },
    "dataProviders": {
        "getRelevantCompanyContacts": {
            "action": "searchValidCompanyContacts",
            "selectionModelMode": "multiple",
            "response": "{{data.FilteredContacts}}",
            "totalFound": "{{data.FilteredContacts.length}}",
            "commands": {
                "Awp0ShowObjectCell": {
                    "id": "cmdOpen",
                    "title": "Open",
                    "areas": [
                        "com.siemens.splm.clientfx.ui.modelObjectListActionCommands"
                    ],
                    "priorities": [
                        300
                    ],
                    "dependencies": [
                        "js/showObjectCommandHandler"
                    ],
                    "displayOption": "ON_HOVER_AND_SELECTION",
                    "position": "TOP_RIGHT"
                }
            }
        }
    },
    "messages": {
        "soaOperationFailure": {
            "messageType": "ERROR",
            "messageText": "{{errorCode}}"
        }
    }
}
