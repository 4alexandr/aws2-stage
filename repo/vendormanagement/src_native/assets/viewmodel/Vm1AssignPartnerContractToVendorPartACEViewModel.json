{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-listbox.directive",
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-scrollpanel.directive",
        "js/aw-list.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive",
        "js/aw-default-cell.directive"
    ],

    "actions":
    {
        "reveal":
        {
            "actionType": "TcSoaService",
            "serviceName": "Core-2007-09-DataManagement",
            "method": "expandGRMRelationsForSecondary",
            "inputData":
            {
                "secondaryObjects": [
                    {
                        "uid": "{{ctx.selected.uid}}",
                        "type": ""
                    }
                ],
                "pref":
                {
                    "expItemRev": false,
                    "returnRelations": true,
                    "info":
                    [
                        {
                            "relationTypeName": "VMRepresents",
                            "otherSideObjectTypes": ""
                        }
                    ]
                }
            },
            "outputData":
            {
                "relatedCommPartObj": "output[0].relationshipData[0].relationshipObjects[0].otherSideObject"
            },
            "events":
            {
                "success":
                [
                    {
                        "name": "calldataprovider"
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            }
        },

        "calldataprovider":
        {
            "actionType": "dataProvider",
            "method": "getPartnerContracts"
        },

        "getPartnerContractsOfCommercialPart":
        {
            "actionType": "TcSoaService",
            "serviceName": "Internal-VendorManagementAW-2019-12-VendorManagement",
            "method": "getPartnerContractsOfSelectedObject",
            "inputData": {
                "inputObject": {
                    "uid": "{{data.relatedCommPartObj.uid}}",
                    "type": ""
                }
            },
            "outputData":
            {
                "searchResults": "{{function:getContractObjects}}",
                "totalFound": "totalFound"
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AssignPartnerContractService"
        },

        "attachOrDetachLicenseToVP":
        {
            "actionType": "TcSoaService",
            "serviceName": "AuthorizedDataAccess-2017-05-LicenseManagement",
            "method": "attachOrDetachLicensesFromObjects",

            "inputData":
            {
                "licenseAttachOrDetachInput": "{{function:attachOrDetachInput}}"
            },
            "outputData":
            {
                "partialErrors": "partialErrors",
                "errorMessage": "{{function:processPartialErrorsFromSOA}}"
            },
            "events":
            {
                "success":
                [
                    {
                        "name": "complete",
                        "eventData":
                        {
                            "source": "toolAndInfoPanel"
                        }
                    },
                    {
                        "name": "cdm.relatedModified",
                        "eventData": {
                            "refreshLocationFlag": true,
                            "relations": "",
                            "relatedModified": [
                                "{{ctx.mselected[0]}}"
                            ]
                        }
                    }
                ],
                "failure":
                [
                    {
                        "name": "complete",
                        "eventData":
                        {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "actionMessages": {
                "failure": [ {
                    "message": "soaOperationFailure"
                } ]
            },
            "deps": "js/Vm1AssignPartnerContractService"
        }
    },

    "onEvent":
    [
        {
            "eventId": "getPartnerContractsOfCommercialPart",
            "action": "getPartnerContractsOfCommercialPart"
        },
        {
            "eventId": "calldataprovider",
            "action": "calldataprovider"
        }
    ],

    "i18n":
    {
        "vm1Assign": [
            "VendorManagementMessages"
        ],
        "vm1AssignPartnerContracts": [
            "VendorManagementMessages"
        ]
    },

    "functions":
    {
        "getContractObjects":
        {
            "functionName": "getContractObjects",
            "parameters": ["{{ctx}}"]
        },
        "attachOrDetachInput":
        {
            "functionName": "attachOrDetachInput",
            "parameters": ["{{data}}", "{{ctx}}"]
        }
    },

    "conditions":
    {
        "showAssignButton": {
            "expression": "data.dataProviders.getPartnerContracts.selectedObjects.length > 0"
        }
    },

    "dataProviders": {

        "getPartnerContracts":
        {
            "action": "getPartnerContractsOfCommercialPart",
            "selectionModelMode": "multiple",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.searchResults.length}}",
            "commands":
            {
                "Awp0ShowObjectCell":
                {
                    "id": "cmdOpen",
                    "title": "Open",
                    "areas": [ "com.siemens.splm.clientfx.ui.modelObjectListActionCommands" ],
                    "priorities": [ 300 ],
                    "dependencies": [ "js/showObjectCommandHandler" ],
                    "displayOption": "ON_HOVER_AND_SELECTION",
                    "position": "TOP_RIGHT"
                }
            }
        }
    },
    "messages": {
        "soaOperationFailure": {
            "messageType": "ERROR",
            "messageText": "{{errorCode}}"
        }
    }
}
