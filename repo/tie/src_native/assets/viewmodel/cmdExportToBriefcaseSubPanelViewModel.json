                ]
        },
        "singleSelectionBriefcaseExportStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.singleSelectionBriefcaseExportStartedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected[0].props.object_string.uiValues[0]}}",
                "{{data.briefcaseName.dbValue}}"
                ]
        },
        "multipleSelectionBriefcaseExportStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.multipleSelectionBriefcaseExportStartedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected.length}}",
                "{{data.briefcaseName.dbValue}}"
                ]
        },
        "singleSelectionBriefcaseExportFailed":
        {
            "messageType": "ERROR",
            "messageText": "{{i18n.singleSelectionBriefcaseExportFailedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected[0].props.object_string.uiValues[0]}}",
                "{{data.briefcaseName.dbValue}}",
                "{{data.exportPartialErrors[0].errorValues[0].message}}"
                ]
        },
        "multipleSelectionBriefcaseExportFailed":
        {
            "messageType": "ERROR",
            "messageText": "{{i18n.multipleSelectionBriefcaseExportFailedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected.length}}",
                "{{data.briefcaseName.dbValue}}",
                "{{data.exportPartialErrors[0].errorValues[0].message}}"
                ]
        },
        "singleSelectionBriefcaseValidateAndExportStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.singleSelectionBriefcaseValidateAndExportStartedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected[0].props.object_string.uiValues[0]}}",
                "{{data.briefcaseName.dbValue}}"
                ]
        },
        "multipleSelectionBriefcaseValidateAndExportStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.multipleSelectionBriefcaseValidateAndExportStartedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected.length}}",
                "{{data.briefcaseName.dbValue}}"
                ]
        },
        "singleSelectionBriefcaseValidateAndExportFailed":
        {
            "messageType": "ERROR",
            "messageText": "{{i18n.singleSelectionBriefcaseValidateAndExportFailedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected[0].props.object_string.uiValues[0]}}",
                "{{data.briefcaseName.dbValue}}",
                "{{data.exportPartialErrors[0].errorValues[0].message}}"
                ]
        },
        "multipleSelectionBriefcaseValidateAndExportFailed":
        {
            "messageType": "ERROR",
            "messageText": "{{i18n.multipleSelectionBriefcaseValidateAndExportFailedMessage}}",
            "messageTextParams": [
                "{{ctx.mselected.length}}",
                "{{data.briefcaseName.dbValue}}",
                "{{data.exportPartialErrors[0].errorValues[0].message}}"
                ]
        }
    },
