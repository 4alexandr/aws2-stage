{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-flex-row.directive",
        "js/aw-flex-column.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-panel-section.directive",
        "js/aw-listbox.directive",
        "js/aw-list.directive",
        "js/aw-radiobutton.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/aw-command-panel-section.directive",
        "js/aw-icon.directive",
        "js/aw-icon-button.directive",
        "js/aw-label.directive",
        "js/aw-widget.directive",
        "js/visible-when.directive",
        "js/aw-file-upload.directive"
        ],
    "actions": {

    "remoteOverrideOpt": {
            "actionType": "JSFunction",
            "method": "remoteOverrideOptionFromList",
            "deps": "js/exportToBriefcase",
            "inputData": {
                "data": "{{data}}"
            }
    },

    "validateOptChanged": {
            "actionType": "JSFunction",
            "method": "updateOverrideContext",
            "deps": "js/exportToBriefcase",
            "inputData": {
                "data": "{{data}}"
            }
    },

    "importBriefcase": {
            "actionType": "JSFunction",
            "method": "populateImportBriefcaseData",
            "inputData": {
            "data": "{{data}}",
            "validateOnly" : false,
            "ctx" :"{{ctx}}"
        },
            "events": {
            "success": [{
                 "name": "importBriefcase.getFMSFileTicket"
            }]
        },

        "deps": "js/importFromBriefcase"
    },


    "validateBriefcase": {
        "actionType": "JSFunction",
        "method": "populateImportBriefcaseData",
        "inputData": {
            "data": "{{data}}",
            "validateOnly" : true,
            "ctx" :"{{ctx}}"
        },

        "events": {
        "success": [{
             "name": "importBriefcase.getFMSFileTicket"
           }]
       },
    "deps": "js/importFromBriefcase"

    },

    "getFMSTicket": {
        "actionType": "TcSoaService",
        "serviceName": "Core-2007-01-FileManagement",
        "method": "getTransientFileTicketsForUpload",
        "inputData": {
            "transientFileInfos": [{
                "fileName": "{{data.fileName}}",
                "isBinary": true,
                "deleteFlag": true
            }]
        },
        "outputData": {
            "fmsTicket": "transientFileTicketInfos[0].ticket"
        },

        "events": {
            "success": [{
                "name": "fmsTicket.updateBriefcase"
            }]
        }
    },

    "updateFormData": {
        "actionType": "JSFunction",
        "method": "updateFormData",
        "inputData": {
            "fileData": {
                "key": "fmsTicket",
                "value": "{{data.fmsTicket}}"
            },
            "data": "{{data}}"
        },
        "events": {
            "success": [{
                "name": "importBriefcase.gotTransientFileTicket"
            }]
        },
        "deps": "js/declUtils"
    },

    "uploadBriefcaseFile": {
        "actionType": "RESTService",
        "serviceName": "",
        "method": "POST",
        "inputData": {
            "request": {
                "method": "POST",
                "url": "{{Constants.fmsUrl}}",
                "headers": {
                    "Content-type": "undefined"
                },
                "data": "{{data.formData}}"
            }
        },
        "events": {
            "success": [{
                "name": "fmsTicket.actionBriefcaseImport"
            }]
        }
    },

    "ImportBriefcaseInternal": {
        "actionType": "TcSoaService",
        "serviceName": "Internal-TCXMLImportExport-2020-12-Briefcase",
        "method": "importObjectsFromBriefcase",
        "inputData": {
            "input": "{{function:getSOAInputForBriefcaseImport}}"
        },

        "outputData": {
            "serviceData": "ServiceData"
        },

        "deps": "js/importFromBriefcase",

        "events": {
            "success": [
                {
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                }
            ]
        },
        "actionMessages": {
            "success": [
                {
                       "condition": "!data.importDryrun",
                        "message": "briefcaseImportStarted"
                },
                {

                    "condition": "data.importDryrun",
                    "message": "briefcaseValidationStarted"
                }
            ],
            "failure": [
                {
                    "condition": "data.serviceData.partialErrors.length > 0",
                    "message": "briefcaseImportFailed"
                }
            ]
        }
    },

    "populateXferOption": {
        "actionType": "Event",
        "method": "Event",
        "inputData": {
            "events": [ {
                "name": "importBriefcase.getXferOptionSets",
                "condition": "data.fileName && data.validFile"
             },
             {
                 "name": "importBriefcase.clearXferOptionSets",
                 "condition": "data.fileName && !data.validFile"
             }
         ]}
    },

    "getXferOptionSets":{
        "actionType": "JSFunction",
            "method": "getTransferOptionSets",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}",
                "isExport" : false
            },
            "deps": "js/exportToBriefcase"

    },

    "clearXferOptionSets":{
        "actionType": "JSFunction",
            "method": "clearTransferOptionSets",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/importFromBriefcase"

    },

    "transferOptionChanged": {
            "actionType": "JSFunction",
            "method": "saveTransferOptionSetContext",
            "deps": "js/exportToBriefcase",
            "inputData": {
                "data": "{{data}}",
                "isCalledFromExport" : false
            }
        }
    },
    "onEvent": [
        {
            "eventId": "importBriefcase.getXferOptionSets",
            "action": "getXferOptionSets"
        },
        {
            "eventId": "importBriefcase.getFMSFileTicket",
            "action": "getFMSTicket"
        },
        {
            "eventId": "fmsTicket.updateBriefcase",
            "action": "updateFormData"
        },
        {
            "eventId": "importBriefcase.gotTransientFileTicket",
            "action": "uploadBriefcaseFile"
        },
        {
            "eventId": "fmsTicket.actionBriefcaseImport",
            "action": "ImportBriefcaseInternal"
        },
        {
            "eventId": "importBriefcase.clearXferOptionSets",
            "action": "clearXferOptionSets"
        }
    ],

    "functions": {
            "getSOAInputForBriefcaseImport": {
            "functionName": "getSOAInputForBriefcaseImport",
            "parameters": [
                "{{data}}"
            ]
        }
    },
    "data": {

        "TOSCommandAnchor" : "tos_section_anchor",

        "removeOptCommand": {
            "action": "remoteOverrideOpt",
            "iconName": "Remove",
            "tooltip": "Remove"
        },

        "transferOptionSetListBox": {
            "displayName": "{{i18n.transferOptionSet}}",
            "type": "STRING",
            "isRequired": "true",
            "hasLov": "true",
            "dbValue": "",
            "dispValue": ""
        },

        "validateRadio": {
            "displayName": "{{i18n.validate}}",
            "type": "BOOLEAN",
            "isRequired": "false",
            "isEditable": "true",
            "dbValue": false,
            "labelPosition": "PROPERTY_LABEL_AT_SIDE",
            "propertyRadioTrueText": "{{i18n.Yes}}",
            "propertyRadioFalseText": "{{i18n.No}}"
        }
    },

    "conditions": {

        "isValidFile": {
            "expression": "data.fileName && data.validFile == true"
        },

        "isLLImport": {
            "expression": "conditions.isValidFile && data.transferOptionSetListBox.dbValue  && data.isLowLevel"
        },

        "isTransferOptionSetSelected": {
            "expression": "conditions.isValidFile && data.transferOptionSetListBox.dbValue"
        },

        "enableImport":{
            "expression": "conditions.isValidFile && conditions.isTransferOptionSetSelected"
        },

        "isValidateYes": {
            "expression": "conditions.isValidFile && data.validateRadio.dbValue === true"
        }
    },

    "messages": {
        "briefcaseImportStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.briefcaseImportStartedMessage}}",
            "messageTextParams": [
                "{{data.fileName}}"
                ]
        },

        "briefcaseValidationStarted":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.singleSelectionBriefcaseValidateStartedMessage}}",
            "messageTextParams": [
                "{{data.fileName}}"
                ]
        },

        "briefcaseImportFailed":
        {
            "messageType": "ERROR",
            "messageText": "{{i18n.briefcaseImportFailedMessage}}",
            "messageTextParams": [
                "{{data.fileName}}",
                "{{data.serviceData.partialErrors[0].errorValues[0].message}}"
                ]
        }
    },

    "i18n": {
        "cmdImportButton": [
            "tieMessages"
        ],
        "transferOptionSet": [
            "tieMessages"
        ],
        "optionOverrides":[
            "tieMessages"
        ],
        "cmdValidateButton":[
            "tieMessages"
        ],

        "briefcaseImportStartedMessage":[
            "tieMessages"
        ],

        "singleSelectionBriefcaseValidateStartedMessage":[
            "tieMessages"
        ],

        "briefcaseImportFailedMessage":[
            "tieMessages"
        ],

        "validate": [
            "tieMessages"
        ],

        "Yes":[
            "tieMessages"
        ],

        "No":[
            "tieMessages"
        ]
    }
}
