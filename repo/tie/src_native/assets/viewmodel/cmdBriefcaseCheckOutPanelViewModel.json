{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-listbox.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/aw-radiobutton.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "TcSoaService",
            "serviceName": "GlobalMultiSite-2007-12-ImportExport",
            "method": "getRemoteSites",
            "inputData": {
                "siteType": "OfflineGMS"
            },
            "policy": {
                "types": [
                    {
                        "name": "POM_imc",
                        "properties": [
                            {
                                "name": "name"
                            }
                        ]
                    }
                ]
            },
            "outputData": {
                "targetSitesListBoxValues": "{{function:getTargetSitesForExport}}"
            },
            "deps": "js/exportToBriefcase"
        },
        "changeSiteType": {
            "actionType": "JSFunction",
            "method": "changeSiteTypeSelection",
            "inputData": {
                "data": "{{data}}",
                "isExportPanel": false
            },
            "deps": "js/exportToBriefcase"
        },
        "performBriefcaseCheckOut": {
            "actionType": "TcSoaService",
            "serviceName": "GlobalMultiSite-2007-06-SiteReservation",
            "method": "siteCheckOut",
            "inputData": {
                "objects": "{{function:getSelectedObjects}}",
                "siteId": "{{function:getSiteForCheckout}}",
                "changeId": "",
                "comment": ""
            },
            "policy": {
                "types": [
                    {
                        "name": "WorkspaceObject",
                        "properties": [
                            {
                                "name": "checked_out"
                            },
                            {
                                "name": "checked_out_user"
                            }
                        ]
                    }
                ]
            },
            "outputData": {
                "errors": "{{function:processBriefcaseCheckoutPartialErrors}}"
            },
            "events": {
                "success": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    },
                    {
                        "name": "cdm.relatedModified",
                        "eventData": {
                            "relatedModified": [
                                "{{ctx.mselected}}"
                            ]
                        }
                    }
                ],
                "failure": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "deps": "js/briefcaseCico"
        }
    },
    "onEvent": [
        {
            "eventId": "awPanel.reveal",
            "action": "getTargetSite",
            "condition": "conditions.isContentLoaded"
        }
    ],
    "messages": {},
    "functions": {
        "getTargetSitesForExport": {
            "functionName": "getTargetSitesForExport",
            "parameters": [
                "{{data}}",
                "{{response}}"
            ]
        },
        "getSiteForCheckout": {
            "functionName": "getSiteForCheckout",
            "parameters": [
                "{{data}}"
            ]
        },
        "getSelectedObjects": {
            "functionName": "getSelectedObjects",
            "parameters": [
                "{{ctx}}",
                "{{data}}"
            ]
        },
        "processBriefcaseCheckoutPartialErrors": {
            "functionName": "processBriefcaseCheckoutPartialErrors",
            "parameters": [
                "{{ctx}}"
            ]
        }
    },
    "data": {
        "isContentLoaded": {
            "dbValue": false,
            "type": "BOOLEAN"
        },
        "siteTypeRadioButton": {
            "displayName": "{{i18n.targetType}}",
            "type": "BOOLEAN",
            "isRequired": "false",
            "isEditable": "true",
            "dbValue": true,
            "vertical": false,
            "labelPosition": "NO_PROPERTY_LABEL",
            "propertyRadioTrueText": "{{i18n.Teamcenter}}",
            "propertyRadioFalseText": "{{i18n.BriefcaseBrowser}}"
        },
        "targetSitesListBox": {
            "displayName": "{{i18n.targetSites}}",
            "type": "STRING",
            "hasLov": true,
            "dbValue": "",
            "dispValue": "",
            "isRequired": "true"
        }
    },
    "conditions": {
        "isTargetSiteSelected": {
            "expression": "data.targetSitesListBox.dbValue && data.targetSitesListBox.uiValue.length > 0"
        }
    },
    "i18n": {
        "cmdBriefcaseCheckOut": [
            "tieMessages"
        ],
        "targetSites": [
            "tieMessages"
        ],
        "cmdCheckOut": [
            "tieMessages"
        ],
        "Teamcenter": [
            "tieMessages"
        ],
        "BriefcaseBrowser": [
            "tieMessages"
        ],
        "targetType": [
            "tieMessages"
        ]
    }
}
