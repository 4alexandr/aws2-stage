{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-command-panel-section.directive",
        "js/aw-checkbox.directive",
        "js/aw-i18n.directive"
    ],
    "actions": {
        "loadTransferOptionsOverridePanel": {
          "actionType": "JSFunction",
          "method": "loadTransferOptionOverridePanel",
          "deps": "js/exportToBriefcase",
          "inputData": {
            "data": "{{data}}"
          }
        },
        "updateTransferOptionSetOverrides" : 
        {
            "actionType": "JSFunction",
            "method": "updateTransferOptionSetOverrides",
            "deps": "js/exportToBriefcase",
            "inputData": {
              "data": "{{data}}"
            }
        },
        "navigateToPanel":
        {
            "actionType": "Event",
            "method": "Event",
            "inputData":
            {
                "events":
                [
                    {
                        "name": "awPanel.navigate",
                        "eventData":
                        {
                            "destPanelId": "{{ctx.navigateToPanel}}",
                            "eventData": "{{data.eventData}}"
                        }
                    }
                ]
            }
        },
        "overrideButtonClicked":
        {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "transferOptionSet.OverrideSelected"
                    },
                    {
                        "name": "transferOptionSet.ReloadProvider"
                    }
                ]
            }
        }
        
    },
    "onEvent": [
        {
        "eventId": "awPanel.reveal",
        "action": "loadTransferOptionsOverridePanel"
        },
        {
            "eventId": "transferOptionSet.OverrideSelected",
            "action": "updateTransferOptionSetOverrides"
        },
        {
            "eventId": "transferOptionSet.OverrideSelected",
            "action": "navigateToPanel"
        }
    ],
    "data": {
    },
    "conditions": {
        "isLLBriefcase":{
            "expression" : "ctx.isLLBriefcase == true"
        }
    },
    "messages": {
    },
    "i18n": {
        "cmdOverrideButton": [
            "tieMessages"
        ]
    }
    
}
