    "actions": {
      "S2claddCommentAction": {
        "actionType": "JSFunction",
        "method": "addCommentary",
        "deps": "js/S2clSocialService",
        "inputData": {
          "commandId": "S2clSCAddCommentNew",
          "objects": [
            {
              "uid": "{{ctx.selected.uid}}",
              "type": "{{ctx.selected.type}}"
            }
          ]
        }
      },
      "S2claddQuestionAction": {
        "actionType": "JSFunction",
        "method": "addCommentary",
        "deps": "js/S2clSocialService",
        "inputData": {
          "commandId": "S2clSCAddQuestionNew",
          "objects": [
            {
              "uid": "{{ctx.selected.uid}}",
              "type": "{{ctx.selected.type}}"
            }
          ]
        }
      },
      "S2claddAnswerAction": {
        "actionType": "JSFunction",
        "method": "addCommentary",
        "deps": "js/S2clSocialService",
        "inputData": {
          "commandId": "S2clSCAddAnswerNew",
          "objects": [
            {
              "uid": "{{commandContext.vmo.uid}}",
              "type": "{{commandContext.vmo.type}}"
            }
          ]
        }
      },
      "S2claddRatingAction": {
        "actionType": "JSFunction",
        "method": "addCommentary",
        "deps": "js/S2clSocialService",
        "inputData": {
          "commandId": "S2clSCAddRatingNew",
          "objects": [
            {
              "uid": "{{commandContext.vmo.uid}}",
              "type": "{{commandContext.vmo.type}}",
              "rating": "{{ctx.Social.rating}}"
            }
          ]
        }
      },
      "S2clrateHelpfulAnswerAction": {
        "actionType": "TcSoaService",
        "serviceName": "Services-2012-10-SocialCollaboration",
        "method": "createComment",
        "inputData": {
          "request": {
            "commentType": "S2clToggleRating",
            "contextObjectUids": [],
            "objectName": "",
            "plainText": "",
            "ratingValue": 1,
            "richText": "",
            "sendToObjectUids": [],
            "tagNameString": "",
            "targetObjectUid": "{{commandContext.vmo.uid}}"
          }
        },
        "outputData": {
          "isSuccess": "isSuccess",
          "message": "message"
        },
        "deps": "js/S2clSocialService",
        "events": {
          "success": [
            {
              "name": "S2clrateHelpfulAnswer.completed"
            }
          ]
        },
        "actionMessages": {
          "failure": [
            {
              "message": "postFailed"
            }
          ]
        }
      },
      "S2clrateHelpfulCommentAction": {
        "actionType": "TcSoaService",
        "serviceName": "Services-2012-10-SocialCollaboration",
        "method": "createComment",
        "inputData": {
          "request": {
            "commentType": "S2clToggleRating",
            "contextObjectUids": [],
            "objectName": "",
            "plainText": "",
            "ratingValue": 1,
            "richText": "",
            "sendToObjectUids": [],
            "tagNameString": "",
            "targetObjectUid": "{{commandContext.vmo.uid}}"
          }
        },
        "outputData": {
          "isSuccess": "isSuccess",
          "message": "message"
        },
        "deps": "js/S2clSocialService",
        "events": {
          "success": [
            {
              "name": "S2clrateHelpfulComment.completed"
            }
          ]
        },
        "actionMessages": {
          "failure": [
            {
              "message": "postFailed"
            }
          ]
        }
      },
      "S2clopenTargetAction": {
        "actionType": "Navigate",
        "navigateTo": "com_siemens_splm_clientfx_tcui_xrt_showObject",
        "navigationParams": {
          "uid": "{{commandContext.vmo.uid}}"
        }
      }
    },
    "conditions": {
      "isComment": {
        "expression": "commandContext.vmo.type ===  'S2clCommentary' && !commandContext.vmo.isHelpfulByThisUser"
      },
      "isAnswer": {
        "expression": "commandContext.vmo.type === 'S2clAnswer' && !commandContext.vmo.isHelpfulByThisUser"
      },
      "isAlreadyHelpful": {
        "expression": " commandContext.vmo.isHelpfulByThisUser "
      },
      "isQuestion": {
        "expression": " (commandContext.vmo.type ===  'S2clQuestion') "
      },
      "showOpenOnQuestion": {
        "expression": "ctx.xrtSummaryContextObject.type !== 'S2clQuestion' || ctx.xrtSummaryContextObject.type === 'S2clQuestion' && commandContext.vmo.type !== 'S2clQuestion'"
      },
      "isSocialType": {
        "expression": "ctx.selected && (ctx.selected.modelType.typeHierarchyArray.indexOf( 'S2clQuestion' ) > -1 || ctx.selected.modelType.typeHierarchyArray.indexOf( 'S2clAnswer' ) > -1 || ctx.selected.modelType.typeHierarchyArray.indexOf( 'S2clCommentary' ) > -1)"
      },
      "isSocialPage": {
        "expression": "ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Collaboration' || ctx.xrtPageContext.secondaryXrtPageID === 'tc_xrt_Collaboration'"
      },
      "S2clstartEditOverride": {
        "expression": "conditions.isStartEditAllowed && ( conditions.isSocialPage || conditions.isSocialType )"
      },
      "socialObjectOpenInRACActiveCondition": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.awp0OpenInRACCommandCondition",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "ctx.selected",
              "$query": {
                "$source": "modelType.typeHierarchyArray",
                "$query": {
                  "$in": [
                    "S2clQuestion",
                    "S2clAnswer",
                    "S2clCommentary"
                  ]
                }
              }
            }
          ]
        }
      },
      "socialObjectCheckOutActiveCondition": {
        "expression": {
          "$and": [
            {
              "$source": "conditions.checkSelections",
              "$query": {
                "$eq": true
              }
            },
            {
              "$source": "ctx.selected",
              "$query": {
                "$source": "modelType.typeHierarchyArray",
                "$query": {
                  "$in": [
                    "S2clQuestion",
                    "S2clAnswer",
                    "S2clCommentary"
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "messages": {
      "postFailed": {
        "messageType": "INFO",
        "messageText": "{{message}}"
      }
    },
    "functions": {
      "getObjectUID": {
        "functionName": "getObjectUID",
