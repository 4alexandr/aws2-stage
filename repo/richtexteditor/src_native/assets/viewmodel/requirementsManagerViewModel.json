{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-class.directive",
        "js/aw-column.directive",
        "js/aw-header-title.directive",
        "js/aw-row.directive",
        "js/aw-flex-row.directive",
        "js/aw-flex-column.directive",
        "js/aw-panel.directive",
        "js/aw-panel-header.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-section.directive",
        "js/aw-tile-canvas.directive",
        "js/aw-global-search.directive",
        "js/aw-logo.directive",
        "js/aw-list.directive",
        "js/aw-include.directive",
        "js/aw-icon.directive",
        "js/aw-command-panel-section.directive"
    ],
    "dataProviders": {
        "recentDataProvider": {
            "action": "loadRecentRequirements",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFoundRelated}}",
            "selectionModelMode": "multiple",
            "commandsAnchor": "com.siemens.splm.clientfx.tcui.commands.modelObjectCellListActionCommands"
        }
    },
    "data": {
        "typeFilter": "Requirement Revision,Paragraph Revision,RequirementSpec Revision",
        "recentCommands": "arm0_recentCommands",
        "recentPrev": "arm0_recentPrev",
        "recentNext": "arm0_recentNext",
        "totalFoundRelated": {
            "type": "INTEGER",
            "dbValue": 0
        }
    },
    "actions": {
        "constructHeader": {
            "actionType": "batchJob",
            "steps": [ {
                    "action": "constructTitles"
                },
                {
                    "action": "setTitlesInCtx"
                }
            ]
        },
        "constructTitles": {
            "actionType": "JSFunctionAsync",
            "method": "getTitles",
            "deps": "js/awHeaderService",
            "outputData": {
                "browserTitle": "result.browserTitle",
                "browserSubTitle": "result.browserSubTitle",
                "headerTitle": "result.headerTitle"
            }
        },
        "setTitlesInCtx": {
            "actionType": "JSFunction",
            "method": "updateCtx",
            "deps": "js/appCtxService",
            "inputData": {
                "name": "location.titles",
                "value": {
                    "browserTitle": "{{data.browserTitle}}",
                    "browserSubTitle": "{{data.browserSubTitle}}",
                    "headerTitle": "{{data.headerTitle}}"
                }
            }
        },
        "reveal":
        {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2018-05-DataManagement",
            "method": "getCurrentUserGateway2",
            "inputData":
            {
            },
            "outputData":
            {
                "tileGroups": "tileGroups"
            },
            "actionMessages":
            {
                "failure":
                [
                    {
                        "message": "accessingGatewayFailed"
                    }
                ]
            },
            "events": {
                "success": [ {
                    "name": "requirementsManager.loadRecentRequirementsAction"
                }]
            }
        },
        "loadRecentRequirements": {
            "actionType": "JSFunction",
            "method": "loadRecentRequirements",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/requirementsManager"
        },
        "loadRecentRequirementsAction": {
            "actionType": "dataProvider",
            "method": "recentDataProvider"
        },
        "getPreviousRecentObjects": {
            "actionType": "JSFunction",
            "method": "getPreviousRecentObjects",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/requirementsManager"
        },
        "getNextRecentObjects": {
            "actionType": "JSFunction",
            "method": "getNextRecentObjects",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/requirementsManager"
        }
    },
    "onEvent": [
        {
            "eventId": "requirementsManager.loadRecentRequirementsAction",
            "action": "loadRecentRequirementsAction"
        },
        {
            "eventId": "requirementsManager.getPreviousRecentObjectsEvent",
            "action": "getPreviousRecentObjects"
        },
        {
            "eventId": "requirementsManager.getNextRecentObjectsEvent",
            "action": "getNextRecentObjects"
        }
    ],
    "i18n": {
        "requirementsManagerDisplayName": [
            "RequirementsManagerMessages"
        ],
        "recents": [
            "RequirementsManagerMessages"
        ],
        "getStarted": [
            "RequirementsManagerMessages"
        ],
        "recentSectionTitle": [
            "awAddDirectiveMessages"
        ],
        "noRecentReq": [
            "RequirementsManagerMessages"
        ]
    },
    "conditions": {
        "isPreviousCmdVisible": {
            "expression": "data.pageIndex > 1"
        },
        "isNextCmdVisible": {
            "expression": "data.pageIndex !== data.pageSize"
        }
    },
    "messages": {}
}