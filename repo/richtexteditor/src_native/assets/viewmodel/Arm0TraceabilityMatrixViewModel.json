{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel.directive",
        "js/aw-splm-table.directive",
        "js/aw-flex-row.directive",
        "js/aw-flex-column.directive",
        "js/aw-separator.directive",
        "js/aw-toolbar.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "init",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "events": {
                "success": [
                    {
                        "name": "Arm0Traceability.fullViewModeAction",
                        "condition": "ctx.generateTracebilityMatrixOnReveal"
                    },
                    {
                        "name": "requirementDocumentation.loadMatrixData",
                        "condition": "ctx.generateTracebilityMatrixOnReveal"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "setServiceData":{
            "actionType": "JSFunction",
            "method": "setServiceData",
            "inputData": {
                "serviceData":"{{data.serviceDataInfo}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "uploadFile": {
            "actionType": "RESTService",
            "serviceName": "",
            "method": "POST",
            "inputData": {
                "request": {
                    "method": "POST",
                    "url": "{{Constants.fmsUrl}}",
                    "headers": {
                        "Content-type": "undefined"
                    },
                    "data": "{{data.formData}}"
                }
            },
            "events": {
                "success": [
                    {
                        "name": "Arm0TracelinkMatrixObject.printTraceabilityMatrix"
                    }
                ]
            }
        },
        "getFMSFileTicket": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2007-01-FileManagement",
            "method": "getTransientFileTicketsForUpload",
            "inputData": {
                "transientFileInfos": [
                    {
                        "fileName": "testFile123.svg",
                        "isBinary": true
                    }
                ]
            },
            "outputData": {
                "fmsTicket": "transientFileTicketInfos[0].ticket"
            },
            "events": {
                "success": [
                    {
                        "name": "Arm0TraceabilityMatrix.updateFileContentInFormData"
                    }
                ]
            }
        },
        "updateFileContentInFormData": {
            "actionType": "JSFunction",
            "method": "updateFileContentInFormData",
            "deps": "js/Arm0TraceabilityMatrix",
            "inputData": {
                "data": "{{data}}"
            }
        },
        "printTracelinkMatrix": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AwReqMgmtSe-2019-12-SpecNavigation",
            "method": "convertSVG",
            "inputData": {
                "inputData": {
                    "svgFileTicket": "{{data.fmsTicket}}",
                    "height": "{{data.height}}",
                    "width": "{{data.width}}",
                    "outputType": "pdf",
                    "options": []
                }
            },
            "outputData": {
                "printMatrixOutput": "{{function:processResponse}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "fullViewModeAction": {
            "actionType": "JSFunction",
            "method": "toggleViewerFullScreenMode",
            "deps": "js/fullViewModeService",
            "inputData": {}
        },
        "loadMatrixData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AwReqMgmtSe-2018-12-SpecNavigation",
            "method": "getTraceabilityMatrix",
            "inputData": {
                "inputData": "{{function:getTraceMatrixInput}}"
            },
            "outputData": {
                "srcObjectInfo": "srcObjectInfo",
                "targetObjectInfo": "targetObjectInfo",
                "rowObjects": "rowObjects",
                "colObjects": "colObjects",
                "tracelinkInfo": "matrixCellInfo",
                "srcContextInfo": "srcContextInfo",
                "targetContextInfo": "targetContextInfo",
                "targetParentObjectInfo": "targetParentObjectInfo",
                "srcParentObjectInfo": "srcParentObjectInfo",
                "serviceDataInfo":"ServiceData"                
            },
            "events": {
                "success": [
                    {
                        "name": "requirementDocumentation.processDataFromServer"
                    }
                ]
            },
            "actionMessages": {
                "failure": [
                    {
                        "message": "RequestFailureMessage"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "tracelinkCreated": {
            "actionType": "JSFunction",
            "method": "tracelinkCreated",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "unRegisterMatrixCellSelectedCtx": {
            "actionType": "JSFunction",
            "method": "unRegisterCtx",
            "inputData": {
                "name": "matrixCellSelected",
                "value": false
            },
            "deps": "js/appCtxService"
        },
        "addObjectToTracelinkPanel": {
            "actionType": "JSFunction",
            "method": "addObjectToTracelinkPanel",
            "inputData": {
                "panelContext": "{{data.eventData}}"
            },
            "deps": "js/Arm0CreateTraceLink"
        },
        "getNoOfItemsPerPage": {
            "actionType": "JSFunction",
            "method": "getNoOfItemsPerPage",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "events": {},
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "performPagination": {
            "actionType": "JSFunction",
            "method": "performPagination",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "getSelectedTypeOfTraceLink": {
            "actionType": "JSFunction",
            "method": "getSelectedTypeOfTraceLink",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "navigateUpOrDown": {
            "actionType": "JSFunction",
            "method": "isNavigationRequired",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "uiPagination": {
            "actionType": "JSFunction",
            "method": "isSoapaginationRequired",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "clickRollupBtn": {
            "actionType": "JSFunction",
            "method": "rollupClicked",
            "inputData": {
                "ctx": "{{ctx}}",
                "data": "{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "requirementsMatrixNavigate": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AwReqMgmtSe-2018-12-SpecNavigation",
            "method": "getTraceabilityMatrix",
            "inputData": {
                "inputData": "{{function:getChildMatrixInput}}"
            },
            "outputData": {
                "srcObjectInfo": "srcObjectInfo",
                "rowObjects": "rowObjects",
                "targetObjectInfo": "targetObjectInfo",
                "colObjects": "colObjects",
                "tracelinkInfo": "matrixCellInfo",
                "srcContextInfo": "srcContextInfo",
                "targetContextInfo": "targetContextInfo",
                "targetParentObjectInfo": "targetParentObjectInfo",
                "srcParentObjectInfo": "srcParentObjectInfo",
                "serviceDataInfo":"ServiceData"
            },
            "events": {
                "success": [
                    {
                        "name":"Arm0TraceabilityMatrix.setServiceData"
                    },
                    {
                        "name": "requirementDocumentation.processDataFromServer"
                    }
                ],
                "failure": [
                    {
                        "name": "requirementDocumentation.processDataFromServer"
                    }
                ]
            },
            "actionMessages": {
                "failure": [
                    {
                        "message": "RequestFailureMessage"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "getChildRollup": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AwReqMgmtSe-2018-12-SpecNavigation",
            "method": "getTraceabilityMatrix",
            "inputData": {
                "inputData": "{{function:getChildMatrixInput}}"
            },
            "actionMessages": {
                "failure": [
                    {
                        "message": "RequestFailureMessage"
                    }
                ],
                "success": [
                    {
                        "message": "NotificationForFullRollup"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "showTracelinksPopup": {
            "actionType": "JSFunction",
            "method": "showTracelinksPopup",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "processDataFromServer": {
            "actionType": "JSFunction",
            "method": "processDataFromServer",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "loadData": {
            "actionType": "JSFunctionAsync",
            "method": "loadFlatTableData",
            "inputData": {
                "data": "{{data}}"
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "searchResults",
                "searchIndex": "searchIndex"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "resetTraceMatrix": {
            "actionType": "JSFunction",
            "method": "resetTraceMatrix",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "loadColumns": {
            "actionType": "JSFunctionAsync",
            "method": "loadFlatTableColumns",
            "inputData": {
                "dataProvider": "{{data.dataProviders.traceMatrixCellPropDataProvider}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "refreshTableData": {
            "actionType": "dataProvider",
            "method": "traceMatrixCellPropDataProvider"
        },
        "OpenCreateTracelinkPanel": {
            "actionType": "JSFunction",
            "method": "OpenCreateTracelinkPanel",
            "inputData": {
                "elementsInCreateTracelink": "{{data.eventMap['Arm0Traceability.OpenCreateTracelinkPanel']}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "OpenCloseCreateTracelinkPanel": {
            "actionType": "JSFunction",
            "method": "OpenCloseCreateTracelinkPanel",
            "inputData": {
                "elementsInCreateTracelink": "{{data.eventData}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "openCloseSaveTracelinkMatrixObjectPanel": {
            "actionType": "JSFunction",
            "method": "openCloseSaveTracelinkMatrixObjectPanel",
            "events": {
                "success": [
                    {
                        "name": "Arm0TracelinkMatrixObject.loadTMOproperties"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "refreshTracelinkMatrixObject": {
            "actionType": "JSFunction",
            "method": "refreshTracelinkMatrixObject",
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "loadTMOproperties": {
            "actionType": "JSFunction",
            "method": "loadTMOproperties",
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "saveTraceabilityMatrix": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AwReqMgmtSe-2019-12-SpecNavigation",
            "method": "saveTraceabilityMatrix",
            "inputData": {
                "inputData": "{{function:getTraceMatrixInputForSave}}"
            },
            "outputData": {
                "updatedTlMatrixObjectUids": "updated"
            },
            "actionMessages": {
                "success": [
                    {
                        "condition": "data.isSaved === true && data.matrixType !== 'Full-Rollup Matrix'",
                        "message": "refreshTracelinkMatrixObjectMsg"
                    },
                    {
                        "condition": "data.isSaved === true && data.matrixType === 'Full-Rollup Matrix'",
                        "message": "refreshRollupTracelinkMatrixObjectMsg"
                    },
                    {
                        "condition": "data.isSaved === false",
                        "message": "saveTracelinkMatrixObjectSaveMsg"
                    }
                ]
            },
            "events": {
                "success": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    },
                    {
                        "name": "Arm0TracelinkMatrixObject.showUpdatedTLMatrix"
                    }
                ]
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "showUpdatedTLMatrix": {
            "actionType": "JSFunction",
            "method": "showUpdatedTLMatrix",
            "inputData": {
                "ctx": "{{ctx}}",
                "data": "{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "closeFunnelPopUp": {
            "actionType": "JSFunction",
            "method": "hide",
            "inputData": {
                "popupId": null
            },
            "deps": "js/popupService"
        },
        "collapseNode": {
            "actionType": "JSFunction",
            "method": "collapseNode",
            "inputData": {
                "data": "{{data}}",
                "ctx": "{{ctx}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "sortTraceabilityMatrix": {
            "actionType": "JSFunction",
            "method": "sortTraceabilityMatrix",
            "inputData": {
                "data" : "{{data}}",
                "ctx": "{{ctx}}"                
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "destroyTraceabilityMatrix": {
            "actionType": "JSFunction",
            "method": "destroyTraceabilityMatrix",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "getFMSFileTicket2": {
            "actionType": "TcSoaService",
            "serviceName": "Core-2007-01-FileManagement",
            "method": "getTransientFileTicketsForUpload",
            "inputData": {
                "transientFileInfos": [
                    {
                        "fileName": "testFile123.svg",
                        "isBinary": true
                    }
                ]
            },
            "outputData": {
                "fmsTicket": "transientFileTicketInfos[0].ticket"
            },
            "events": {
                "success": [
                    {
                        "name": "Arm0TraceabilityMatrix.updateFMSFileToReplaceMatrix"
                    }
                ]
            }
        },
        "updateFMSFileToReplaceMatrix":{
            "actionType": "JSFunction",
            "method": "updateFMSFileToReplaceMatrix",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/Arm0TraceabilityMatrix"
        },
        "uploadFile2": {
            "actionType": "RESTService",
            "serviceName": "",
            "method": "POST",
            "inputData": {
                "request": {
                    "method": "POST",
                    "url": "{{Constants.fmsUrl}}",
                    "headers": {
                        "Content-type": "undefined"
                    },
                    "data": "{{data.formData}}"
                }
            },
            "events": {
                "success": [
                    {
                        "name": "Arm0TraceabilityMatrix.init"                        
                    }
                ]
            }
        }
    },
    "dataProviders": {
        "traceMatrixCellPropDataProvider": {
            "action": "loadData",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "searchIndex": "{{data.searchIndex}}"
        }
    },
    "columnProviders": {
        "traceMatrixCellPropColumnProvider": {
            "loadColumnAction": "loadColumns",
            "columns": "{{data.columns}}",
            "soaEnabled": false,
            "sortCriteria": []
        }
    },
    "grids": {
        "traceMatrixCellPropTable": {
            "dataProvider": "traceMatrixCellPropDataProvider",
            "columnProvider": "traceMatrixCellPropColumnProvider",
            "addIconColumn": false,
            "gridOptions": {
                "enableGridMenu": false,
                "enablePinning": true,
                "enableSorting": false
            }
        }
    },
    "data": {
        "tlType": {
            "displayName": "Type",
            "type": "STRING",
            "isRequired": "true",
            "hasLov": true,
            "labelPosition": "PROPERTY_LABEL_AT_LEFT",
            "dbValue": "ALL"
        },
        "matrixType": "",
        "noOfItem": {
            "displayName": "Items per page",
            "type": "STRING",
            "isRequired": "true",
            "hasLov": true,
            "labelPosition": "PROPERTY_LABEL_AT_LEFT"
        },
        "noOfPageListIn": {
            "type": "STRING",
            "dbValue": [
                "25",
                "50",
                "100"
            ]
        },
        "tracelinkedItems": {
            "isArray": "true",
            "dbValue": []
        },
        "columnLabel": {
            "type": "STRING"
        },
        "rowLabel": {
            "type": "STRING"
        },
        "showColor": {
            "displayName": "{{i18n.showColor}}",
            "type": "BOOLEAN",
            "isRequired": "true",
            "dbValue": false,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        },
        "showChildCounts": {
            "displayName": "{{i18n.showChildCounts}}",
            "type": "BOOLEAN",
            "isRequired": "true",
            "dbValue": false,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        },
        "showChildCountsForFullRollup": {
            "displayName": "{{i18n.showChildCounts}}",
            "type": "BOOLEAN",
            "isRequired": "true",
            "dbValue": true,
            "isEditable": false,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        },
        "refreshTracelinkMatrixObjectCommand": {
            "dbValue": [
                {
                    "action": "refreshTracelinkMatrixObject",
                    "iconName": "Refresh",
                    "tooltip": "{{i18n.refreshTraceabilityMatrix}}"
                }
            ]
        }
    },
    "functions": {
        "getTraceMatrixInput": {
            "functionName": "getTraceMatrixInput",
            "parameters": [
                "{{ctx}}",
                "{{data}}"
            ]
        },
        "getChildMatrixInput": {
            "functionName": "getChildMatrixInput",
            "parameters": [
                "{{ctx}}",
                "{{data}}"
            ]
        },
        "getChildInterfacesInput": {
            "functionName": "getChildInterfacesInput",
            "parameters": [
                "{{ctx}}",
                "{{data}}"
            ]
        },
        "getTraceMatrixInputForSave": {
            "functionName": "getTraceMatrixInputForSave"
        },
        "processResponse": {
            "functionName": "processResponse",
            "deps": "js/Arm0TraceabilityMatrix"
        }
    },
    "onEvent": [
        {
            "eventId": "requirementDocumentation.loadMatrixData",
            "cacheEventData": true,
            "action": "loadMatrixData"
        },
        {
            "eventId": "requirementDocumentation.processDataFromServer",
            "action": "processDataFromServer"
        },
        {
            "eventId": "RM.PostTraceLinkCreated",
            "cacheEventData": true,
            "action": "tracelinkCreated"
        },
        {
            "eventId": "Arm0Traceability.unRegisterMatrixCellSelectedCtx",
            "action": "unRegisterMatrixCellSelectedCtx"
        },
        {
            "eventId": "requirementDocumentation.navigate",
            "cacheEventData": true,
            "action": "requirementsMatrixNavigate"
        },
        {
            "eventId": "requirementTraceability.navigateUpOrDown",
            "cacheEventData": true,
            "action": "navigateUpOrDown"
        },
        {
            "eventId": "requirementTraceability.uiPagination",
            "cacheEventData": true,
            "action": "uiPagination"
        },
        {
            "eventId": "requirementDocumentation.addObjectToTracelinkPanel",
            "cacheEventData": true,
            "action": "addObjectToTracelinkPanel"
        },
        {
            "eventId": "Arm0Traceability.showTracelinksPopup",
            "cacheEventData": true,
            "action": "showTracelinksPopup"
        },
        {
            "eventId": "Arm0Traceability.refreshTableData",
            "action": "refreshTableData"
        },
        {
            "eventId": "requirementTraceabilityMatrix.performPagination",
            "action": "performPagination"
        },
        {
            "eventId": "requirementTraceabilityMatrix.getSelectedTypeOfTraceLink",
            "action": "getSelectedTypeOfTraceLink"
        },
        {
            "eventId": "requirementTraceabilityMatrix.getNoOfItemsPerPage",
            "action": "getNoOfItemsPerPage"
        },
        {
            "eventId": "requirementTraceabilityMatrix.getChildRollup",
            "action": "getChildRollup"
        },
        {
            "eventId": "requirementTraceabilityMatrix.clickRollupBtn",
            "action": "clickRollupBtn"
        },
        {
            "eventId": "Arm0Traceability.fullViewModeAction",
            "action": "fullViewModeAction"
        },
        {
            "eventId": "Arm0Traceability.OpenCreateTracelinkPanel",
            "cacheEventData": true,
            "action": "OpenCreateTracelinkPanel"
        },
        {
            "eventId": "Arm0Traceability.OpenCloseCreateTracelinkPanel",
            "cacheEventData": true,
            "action": "OpenCloseCreateTracelinkPanel"
        },
        {
            "eventId": "Arm0TracelinkMatrix.closeFunnelPopup",
            "cacheEventData": true,
            "action": "closeFunnelPopUp"
        },
        {
            "eventId": "Arm0TracelinkMatrixObject.loadTMOproperties",
            "action": "loadTMOproperties"
        },
        {
            "eventId": "Arm0TracelinkMatrixObject.saveTraceabilityMatrix",
            "action": "saveTraceabilityMatrix"
        },
        {
            "eventId": "Arm0TracelinkMatrixObject.openCloseSaveTracelinkMatrixObjectPanel",
            "action": "openCloseSaveTracelinkMatrixObjectPanel"
        },
        {
            "eventId": "Arm0TracelinkMatrixObject.showUpdatedTLMatrix",
            "action": "showUpdatedTLMatrix"
        },
        {
            "eventId": "Arm0TracelinkMatrixObject.printTraceabilityMatrix",
            "action": "printTracelinkMatrix"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.updateFileContentInFormData",
            "action": "updateFileContentInFormData"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.uploadFile",
            "action": "uploadFile"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.reset",
            "action": "resetTraceMatrix"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.print",
            "action": "getFMSFileTicket"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.collapseNode",
            "cacheEventData": true,
            "action": "collapseNode"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.sortTraceabilityMatrix",
            "cacheEventData": true,
            "action": "sortTraceabilityMatrix"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.setServiceData",
            "action": "setServiceData"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.getFMSFileTicket2",
            "action": "getFMSFileTicket2"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.updateFMSFileToReplaceMatrix",
            "action": "updateFMSFileToReplaceMatrix"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.uploadFile2",
            "action": "uploadFile2"
        },
        {
            "eventId": "Arm0TraceabilityMatrix.init",
            "action": "reveal"
        }
        
    ],
    "conditions": {
        "showHeatMap": {
            "expression": "ctx.mselected.length > 0"
        }
    },
    "messages": {
        "RequestFailureMessage": {
            "messageType": "ERROR",
            "messageText": "{{i18n.requestFailureMsg}}"
        },
        "NotificationForFullRollup": {
            "messageType": "INFO",
            "messageText": "Traceability Matrix is being generated. You will be notified when it is complete."
        },
        "refreshTracelinkMatrixObjectMsg": {
            "messageType": "INFO",
            "messageText": "{{i18n.refreshTracelinkMatrixObjectMsg}}",
            "messageTextParams": [
                "{{ctx.selected.props.object_name.dbValues[0]}}"
            ]
        },
        "refreshRollupTracelinkMatrixObjectMsg": {
            "messageType": "INFO",
            "messageText": "{{i18n.refreshRollupTracelinkMatrixObjectMsg}}",
            "messageTextParams": [
                "{{ctx.selected.props.object_name.dbValues[0]}}"
            ]
        },
        "saveTracelinkMatrixObjectSaveMsg": {
            "messageType": "INFO",
            "messageText": "{{i18n.saveTracelinkMatrixObjectSaveMsg}}",
            "messageTextParams": [
                "{{ctx.selected.props.object_name.dbValues[0]}}"
            ]
        }
    },
    "i18n": {
        "requestFailureMsg": [
            "MatrixMessages"
        ],
        "notificationForFullRollup": [
            "MatrixMessages"
        ],
        "showColor": [
            "MatrixMessages"
