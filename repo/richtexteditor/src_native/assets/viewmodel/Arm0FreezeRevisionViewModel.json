{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/aw-panel-footer.directive",
        "js/aw-panel-body.directive",
        "js/aw-command-panel.directive",
        "js/aw-radiobutton.directive",
        "js/aw-list.directive",
        "js/aw-panel-section.directive",
        "js/aw-default-cell.directive",
        "js/visible-when.directive"
    ],
    "data": {
        "revisions": {
            "isArray": "true",
            "dbValue": []
        },
        "freezeRevision": {
            "type": "BOOLEAN",
            "isRequired": "true",
            "propertyRadioTrueText": "{{i18n.freeze}}",
            "propertyRadioFalseText": "{{i18n.unfreeze}}",
            "dbValue": true,
            "vertical": true,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        }
    },
    "dataProviders": {
        "revisionData": {
            "response": "{{data.revisions.dbValue}}",
            "selectionModelMode": "single",
            "totalFound": "{{data.revisions.dbValue.length}}"
        }
    },
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "setFullTextRevisions",
            "inputData": {
                "ctx": "{{ctx}}",
                "data": "{{data}}"
            },
            "deps": "js/reuseRequirementService"
        },
        "refreshRevisionsList": {
            "actionType": "dataProvider",
            "method": "revisionData"
        },
        "freezeAtRevision": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-ActiveWorkspaceReqMgmt-2019-06-SpecNavigation",
            "method": "reuseSpecification",
            "inputData": {
                "inputs": [ {
                    "operationType": "{{function:getFreezeOperationType}}",
                    "selectedElements": "{{ctx.rmselected}}",
                    "dataset": "{{function:getDatasetId}}",
                    "inputCtxt": {},
                    "isDeep": false,
                    "isRunInBackground": false,
                    "options": {},
                    "datasetVersion": "{{function:getVersion}}"
                } ]
            },
            "outputData": {
                "response": "reuseStatusList"
            },
            "events": {
                "success": [ {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    },
                    {
                        "name": "requirementDocumentation.closeExistingBalloonPopup"
                    },
                    {
                        "name": "requirementDocumentation.documentationTabRefresh"
                    }
                ],

                "failure": [ {
                    "condition": "errorCode.code==223201",
                    "name": "layout.showToolInfo",
                    "eventData": {
                        "visible": false
                    }
                } ]
            },
            "deps": "js/reuseRequirementService"
        },
        "closePanel":
        {
            "actionType": "Event",
            "method": "Event",
            "inputData":
            {
                "events":
                [
                    {
                        "name": "complete",
                        "eventData":
                        {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            }
        }
    },
    "functions": {
        "getVersion": {
            "functionName": "getVersion",
            "parameters": [
                "{{data}}"
            ]
        },
        "getFreezeOperationType": {
            "functionName": "getFreezeOperationType",
            "parameters": [
                "{{data}}"
            ]
        },
        "getDatasetId":{
            "functionName": "getDatasetId",
            "parameters": [
                "{{data}}"
            ]
        }
    },
    "onEvent": [ {
            "eventId": "FullTextRequirement.refreshRevisionList",
            "action": "refreshRevisionsList"
        },
        {
            "eventId": "FullTextRequirement.refreshRevisionList",
            "action": "refreshRevisionsList"
        },
        {
            "eventId": "awPanel.reveal",
            "criteria": {
                "panelId": "Arm0FreezeRevision"
            },
            "action": "reveal"
        },
        {
            "eventId": "gwt.SubLocationContentSelectionChangeEvent",
            "action": "closePanel"
        }
    ],
    "i18n": {
        "freeze": [
            "RequirementsCommandPanelsMessages"
        ],
        "freezeUnFreeze": [
            "RequirementsCommandPanelsMessages"
        ],
        "revision": [
            "RequirementsCommandPanelsMessages"
        ],
        "unfreeze": [
            "RequirementsCommandPanelsMessages"
        ]
    }
}
