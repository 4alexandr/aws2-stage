{
    "schemaVersion" : "1.0.0",
    "imports":[ "js/aw-panel-body.directive",
                "js/aw-ace-effectivity.directive"
                ],
    "i18n":
    {
        "addElementBtn":[ "OccurrenceManagementConstants" ],
        "dateEffectivity":[ "OccurrenceManagementConstants" ],
        "dateEffectivityPlaceholder":[ "OccurrenceManagementConstants" ],
        "duplicateEffectivityCreationErrorMessage":["OccurrenceManagementMessages"],
        "effectivityType":[ "OccurrenceManagementConstants"],
        "endDate":[ "OccurrenceManagementConstants"],
        "endItemMessage":[ "OccurrenceManagementConstants" ],
        "endItemRequired":[ "OccurrenceManagementConstants"],
        "failedToApplyEffectivity":[ "OccurrenceManagementConstants" ],
        "name":[ "OccurrenceManagementConstants" ],
        "protect":[ "OccurrenceManagementConstants" ],
        "sharedEffectivities":[ "OccurrenceManagementConstants" ],
        "shareEffectivity":[ "OccurrenceManagementConstants"],
        "soText":[ "OccurrenceManagementConstants"],
        "startDate":[ "OccurrenceManagementConstants"],
        "unitEffectivity":[ "OccurrenceManagementConstants" ],
        "upText":[ "OccurrenceManagementConstants"],
        "aceRemove":[ "OccurrenceManagementConstants"]
    },
    "data" :
    {
        "nameBox":{
            "displayName": "{{i18n.name}}",
            "type": "STRING",
            "dbValue": "",
            "isRequired": "true",
            "maxLength":32
        },
        "unitRangeText":{
            "displayName": "{{i18n.unitEffectivity}}",
            "type": "STRING",
            "dbValue": "",
            "isRequired": "true"
        },
        "isShared":{
            "displayName": "{{i18n.shareEffectivity}}",
            "type": "STRING",
            "isRequired": "true",
            "isEditable": "true",
            "dbValue": false,
            "labelPosition":"PROPERTY_LABEL_AT_RIGHT"
        },
        "dateOrUnitEffectivityTypeRadioButton":
        {
            "type": "BOOLEAN",
            "isRequired": "true",
            "propertyRadioTrueText": "{{i18n.dateEffectivity}}",
            "propertyRadioFalseText":"{{i18n.unitEffectivity}}",
            "dbValue": true,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        },
        "startDate":
        {
            "dbValue": "",
            "type": "DATETIME",
            "isRequired": "false",
            "displayName": "{{i18n.startDate}}"
        },
        "endDate":
        {
            "dbValue": "",
            "type": "DATETIME",
            "isRequired": "false"
        },
        "endDateList":{
            "type": "STRING",
            "dbValue":
            [
                {"propDisplayValue" :"{{i18n.dateEffectivity}}", "propInternalValue" : "Date"},
                {"propDisplayValue" :"{{i18n.upText}}", "propInternalValue" : "UP"},
                {"propDisplayValue" :"{{i18n.soText}}", "propInternalValue" : "SO"}
            ]
        },
        "endDateOptions":
        {
            "type": "STRING",
            "isRequired": "true",
            "hasLov":true,
            "displayName": "{{i18n.endDate}}",
            "isEditable": "true"
        },
        "endItemLabel":
        {
            "displayName": "{{i18n.endItemMessage}}",
            "type": "STRING"
        },
        "endItemRequiredLabel":
        {
            "displayName": "{{i18n.endItemRequired}}",
            "type": "STRING"
        },
        "endItemVal":{
            "type": "STRING",
            "uiValue":"{{ctx.elementEffectivity.author.endItem.dbValue}}",
            "displayName": "{{i18n.endItemMessage}}"
        }
    },
    "actions":
    {

        "clearAuthorEffectivityPanel":{
            "actionType": "JSFunction",
            "method": "clearAuthorEffectivityPanel",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/sharedEffectivityService"
        },

        "handleTabSelectionChange":
        {
            "actionType": "JSFunction",
            "method": "handleTabSelectionChange",
            "inputData":
            {
                "data": "{{data}}"
            },
            "deps": "js/sharedEffectivityService"
        }
    },

     "conditions":
    {
        "isNewAuthorPanelSelected":{
            "expression":"$parent.ctx.elementEffectivity.selectedPanel == 'NEW'"
        }
    },


    "functions":
    {
        "getDateRangeText":{
            "functionName": "getDateRangeText",
            "parameters": [ "{{data}}" ]
        },
        "getEffectivityName":{

            "functionName": "getEffectivityName",
            "parameters": [ "{{data}}" ]
        }
    },
    "onEvent": [
        {
            "eventId": "awTab.selected",
            "action":  "handleTabSelectionChange"
        },
        {
            "eventId": "authorEffectivities.effectivityAppliedSuccessfully",
            "action":  "clearAuthorEffectivityPanel"
        }
    ],
    "messages":
     {
         "failedToApplyEffectivityMessage":
         {
             "messageType": "INFO",
            "messageText": "{{i18n.failedToApplyEffectivity}}",
            "messageTextParams":
            [
                "{{ctx.selected.props.awb0Name.dbValue}}"
            ]
         },
         "duplicateEffectivityCreationErrorMessage":{
            "messageType": "ERROR",
            "messageText": "{{i18n.duplicateEffectivityCreationErrorMessage}}",
            "messageTextParams":
            [
                "{{data.nameBox.dbValue}}"
            ]
         }
     }
}
