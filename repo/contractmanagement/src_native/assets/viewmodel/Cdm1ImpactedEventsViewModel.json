{
    "schemaVersion": "1.0.0",
    "imports":
    [
        "js/aw-panel-body.directive",
        "js/aw-column.directive",
        "js/aw-splm-table.directive"
    ],

    "actions":
    {
        "getFilterFacets": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-12-Finder",
            "method": "getFilterValues",
            "inputData": {
                "filterFacetInput": {
                    "columnFilters": "{{filterFacetInput.columnFilters}}",
                    "columnName": "{{filterFacetInput.column.field}}",
                    "maxToReturn": "{{filterFacetInput.maxToReturn}}",
                    "providerName": "Cdm1ImpactedEventsProvider",
                    "searchCriteria":
                    {
                        "parentUid": "{{ctx.selected.uid}}",
                        "isSelectionValid": "{{(ctx.mselected.length > 1) || (ctx.selected.modelType.typeHierarchyArray.indexOf( 'Cdm0ContractRevision' ) > -1)}}"
                    },
                    "searchFilterMap":  "{{ctx.search.activeFilterMap}}",
                    "startIndex": "{{filterFacetInput.startIndex}}"
                }
            },
            "outputData": {
                "filterFacetResults": "{{json:facetValues}}"
            }
        },
        "reloadImpactedEventDataProvider":
        {
            "actionType": "dataProvider",
            "method": "performImpactedSearch"
        },

        "searchImpacted":
        {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData":
            {
                "columnConfigInput":
                {
                    "clientName": "AWClient",
                    "clientScopeURI": "Cdm1ImpactedEventsColConfig"
                },

                "searchInput":
                {
                    "attributesToInflate":
                    [

                    ],

                    "internalPropertyName": "",
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Cdm1ImpactedEventsProvider",
                    "searchCriteria":
                    {
                        "parentUid": "{{ctx.mselected[0].uid}}",
                        "isSelectionValid": "{{(ctx.mselected.length > 1) || (ctx.selected.modelType.typeHierarchyArray.indexOf( 'Cdm0ContractRevision' ) > -1)}}"
                    },

                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.clientScopeUI.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.performImpactedSearch.startIndex}}",
                    "columnFilters": "{{data.columnProviders.clientScopeUI.columnFilters}}"
                }
            },

            "outputData":
            {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.performImpactedSearch.columnConfig": "columnConfig",
                "ctx.search.totalFound": "totalFound",
                "ctx.search.totalLoaded": "totalLoaded"
            },

            "deps": "js/Cdm1ImpactedEventsService"
        }
    },

    "data":
    {

    },
    "columnProviders": {
        "clientScopeUI": {
            "columns": [{}],
            "resetColumnAction" : "resetColumnConfig",
            "columnFilters": "{{filterFacetInput.columnFilters}}"
        }
    },
    "dataProviders":
    {
        "performImpactedSearch":
        {
            "action": "searchImpacted",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "none",
            "filterFacetAction": "getFilterFacets",
            "filterFacetResults": "{{data.filterFacetResults}}"
        }
    },

    "functions":
    {
    },

    "conditions":
    {
        "checkSelectionChange":
        {
            "expression": "name == 'mselected'"
        }
    },

    "onEvent":
    [
        {
            "eventId": "appCtx.register",
            "condition": "conditions.checkSelectionChange",
            "action": "reloadImpactedEventDataProvider"
        }
    ],

    "grids":
    {
        "impactedEventTable":
        {
            "dataProvider": "performImpactedSearch",
            "columnProvider": "clientScopeUI",
            "addIconColumn": false,
            "gridOptions":
            {
                "enablePinning": true,
                "enableSorting": true,
                "maxRowsToShow": 5,
                "isFilteringEnabled": true
            }
        }
    },

    "i18n":
    {
        "impactedEvents":
        [
            "contractmanagementMessages"
        ]
    }
}