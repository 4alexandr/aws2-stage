    "conditions": {
      "markupVisible": {
        "expression": "ctx.viewerContext.type=='aw-pdf-viewer' || ctx.viewerContext.type=='aw-2d-viewer' || ctx.viewerContext.type=='aw-image-viewer' || ctx.viewerContext.type=='aw-text-viewer' || ctx.viewerContext.type=='aw-html-viewer' ||  ctx.reqMarkupCtx.viewerType=='aw-requirement-ckeditor' || ctx.markup.keep"
      },
      "markupShowMarkupsSelected": {
        "expression": "ctx.markup.showMarkups"
      },
      "markupShowPanelSelected": {
        "expression": "ctx.markup.showPanel"
      },
      "markupHighlightEnabled": {
        "expression": "!ctx.markup.currentEdit && ctx.markup.supportedTools.highlight"
      },
      "markupFreehandEnabled": {
        "expression": "!ctx.markup.currentEdit && ctx.markup.supportedTools.freehand"
      },
      "markupHighlightSelected": {
        "expression": "ctx.markup.selectedTool==='highlight'"
      },
      "markupFreehandSelected": {
        "expression": "ctx.markup.selectedTool==='freehand'"
      },
      "markupShapeSelected": {
        "expression": "ctx.markup.selectedTool==='shape'"
      },
      "markupShapeEnabled": {
        "expression": "!ctx.markup.currentEdit && ctx.markup.supportedTools.shape"
      },
      "markupStampSelected": {
        "expression": "ctx.markup.selectedTool==='stamp'"
      },
      "markupStampEnabled": {
        "expression": "!ctx.markup.currentEdit && ctx.markup.supportedTools.stamp"
      },
      "markupEditable": {
        "expression": "commandContext.vmo.isEditable"
      },
      "markupReplyable": {
        "expression": "commandContext.vmo.isReplyable"
      },
      "markupDeletable": {
        "expression": "commandContext.vmo.isDeletable"
      },
      "markupPrintable": {
        "expression": "(ctx.markup.showMarkups || ctx.markup.showPanel) && ctx.markup.count > 0"
      }
    },
