    "commandPlacements": {
      "Awa0ShowPredictionsPlacement": {
        "id": "Awa0ShowPredictions",
        "uiAnchor": "aw_globalNavigationbar",
        "priority": 4
      },
      "Awa0CopyCommandPlacement": {
        "id": "Awa0Copy",
        "uiAnchor": "awa_dataAssistant",
        "priority": 2,
        "cellDisplay": {
          "hover": true,
          "position": "TOP_RIGHT",
          "selected": true
        }
      },
      "Awa0OpenCommandPlacement": {
        "id": "Awa0Open",
        "uiAnchor": "awa_dataAssistant",
        "priority": 1,
        "cellDisplay": {
          "hover": true,
          "position": "TOP_RIGHT",
          "selected": true
        }
