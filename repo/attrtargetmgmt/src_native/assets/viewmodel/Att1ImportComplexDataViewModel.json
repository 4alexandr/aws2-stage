{
    "schemaVersion": "1.0.0",
    "imports":
    [
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-section.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/aw-file-upload.directive",
        "js/visible-when.directive"
    ],

    "actions":
    {
        "getTransientFileTickets":
        {
            "actionType": "TcSoaService",
            "serviceName": "Core-2007-01-FileManagement",
            "method": "getTransientFileTicketsForUpload",
            "inputData":
            {

                "transientFileInfos":
                [
                    {
                        "fileName":"{{data.fileName}}",
                        "isBinary":false,
                        "deleteFlag":true
                    }
                ]
            },
            "outputData": {
                "fmsTicket": "transientFileTicketInfos[0].ticket"
            },
            "events":
            {
                "success":
                [
                    {
                       "name": "updateFormData"
                    }
                ]
            }
        },
        "initDSCreateParams":
        {
            "actionType": "JSFunction",
            "method": "initDSCreateParams",
            "inputData":
            {
                "data": "{{data}}"
            },

            "outputData":
            {

            },

            "deps": "js/addObjectUtils"
        },
        "setAttributeComplexDataSoaCall":
        {
            "actionType": "TcSoaService",
            "serviceName": "AttrTargetMgmt-2018-06-AttributeTargetManagement",
            "method": "setAttributeComplexData",
            "inputData":
            {
               "inputs": [{
                   "clientId": "AWClient",
                   "isProceedWithValidationError": false,
                   "objectToModify": "{{function:getValidParameterInstance}}",
                   "fileData": {
                       "fileTicket": "{{data.fmsTicket}}",
                       "sheetNamePropNameMapping": {
                           "att0GoalTable": "att0GoalTable",
                           "att0MinTable": "att0MinTable",
                           "att0MaxTable": "att0MaxTable"
                       },
                       "sheetNameMeasurementPropNameMapping": {
                           "att0ValueTable": "att0ValueTable"
                       }
                   }
               }]
            },
            "outputData": {
                "setAttrComplexDataResp": "",
                "importMessages":"{{function:processPartialErrorForComplexData}}"
            },
            "events":
            {
                "success":
                [

                    {
                        "name": "cdm.relatedModified",
                        "condition": "ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf( 'Att0MeasurableAttribute' ) > -1",
                        "eventData": {
                            "refreshLocationFlag": true,
                            "relatedModified": [ "{{ctx.selected}}" ]
                        }
                    },
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ],
                "failure": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "actionMessages": {
                "success": [
                    {
                        "message": "importDone"
                    }
                ],
                "failure": [
                    {
                        "message": "importFailureMessage"
                    }
                ]
            },
            "deps": "js/Att1ParameterMgmtUtilService"
        },
        "updateFormData":
        {
            "actionType": "JSFunction",
            "method": "updateFormData",
            "inputData":
            {
                "fileData":
                {
                    "key"  : "fmsTicket",
                    "value": "{{data.fmsTicket}}"
                },
                "data":"{{data}}"
            },
            "events":
            {
                "success":
                [

                    {
                        "name": "uploadFile"
                    }
                ]
            },
            "deps": "js/declUtils"
        },
        "uploadFile":
        {
            "actionType": "RESTService",
            "serviceName": "",
            "method": "POST",
            "inputData":
            {
                "request":
                {
                    "method": "POST",
                    "url": "{{Constants.fmsUrl}}",
                    "headers":
                    {
                        "Content-type": "undefined"
                    },

                    "data": "{{data.formData}}"
                }
            },
            "events":
            {
                "success":
                [
                    {
                        "name": "setAttributeComplexDataSoaCall"
                    }
                ]
            }
        }
    },

    "onEvent":
    [
        {
            "eventId" : "uploadFile",
            "action" : "uploadFile"
        },
        {
            "eventId": "setAttributeComplexDataSoaCall",
            "action": "setAttributeComplexDataSoaCall"
        },
        {
            "eventId": "updateFormData",
            "action": "updateFormData"
        }
    ],

    "data":
    {
        "datasetName":
        {
            "displayName": "",
            "type": "STRING",
            "isRequired": "true"
        },

        "datasetFileName":
        {
            "displayName": "",
            "type": "STRING",
            "hasLov": true
        },

        "datasetDesc":
        {
            "displayName": "",
            "type": "STRING"
        },

        "reference":
        {
            "displayName": "",
            "type": "STRING",
            "hasLov": true
        },

        "datasetType":
        {
            "displayName": "",
            "type": "STRING",
            "hasLov": true
        }
    },
    "functions":
    {
        "getValidParameterInstance": {
            "functionName": "getValidParameterInstance",
            "parameters": []
        },
        "processPartialErrorForComplexData": {
            "functionName": "processPartialErrorForComplexData",
            "parameters": [
                "{{setAttrComplexDataResp}}"
            ]
        }
    },
    "messages":
    {
        "importDone":
        {
            "messageType": "INFO",
            "messageText": "{{i18n.ImportSuccessful}}"
        },
        "importFailureMessage": {
            "messageType": "ERROR",
            "messageText": "{{i18n.att1FailureMessage}}",
            "messageTextParams": [
                "{{data.importMessages}}"
            ]
        }
    },
    "i18n":
     {
         "ImportAttributeData" : ["Att1AttrMappingMessages"],
         "Import" : ["Att1AttrMappingMessages"],
         "ImportSuccessful" : ["Att1AttrMappingMessages"],
         "att1FailureMessage": ["Att1AttrMappingMessages"]
     }
}
