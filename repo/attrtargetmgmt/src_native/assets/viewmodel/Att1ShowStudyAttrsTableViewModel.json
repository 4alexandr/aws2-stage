{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive",
        "js/aw-command-bar.directive",
        "js/aw-row.directive"
    ],
    "actions": {
        "editEventAction": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "plTable.editStateChange",
                        "eventData": {
                            "state": "{{data.eventData.state}}",
                            "dataSource": {
                                "dataProviders": "{{data.dataProviders}}"
                            }
                        }
                    }
                ]
            }
        },
        "addStudyEventDataToNativeData": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "nativeDataLoadEvent",
                        "eventData": {
                            "viewModelObjects": "{{data.dataProviders.studyAttrsDataProvider.viewModelCollection.loadedVMObjects}}"
                        }
                    }
                ]
            }
        },
        "checkIfStudyORARSelected": {
            "actionType": "JSFunction",
            "method": "checkIfStudyORARSelected",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/attrStudyUtils"
        },
        "changeSelectionToAttribute": {
            "actionType": "JSFunction",
            "method": "changeSelectionToAttribute",
            "inputData": {
                "dataProvider": "{{data.dataProviders.studyAttrsDataProvider}}"
            },
            "deps": "js/attrStudyUtils"
        },
        "checkIfStudySelected": {
            "actionType": "JSFunction",
            "method": "checkIfStudySelected",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/attrStudyUtils"
        },
        "refreshStudyAttrsTable": {
            "actionType": "dataProvider",
            "method": "studyAttrsDataProvider"
        },
        "isAttrItemUpdated": {
            "actionType": "JSFunction",
            "method": "isAttrItemUpdated",
            "inputData": {
                "eventMap": "{{data.eventMap}}",
                "refreshEvent": "Att1ShowStudyAttrsTable.refreshStudyTable"
            },
            "deps": "js/attrTableUtils"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "Att1StudiesAttrTable"
                },
                "saveColumnConfigData": {
                    "clientScopeURI": "Att1StudiesAttrTable",
                    "columnConfigId": "{{data.dataProviders.studyAttrsDataProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.studyAttrsDataProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "parentUids": "{{function:getSelectedStudyUids}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.studyAttrsColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.studyAttrsDataProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.studyAttrsColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.studyAttrsDataProvider.columnConfig": "columnConfig"
            },
            "deps": "js/attrStudyUtils"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [
                    {
                        "scope": "LoginUser",
                        "scopeName": "",
                        "clientName": "AWClient",
                        "resetColumnConfig": true,
                        "columnConfigQueryInfos": [
                            {
                                "clientScopeURI": "Att1StudiesAttrTable",
                                "operationType": "configured",
                                "typeNames": [
                                    "WorkspaceObject"
                                ],
                                "columnsToExclude": []
                            }
                        ],
                        "businessObjects": [
                            {}
                        ]
                    }
                ]
            },
            "outputData": {
                "dataProviders.studyAttrsDataProvider.resetColumnConfigs": "columnConfigurations"
            }
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "Att1StudiesAttrTable",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "parentUids": "{{function:getSelectedStudyUids}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.studyAttrsColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.studyAttrsDataProvider.startIndex}}",
                    "columnFilters": "{{function:getColumnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.studyAttrsDataProvider.columnConfig": "columnConfig"
            },
            "deps": "js/attrStudyUtils"
        },
        "setOpenedContext": {
            "actionType": "JSFunction",
            "method": "onAttrSelection",
            "inputData": {
                "eventData": "{{data.eventMap}}"
            },
            "deps": "js/attrTableUtils"
        }
    },
    "functions": {
        "getSelectedStudyUids": {
            "functionName": "getSelectedStudyUids",
            "parameters": [
                "{{data}}"
            ]
        },
        "getColumnFilters": {
            "functionName": "getColumnFilters",
            "parameters": [
                "{{data}}"
            ]
        }
    },
    "columnProviders": {
        "studyAttrsColumnProvider": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "dataProviders": {
        "studyAttrsDataProvider": {
            "action": "loadData",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "commandsAnchor": "Open_StudyAttr_command"
        }
    },
    "grids": {
        "studyTable": {
            "columnProvider": "studyAttrsColumnProvider",
            "dataProvider": "studyAttrsDataProvider",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableSorting": true,
                "maxRowsToShow": 18,
                "isFilteringEnabled": true
            }
        }
    },
    "onEvent": [
        {
            "eventId": "editHandlerStateChange",
            "cacheEventData": true,
            "action": "editEventAction"
        },
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        },
        {
            "eventId": "Att1ShowStudyAttrsTable.contentLoaded",
            "action": "checkIfStudySelected"
        },
        {
            "eventId": "appCtx.register",
            "condition": "name === 'mselected'",
            "cacheEventData": true,
            "action": "checkIfStudyORARSelected"
        },
        {
            "eventId": "Att1ShowStudyAttrsTable.refreshStudyTable",
            "action": "refreshStudyAttrsTable"
        },
        {
            "eventId": "studyAttrsDataProvider.selectionChangeEvent",
            "action": "changeSelectionToAttribute"
        },
        {
            "eventId": "studyAttrsDataProvider.modelObjectsUpdated",
            "cacheEventData": true,
            "action": "addStudyEventDataToNativeData"
        },
        {
            "eventId": "cdm.updated",
            "cacheEventData": true,
            "action": "isAttrItemUpdated"
        },

        {
            "eventId": "studyTable.gridSelection",
            "cacheEventData": true,
            "action": "setOpenedContext"
        }

    ],
    "i18n": {
        "StudyAttributes": [
            "Att1Messages"
        ],
        "RunAttributes": [
            "Att1Messages"
        ],
        "TestEventAttributes": [
            "Att1Messages"
        ],
        "SelectStudy": [
            "Att1Messages"
        ],
        "SelectRun": [
            "Att1Messages"
        ],
        "SelectTestEvent": [
            "Att1Messages"
        ],
        "noResultsFound": [
            "Att1AttrMappingMessages"
        ],
        "StudyAttributesTC124": [
            "Att1Messages"
        ],
        "RunAttributes": [
            "Att1Messages"
        ],
        "TestEventAttributes": [
            "Att1Messages"
        ],
        "SelectStudyTC124": [
            "Att1Messages"
        ],
        "SelectTestEvent": [
            "Att1Messages"
        ],
        "SelectRun": [
            "Att1Messages"
        ]
    }
}
