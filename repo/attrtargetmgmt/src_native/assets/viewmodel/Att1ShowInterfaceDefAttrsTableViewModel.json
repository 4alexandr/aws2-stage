{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-panel-section.directive",
        "js/aw-indefattr-table-commands.directive"
    ],
    "actions": {
        "addEventDataToNativeData": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "nativeDataLoadEvent",
                        "eventData": {
                            "viewModelObjects": "{{data.dataProviders.interfaceDefAttrsTableProvider.viewModelCollection.loadedVMObjects}}"
                        }
                    }
                ]
            }
        },
        "changeSelectionToAttribute": {
            "actionType": "JSFunction",
            "method": "changeSelectionToAttribute",
            "inputData": {
                "data": "{{data.dataProviders.interfaceDefAttrsTableProvider}}"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "updateShowUnusedSelection": {
            "actionType": "JSFunction",
            "method": "updateShowUnusedSelection",
            "inputData": {
                "from": "{{data.params.showUnusedAttrs}}",
                "to": "Att1ShowInterfaceDefAttrsTableShowUnusedAttrs"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "refreshAttrsTable": {
            "actionType": "dataProvider",
            "method": "interfaceDefAttrsTableProvider"
        },
        "isAttrItemUpdated": {
            "actionType": "JSFunction",
            "method": "isAttrItemUpdated",
            "inputData": {
                "eventMap": "{{data.eventMap}}",
                "refreshEvent": "Att1ShowInterfaceDefAttrsTable.refreshTable"
            },
            "deps": "js/attrTableUtils"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "Crt1InterfaceDefAttrTable"
                },
                "saveColumnConfigData": {
                    "clientScopeURI": "Crt1InterfaceDefAttrTable",
                    "columnConfigId": "{{data.dataProviders.interfaceDefAttrsTableProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.interfaceDefAttrsTableProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "parentUids": "{{ctx.Att1ShowInterfaceDefAttrsTable.parentUids}}",
                        "openedObjectUid": "{{function:getOpenedObjectUidForInterfaceDefs}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true",
                        "showUnusedAttrs": "{{data.params.showUnusedAttrs}}"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.interfaceDefAttrsColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.interfaceDefAttrsTableProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.interfaceDefAttrsColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.interfaceDefAttrsTableProvider.columnConfig": "columnConfig",
                "ctx.selectedAttrProxyObjects": []
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [
                    {
                        "scope": "LoginUser",
                        "scopeName": "",
                        "clientName": "AWClient",
                        "resetColumnConfig": true,
                        "columnConfigQueryInfos": [
                            {
                                "clientScopeURI": "Crt1InterfaceDefAttrTable",
                                "operationType": "configured",
                                "typeNames": [
                                    "WorkspaceObject"
                                ],
                                "columnsToExclude": []
                            }
                        ],
                        "businessObjects": [
                            {}
                        ]
                    }
                ]
            },
            "outputData": {
                "dataProviders.interfaceDefAttrsTableProvider.resetColumnConfigs": "columnConfigurations"
            }
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "Crt1InterfaceDefAttrTable",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "parentUids": "{{ctx.Att1ShowInterfaceDefAttrsTable.parentUids}}",
                        "openedObjectUid": "{{function:getOpenedObjectUidForInterfaceDefs}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true",
                        "showUnusedAttrs": "{{data.params.showUnusedAttrs}}"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.interfaceDefAttrsColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.interfaceDefAttrsTableProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.interfaceDefAttrsColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.interfaceDefAttrsTableProvider.columnConfig": "columnConfig",
                "ctx.selectedAttrProxyObjects": []
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "setOpenedContext": {
            "actionType": "JSFunction",
            "method": "onAttrSelection",
            "inputData": {
                "eventData": "{{data.eventMap}}"
            },
            "deps": "js/attrTableUtils"
        }
    },
    "functions": {
        "getOpenedObjectUidForInterfaceDefs": {
            "functionName": "getOpenedObjectUidForInterfaceDefs",
            "parameters": [
                "{{ctx}}",
                "{{ctx.Att1ShowInterfaceDefAttrsTable.parentUids}}"
            ]
        }
    },
    "columnProviders": {
        "interfaceDefAttrsColumnProvider": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "dataProviders": {
        "interfaceDefAttrsTableProvider": {
            "action": "loadData",
            "editContext": "ATTRIBUTE_TABLE_CONTEXT",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "commandsAnchor": "show_object_command"
        }
    },
    "grids": {
        "interfaceDefAttrsTable": {
            "columnProvider": "interfaceDefAttrsColumnProvider",
            "dataProvider": "interfaceDefAttrsTableProvider",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableSorting": true,
                "maxRowsToShow": 18,
                "isFilteringEnabled": true
            }
        }
    },
    "data": {
        "params": {
            "showUnusedAttrs": "false",
            "showInOut": "",
            "refreshEvent": "Att1ShowInterfaceDefAttrsTable.refreshTable"
        }
    },
    "onEvent": [
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        },
        {
            "eventId": "Att1ShowInterfaceDefAttrsTable.refreshTable",
            "cacheEventData": true,
            "action": "refreshAttrsTable"
        },
        {
            "eventId": "Att1ShowInterfaceDefAttrsTable.refreshTable",
            "cacheEventData": false,
            "action": "updateShowUnusedSelection"
        },
        {
            "eventId": "interfaceDefAttrsTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "changeSelectionToAttribute"
        },
        {
            "eventId": "interfaceDefAttrsTable.nativeData.loaded",
            "cacheEventData": true,
            "action": "addEventDataToNativeData"
        },
        {
            "eventId": "cdm.updated",
            "cacheEventData": true,
            "action": "isAttrItemUpdated"
        },
        {
            "eventId": "interfaceDefAttrsTable.gridSelection",
            "cacheEventData": true,
            "action": "setOpenedContext"
        }
    ],
    "i18n": {
        "attributeTitle": [
            "Att1Messages"
        ]
    }
}