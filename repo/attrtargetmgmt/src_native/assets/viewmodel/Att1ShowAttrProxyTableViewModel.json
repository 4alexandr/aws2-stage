{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-attrproxy-table-commands.directive",
        "js/aw-row.directive"
    ],
    "actions": {
        "editEventAction": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "plTable.editStateChange",
                        "eventData": {
                            "state": "{{data.eventData.state}}",
                            "dataSource": {
                                "dataProviders": "{{data.dataProviders}}"
                            }
                        }
                    }
                ]
            }
        },
        "addEventDataToNativeData": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "nativeDataLoadEvent",
                        "eventData": {
                            "viewModelObjects": "{{data.dataProviders.showAttrProxyTableProvider.viewModelCollection.loadedVMObjects}}"
                        }
                    }
                ]
            }
        },
        "changeSelectionToAttribute": {
            "actionType": "JSFunction",
            "method": "changeSelectionToAttribute",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "updateShowUnusedSelection": {
            "actionType": "JSFunction",
            "method": "updateShowUnusedSelection",
            "inputData": {
                "from": "{{data.params.showUnusedAttrs}}",
                "to": "Att1ShowAttrProxyTableShowUnusedAttrs",
                "data":"{{data}}"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "refreshAttrsTable": {
            "actionType": "dataProvider",
            "method": "showAttrProxyTableProvider"
        },
        "isAttrItemUpdated": {
            "actionType": "JSFunction",
            "method": "isAttrItemUpdated",
            "inputData": {
                "eventMap": "{{data.eventMap}}",
                "refreshEvent": "Att1ShowAttrProxyTable.refreshTable"
            },
            "deps": "js/attrTableUtils"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "{{function:getClientScopeURI}}"
                },
                "saveColumnConfigData": {
                    "clientScopeURI": "{{function:getClientScopeURI}}",
                    "columnConfigId": "{{data.dataProviders.showAttrProxyTableProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.showAttrProxyTableProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "openedObjectUid": "{{function:getOpenedObjectUidForDCP}}",
                        "parentUids": "{{function:getParentUids}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true",
                        "showUnusedAttrs": "{{data.params.showUnusedAttrs}}",
                        "showInOut": "{{function:getShowInOut}}"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.showAttrProxyColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.showAttrProxyTableProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.showAttrProxyColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.showAttrProxyTableProvider.columnConfig": "columnConfig",
                "ctx.selectedAttrProxyObjects": []
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [
                    {
                        "scope": "LoginUser",
                        "scopeName": "",
                        "clientName": "AWClient",
                        "resetColumnConfig": true,
                        "columnConfigQueryInfos": [
                            {
                                "clientScopeURI": "{{function:getClientScopeURI}}",
                                "operationType": "configured",
                                "typeNames": [
                                    "WorkspaceObject"
                                ],
                                "columnsToExclude": []
                            }
                        ],
                        "businessObjects": [
                            {}
                        ]
                    }
                ]
            },
            "outputData": {
                "dataProviders.showAttrProxyTableProvider.resetColumnConfigs": "columnConfigurations"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "{{function:getClientScopeURI}}",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 50,
                    "maxToReturn": 50,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "openedObjectUid": "{{function:getOpenedObjectUidForDCP}}",
                        "parentUids": "{{function:getParentUids}}",
                        "productContextUids":"{{ctx.occmgmtContext.productContextInfo.uid}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true",
                        "getChartInfo": "{{function:isVROrStudyOverviewPageOpened}}",
                        "showUnusedAttrs": "{{data.params.showUnusedAttrs}}",
                        "showInOut": "{{function:getShowInOut}}"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.showAttrProxyColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.showAttrProxyTableProvider.startIndex}}",
                    "columnFilters": "{{function:getColumnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.showAttrProxyTableProvider.columnConfig": "columnConfig",
                "ctx.search.chartData":"additionalSearchInfoMap.searchTermsToHighlight",
                "ctx.selectedAttrProxyObjects": []
            },
            "events": {
                "success": [
                 {
                    "condition": "ctx.isparamDataUpdated === true",
                    "name": "chart.reloadARChart"
                 },
                 {
                    "name": "IAV1ChartViewModel.createChart"
                 },
                 {
                     "name": "Att1ShowAttrproxyTable.clearProviderSelection"
                 }
             ]
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "setOpenedContext": {
            "actionType": "JSFunction",
            "method": "onAttrSelection",
            "inputData": {
                "eventData": "{{data.eventMap}}"
            },
            "deps": "js/attrTableUtils"
        },
        "clearProviderSelection":{
            "actionType": "JSFunction",
            "method": "clearProviderSelection",
            "inputData": {
                "eventData": "{{data}}"
            },
            "deps": "js/Att1AttrProxyTableService"
        },
        "unRegisterCtxForProxyTable":{
            "actionType": "JSFunction",
            "method": "unRegisterCtxForProxyTable",
            "deps": "js/attrTableUtils"
        }
    },
    "preferences": [
        "PLE_MeasurableAttr_Override_RootContext"
    ],
    "functions": {
        "getClientScopeURI": {
            "functionName": "getClientScopeURI",
            "parameters": [
                "{{ctx}}"
            ]
        },
        "getOpenedObjectUidForDCP": {
            "functionName": "getOpenedObjectUidForDCP",
            "parameters": [
                "{{ctx}}"
            ]
        },
        "getParentUids": {
            "functionName": "getParentUids",
            "parameters": [
                "{{ctx}}"
            ]
        },
        "getShowInOut": {
            "functionName": "getShowInOut",
            "parameters": [
                "{{ctx}}",
                "{{data.params.showInOut}}"
            ]
        },
        "getColumnFilters": {
            "functionName": "getColumnFilters",
            "parameters": [
                "{{data}}"
            ]
        },
        "isVROrStudyOverviewPageOpened": {
            "functionName": "isVROrStudyOverviewPageOpened",
            "parameters": [
                "{{ctx}}"
            ]
        }
    },
    "columnProviders": {
        "showAttrProxyColumnProvider": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "dataProviders": {
        "showAttrProxyTableProvider": {
            "action": "loadData",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "multiple",
            "commandsAnchor": "show_object_command"
        }
    },
    "grids": {
        "showAttrProxyTable": {
            "columnProvider": "showAttrProxyColumnProvider",
            "dataProvider": "showAttrProxyTableProvider",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableSorting": true,
                "maxRowsToShow": 18,
                "isFilteringEnabled": true
            }
        }
    },
    "data": {
        "params": {
            "showUnusedAttrs": "false",
            "showInOut": "",
            "refreshEvent": "Att1ShowAttrProxyTable.refreshTable"
        }
    },
    "onEvent": [
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        },
        {
            "eventId": "Att1ShowAttrProxyTable.contentLoaded",
            "action": "updateShowUnusedSelection"
        },
        {
            "eventId": "Att1ShowAttrProxyTable.refreshTable",
            "cacheEventData": true,
            "action": "refreshAttrsTable"
        },
        {
            "eventId": "Att1ShowAttrProxyTable.refreshTable",
            "cacheEventData": false,
            "action": "updateShowUnusedSelection"
        },
        {
            "eventId": "showAttrProxyTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "changeSelectionToAttribute"
        },
        {
            "eventId": "showAttrProxyTableProvider.modelObjectsUpdated",
            "cacheEventData": true,
            "action": "addEventDataToNativeData"
        },
        {
            "eventId": "editHandlerStateChange",
            "cacheEventData": true,
            "action": "editEventAction"
        },
        {
            "eventId": "cdm.updated",
            "cacheEventData": true,
            "action": "isAttrItemUpdated"
        },
        {
            "eventId": "showAttrProxyTable.gridSelection",
            "cacheEventData": true,
            "action": "setOpenedContext"
        },
        {
            "eventId":"Att1ShowAttrProxyTable.contentUnloaded",
            "action": "unRegisterCtxForProxyTable",
            "condition": "ctx.openedARObject===undefined || (_appCtxSvc.ctx.openedARObject && _appCtxSvc.ctx.openedARObject.modelType.typeHierarchyArray.indexOf('Crt0VldnContractRevision') === -1)"
        },
        {
            "eventId": "Att1ShowAttrproxyTable.clearProviderSelection",
            "cacheEventData": true,
            "action":"clearProviderSelection"
        }
    ],
    "i18n": {
        "attributeTitle": [
            "Att1Messages"
        ]
    }
}
