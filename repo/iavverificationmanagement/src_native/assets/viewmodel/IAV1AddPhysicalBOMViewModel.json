{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-panel-footer.directive",
        "js/visible-when.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive",
        "js/aw-add.directive"
    ],
    "actions": {
        "createRelationForPaletteOrSearch":
        {
            "actionType": "Event",
            "method": "Event",
            "inputData":
            {
                 "events":
                 [
                     {
                         "name": "addPhyBOM.addPhyBOMPostProcess"
                     }
                 ]
            }

        },
        "postProcess":
        {
            "actionType": "JSFunction",
            "method": "getManageVRInputToAddToBOMTable",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/IAV1AddToVRService",
            "outputData": {
                "getManageVRInputToAddToBOMTable": ""
            },
            "events": {
                "success": [
                    {
                        "name": "manageAnalysisRequests"
                    }
                ]
            }
        },
        "manageAnalysisRequests": {
            "actionType": "JSFunction",
            "method": "callManageVerificationSOA",
            "inputData": {
                "input": "{{data.getManageVRInputToAddToBOMTable.input}}",
                "pref": "{{data.getManageVRInputToAddToBOMTable.pref}}",
                "data": "{{data}}",
                "tableContext": "PhyBOMTable"
            },
            "deps": "js/manageVerificationService",
            "events": {
                "success": [
                    {
                        "name": "closePanel"
                    }
                ]
            }
        },
        "closePanel":
        {
            "actionType": "Event",
            "method": "Event",
            "inputData":
            {
                 "events":
                 [
                     {
                        "name": "complete",
                        "eventData":
                        {
                            "source": "toolAndInfoPanel"
                        }
                    }

                 ]
            }
        }
    },
    "functions": {
    "getCreateRelationInput": {
        "functionName": "getCreateRelationInput",
        "parameters":
        [
            "{{data}}"
        ]
     }
    },

    "onEvent": [
        {
            "eventId": "closePanel",
            "action": "closePanel"
        },
        {
            "eventId": "addPhyBOM.addPhyBOMPostProcess",
            "action": "postProcess"
        },
        {
            "eventId": "manageAnalysisRequests",
            "action": "manageAnalysisRequests"
        }
    ],
    "i18n": {
        "AddBOMTitle": [
            "verificationMgmtmMessages"
        ],
        "Add": [
            "verificationMgmtmMessages"
        ]
    }
}
