{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-command-bar.directive",
        "js/aw-panel-section.directive"
    ],
    "actions": {
        "editEventAction": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "plTable.editStateChange",
                        "eventData": {
                            "state": "{{data.eventData.state}}",
                            "dataSource": {
                                "dataProviders": "{{data.dataProviders}}"
                            }
                        }
                    }
                ]
            }
        },
        "addEventDataToNativeData": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "nativeDataLoadEvent",
                        "eventData": {
                            "viewModelObjects": "{{data.dataProviders.testEBOMTableProvider.viewModelCollection.loadedVMObjects}}"
                        }
                    }
                ]
            }
        },
        "refreshPhyBOMTable": {
            "actionType": "dataProvider",
            "method": "testEBOMTableProvider"
        },
        "changeSelectionForPhyBOM": {
            "actionType": "JSFunction",
            "method": "changeSelectionForPhyBOM",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/IAV1ContentsTMTableService"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",

            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "Crt1TestAndProdBomTable"
                },
                "saveColumnConfigData": {
                    "clientScopeURI": "Crt1TestAndProdBomTable",
                    "columnConfigId": "{{data.dataProviders.testEBOMTableProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.testEBOMTableProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 10,
                    "maxToReturn": 10,
                    "providerName": "Crt1AnalysisRequestInProvider",
                    "searchCriteria": {
                        "parentUid": "{{ctx.selected.uid}}",
                        "requestedTypeFilter": "TestBOM"
                    },
                    "startIndex": "{{data.dataProviders.testEBOMTableProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.testEBOMTableColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.testEBOMTableProvider.columnConfig": "columnConfig"
            },
            "deps": "js/analysisRequestUtils"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [
                    {
                        "scope": "LoginUser",
                        "scopeName": "",
                        "clientName": "AWClient",
                        "resetColumnConfig": true,
                        "columnConfigQueryInfos": [
                            {
                                "clientScopeURI": "Crt1TestAndProdBomTable",
                                "operationType": "configured",
                                "typeNames": [
                                    "WorkspaceObject"
                                ],
                                "columnsToExclude": []
                            }
                        ],
                        "businessObjects": [
                            {}
                        ]
                    }
                ]
            },
            "outputData": {
                "dataProviders.testEBOMTableProvider.resetColumnConfigs": "columnConfigurations"
            },
            "deps": "js/analysisRequestUtils"
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "Crt1TestAndProdBomTable",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 10,
                    "maxToReturn": 10,
                    "providerName": "Crt1AnalysisRequestInProvider",
                    "searchCriteria": {
                        "parentUid": "{{ctx.xrtSummaryContextObject.uid}}",
                        "requestedTypeFilter": "PhysicalTestBOM"
                    },
                    "startIndex": "{{data.dataProviders.testEBOMTableProvider.startIndex}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.testEBOMTableProvider.columnConfig": "columnConfig"
            },
            "deps": "js/analysisRequestUtils"
        }
    },
    "columnProviders": {
        "testEBOMTableColumnProvider": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "dataProviders": {
        "testEBOMTableProvider": {
            "action": "loadData",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "multiple",
            "commandsAnchor": "Open_StudyAttr_command"
        }
    },
    "grids": {
        "testEBOMTable": {
            "columnProvider": "testEBOMTableColumnProvider",
            "dataProvider": "testEBOMTableProvider",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableSorting": true,
                "maxRowsToShow": 6,
                "isFilteringEnabled": true
            }
        }
    },
    "onEvent": [
        {
            "eventId": "testEBOMTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "changeSelectionForPhyBOM"
        },
        {
            "eventId": "testEBOMTableProvider.refreshTable",
            "cacheEventData": true,
            "action": "refreshPhyBOMTable"
        }
    ]
}
