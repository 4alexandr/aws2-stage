{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-chart.directive",
        "js/aw-row.directive"
    ],

    "actions": {
        "getChartData": {
            "actionType": "JSFunction",
            "method": "loadStudyObjects",
            "inputData": {
                "input":  "{{ctx.xrtSummaryContextObject.uid}}"
            },
            "deps": "js/IAV1BarChartService"
        },
        "resetColumnFilters": {
            "actionType": "JSFunction",
            "method": "resetColumnFilters",
            "inputData": {
                "input":  "{{data}}"
            },
            "deps": "js/IAV1BarChartService"
        },

        "createChart": {
            "actionType": "JSFunction",
            "method": "createBarChart",
            "inputData": {
                "input":  "{{data}}"
            },
            "outputData": {
                "chartProviders.pieChartProvider2.chartPoints": ""
            },
            "deps": "js/IAV1BarChartService"
        },

        "getParamOfStudies": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "ARInputAttrTable",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 10,
                    "maxToReturn": 10,
                    "providerName": "Att1AttributeMapProvider",
                    "searchCriteria": {
                        "parentUids": "{{ctx.ARStudies}}",
                        "queryMappedAttrs": "false",
                        "dcpSortByDataProvider": "true"
                    }
                },
                "inflateProperties": true
            },
            "events":
            {
                "success":
                [
                    {
                        "name": "IAV1BarChartViewModel.createChart"
                    }

                ]
            },
            "outputData": {
                "totalFound": "totalFound",
                "modelObjects": "ServiceData.modelObjects",
                "ctx.selectedAttrProxyObjects2": []
            },
            "deps": "js/IAV1BarChartService"

        },
        "filterStudyTable": {
            "actionType": "JSFunction",
            "method": "filterStudyTable",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/IAV1BarChartService"
        },
        "displayAll": {
            "actionType": "JSFunction",
            "method": "displayAll",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/IAV1BarChartService"
        },
        "checkAndReloadBarChart": {
            "actionType": "JSFunction",
            "method": "checkAndReloadBarChart",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/IAV1BarChartService"
        }
    },

    "data": {
        "chartProviders" : {
            "pieChartProvider2": {
                "chartType": "column",
                "chartColorOverrideClass":"aw-verificationManagement-chartStatusColor",
                "loadDataAction": "getChartData",
                "chartConfig": {
                    "isChartZoomable": true,
                    "isYAxisLinearOrLogarithmic": "linear",
                    "xAxisLabel": "",
                    "yAxisLabel": "",
                    "isDataLabelOnChartEnabled": true
                }
            }
        }
    },

    "onEvent": [ {
        "eventId": "getParamOfStudies",
        "action": "getParamOfStudies"
    },
    {
        "eventId": "IAV1BarChartViewModel.createChart",
        "action": "createChart"
    },
    {
        "eventId": "drawBarChart",
        "action": "getChartData"
    },
    {
        "eventId": "undefined.selected",
        "cacheEventData": true,
        "action": "filterStudyTable"
    },
    {
        "eventId": "undefined.unselected",
        "cacheEventData": true,
        "action": "displayAll"
    },
    {
        "eventId": "IAV1BarChart.contentUnloaded",
        "cacheEventData": true,
        "action": "resetColumnFilters"
    },
    {
        "eventId": "plTable.editStateChange",
        "action": "checkAndReloadBarChart"
    }
],
"i18n": {
    "NoResult": [
        "verificationMgmtmMessages"
    ],
    "Fail": [
        "verificationMgmtmMessages"
    ],
    "Pass": [
        "verificationMgmtmMessages"
    ],
    "Contents": [
        "verificationMgmtmMessages"
    ],
    "Parameters": [
        "verificationMgmtmMessages"
    ],
    "Output": [
        "verificationMgmtmMessages"
    ],
    "output": [
        "verificationMgmtmMessages"
    ]
}


}
