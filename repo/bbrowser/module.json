{
  "name": "bbrowser",
  "description": "",
  "type": [
    "native"
  ],
  "srcDir": "src_native",
  "pathOffset": ".",
  "skipAudit": true,
  "skipTest": true,
  "version": "5.1.0",
  "author": "Siemens Product Lifecycle Management Software Inc.",
  "commandsViewModel": {
    "commands": {
      "bbrowserCompareViewer": {
        "iconId": "cmdCompare",
        "title": "{{i18n.compare}}",
        "description": "{{i18n.bbrowserCompareViewerDesc}}"
      },
      "bbrowserOneClickViewer": {
        "iconId": "cmdViewConvenience",
        "title": "{{i18n.LoadButton}}",
        "description": "{{i18n.bbrowserOneClickViewerDesc}}"
      }
    },
    "commandHandlers": {
      "bbrowserCompareCommandHandler": {
        "id": "bbrowserCompareViewer",
        "action": "launchBriefcaseCompareViewerPanel",
        "activeWhen": true,
        "visibleWhen": {
          "condition": "conditions.isBriefcaseCompare"
        }
      },
      "bbrowserOneClickViewerCommandHandler": {
        "id": "bbrowserOneClickViewer",
        "action": "launchOneClickViewerPanel",
        "activeWhen": true,
        "visibleWhen": {
          "condition": "conditions.isBriefcaseOneClickViewer"
        }
      }
    },
    "commandPlacements": {
      "bbrowserCompareToolsAndInfo": {
        "id": "bbrowserCompareViewer",
        "uiAnchor": "aw_rightWall",
        "parentGroupId": "Awp0ViewGroup",
        "priority": 350
      },
      "bbrowserOneClickViewerToolsAndInfo": {
        "id": "bbrowserOneClickViewer",
        "uiAnchor": "aw_rightWall",
        "parentGroupId": "Awp0ViewGroup",
        "priority": 350
      }
    },
    "actions": {
      "launchBriefcaseCompare": {
        "actionType": "JSFunction",
        "method": "launchBriefcaseCompare",
        "deps": "js/bbrowserCompareService",
        "inputData": {
          "srcUID": "{{ctx.mselected[0].uid}}",
          "targetUID": "{{ctx.mselected[1].uid}}"
        }
      },
      "launchOneClickViewer": {
        "actionType": "JSFunction",
        "method": "launchOneClickViewer",
        "deps": "js/bbrowserOneClickViewerService",
        "inputData": {
          "srcUID": "{{ctx.mselected[0].uid}}"
        }
      },
      "launchOneClickViewerPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "bbrowserOneClickViewer",
          "location": "aw_toolsAndInfo"
        }
      },
      "launchBriefcaseCompareViewerPanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "bbrowserCompareViewer",
          "location": "aw_toolsAndInfo"
        }
      }
    },
    "functions": {},
    "onEvent": [],
    "conditions": {
      "isBriefcaseCompare": {
        "expression": "((ctx.mselected.length === 2)) && ((ctx.mselected[0].modelType !== null)) && ((ctx.mselected[1].modelType !== null)) && ((ctx.mselected[0].modelType !== undefined)) && ((ctx.mselected[1].modelType !== undefined)) && ( ctx.mselected[0].modelType.typeHierarchyArray !== null )  && ( ctx.mselected[0].modelType.typeHierarchyArray !== undefined )  &&  ( ctx.mselected[0].modelType.typeHierarchyArray.indexOf( 'Briefcase' ) != -1) && ( ctx.mselected[1].modelType.typeHierarchyArray !== null )  && ( ctx.mselected[1].modelType.typeHierarchyArray !== undefined )  && ( ctx.mselected[1].modelType.typeHierarchyArray.indexOf( 'Briefcase' ) != -1) && ((ctx.workspace.availablePages.indexOf('compareBriefcase')) != -1)"
      },
      "isBriefcaseOneClickViewer": {
        "expression": "((ctx.mselected.length === 1)) && ((ctx.mselected[0].modelType !== null)) && ((ctx.mselected[0].modelType !== undefined)) && ( ctx.mselected[0].modelType.typeHierarchyArray !== null )  && ( ctx.mselected[0].modelType.typeHierarchyArray !== undefined ) &&  ( ctx.mselected[0].modelType.typeHierarchyArray.indexOf( 'Briefcase' ) != -1) && ((ctx.workspace.availablePages.indexOf('viewerBriefcase')) != -1)"
      }
    },
    "messages": {},
    "i18n": {
      "compare": [
        "bbrowserMessages"
      ],
      "LoadButton": [
        "bbrowserMessages"
      ],
      "bbrowserCompareViewerDesc": [
        "bbrowserMessages"
      ],
      "bbrowserOneClickViewerDesc": [
        "bbrowserMessages"
      ]
    }
  },
  "states": {
    "compareBriefcaseParentLoc": {
      "data": {
        "browserSubTitle": {
          "source": "/i18n/bbrowserCompareMessages",
          "key": "locationBrowserSubTitle"
        },
        "headerTitle": {
          "source": "/i18n/bbrowserCompareMessages",
          "key": "locationHeaderTitle"
        }
      },
      "type": "location"
    },
    "compareBriefcase": {
      "controller": "NativeSubLocationCtrl",
      "data": {
        "priority": 0,
        "label": {
          "source": "/i18n/bbrowserCompareMessages",
          "key": "compareSubLocationTitle"
        },
        "clientScopeURI": "",
        "nameToken": "compareBriefcase"
      },
      "dependencies": [
        "js/aw.native.sublocation.controller"
      ],
      "params": {
        "filter": null,
        "src_uid": null,
        "trg_uid": null,
        "src_map_uid": null,
        "tar_map_uid": null
      },
      "templateUrl": "/html/aw.native.sublocation.html",
      "parent": "compareBriefcaseParentLoc",
      "type": "subLocation",
      "url": "/compareBriefcase",
      "view": "bbrowserComparePage"
    },
    "OneClickViewerBriefcaseParentLoc": {
      "data": {
        "browserSubTitle": {
          "source": "/i18n/bbrowserMessages",
          "key": "locationOneClickViewerSubTitle"
        },
        "headerTitle": {
          "source": "/i18n/bbrowserMessages",
          "key": "locationClickViewerHeaderTitle"
        }
      },
      "type": "location"
    },
    "viewerBriefcase": {
      "controller": "NativeSubLocationCtrl",
      "data": {
        "priority": 0,
        "label": {
          "source": "/i18n/bbrowserCompareMessages",
          "key": "locationClickViewerHeaderTitle"
        },
        "clientScopeURI": "viewerBriefcase",
        "nameToken": "viewerBriefcase"
      },
      "dependencies": [
        "js/aw.native.sublocation.controller"
      ],
      "params": {
        "filter": null,
        "src_uid": null,
        "src_map_uid": null
      },
      "templateUrl": "/html/aw.native.sublocation.html",
      "parent": "OneClickViewerBriefcaseParentLoc",
      "type": "subLocation",
      "url": "/viewerBriefcase",
      "view": "bbrowserOneClickViewerPage"
    }
  }
}
