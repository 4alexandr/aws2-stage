{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-i18n.directive",
        "js/aw-panel-section.directive",
        "js/aw-listbox.directive",
        "js/aw-button.directive",
        "js/aw-list.directive",
        "js/aw-default-cell.directive"       
    ],
    "data": {
        "selectedMapping": {
            "displayName": "{{i18n.transferOptionSet}}",
            "isSelectOnly": "true",
            "type": "STRING",
            "isRequired": "false",
            "hasLov": true
        }
    },
    "actions": {
        "reveal":
        {
            "actionType": "JSFunction",
            "method": "getTransferOptionSets",
            "inputData":
            {
                "input": "{{ctx.mselected[0].uid}}",
                "data": "{{data}}"

            },

            "outputData":
            {
                "mappingList": ""
            },

            "deps": "js/bbrowserTableDataService"
        },
        "loadBriefcaseWindow": {
            "actionType": "JSFunction",
            "method": "launchOneClickViewer",
            "deps": "js/bbrowserOneClickViewerService",
            "inputData": {
                "srcUID": "{{ctx.mselected[0].uid}}",
                "data": "{{data.selectedMapping}}"  
            }
        },
        "getSourceContexts": {
            "actionType": "JSFunction",
            "method": "previewContext",
            "inputData":{
                "inf": "{{ctx.mselected[0].uid}}"
            },
            "outputData": {
                "sourceContexts": ""
            },
            "deps": "js/bbrowserOneClickViewerService"
        },
        "revealSource": {
            "actionType": "dataProvider",
            "method": "getSourceContextData"
        }
    },
    "dataProviders":{
        "getSourceContextData": {
            "action": "getSourceContexts",
            "response": "{{data.sourceContexts}}",
            "selectionModelMode": "single"
        }
    },
    "messages": {
    },
    "onEvent": [
        {
        "eventId": "bbrowserOneClickViewer.contentLoaded",
        "action": "revealSource"
        }
    ],
    "conditions": {
    },
    "functions": {
    },
    "i18n": {
        "pickTOSPanel": ["bbrowserMessages"],
        "transferOptionSetLabel": ["bbrowserMessages"],
        "LoadButton": ["bbrowserMessages"],
        "transferOptionSet" : ["bbrowserMessages"],
        "tosPanelSourceBCZ" : ["bbrowserMessages"]
    }
}
