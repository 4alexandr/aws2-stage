{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel-body.directive",
        "js/aw-list.directive",
        "js/aw-default-cell.directive",
        "js/aw-sublocation.directive",
        "js/aw-label.directive",
        "js/aw-splm-table.directive"
    ],
    "data": {
        "sourceTransferSet": {
            "displayName": "{{i18n.tosSourceLabel}}",
            "type": "STRING",
            "labelPosition": "PROPERTY_LABEL_AT_LEFT"
        }
    },
    "onEvent": [ 
        {
            "eventId": "bbrowserOneClickViewerPage.contentLoaded",
            "action": "revealSource"
        },
        {
            "eventId": "bbrowserOneClickViewerPage.contentLoaded",
            "action": "revealSourceMapping"
        }
    ],
    "actions": {
        "loadPrimaryTableProperties": {
        "actionType": "JSFunctionAsync",
        "method": "loadTreeTableProperties",
        "inputData": {
            "propertyLoadInput": "request.propertyLoadInput",
            "delayTimeProperty": "{{data.delayTimeProperty}}"
        },
        "outputData": {},
        "deps": "js/bbrowserTableDataService"
        },

        "loadPrimaryTableColumns": {
            "actionType": "JSFunction",
            "method": "loadTreeTableColumns",
            "inputData": {
                "dataProvider": "{{data.dataProviders.primaryTableDataProvider}}"
            },
            "deps": "js/bbrowserTableDataService"
        },
        "loadTreeData": {
            "actionType": "JSFunctionAsync",
            "method": "loadTreeTableDataPaging",
            "inputData": {
                "treeLoadInput": "request.treeLoadInput",
                "dataProvider": "{{data.dataProviders.primaryTableDataProvider}}",
                "srcUID": "{{ctx.state.params.src_uid}}",
                "trgUID": "",
                "SearchedUID": "",
                "data" : "{{data}}",
                "gridNameID": "compareSourceTreeView",
                "srcMapUID": "{{ctx.state.params.src_map_uid}}",
                "tarMapUID": ""
            },
            "outputData": {
            },
            "deps": "js/bbrowserTableDataService"
        },

        "loadTreePage": {
            "actionType": "JSFunctionAsync",
            "method": "loadTreeTablePage",
            "inputData": {
                "treeLoadInput": "request.treeLoadInput",
                "srcUID": "{{ctx.state.params.src_uid}}",
                "trgUID": "",
                "SearchedUID": "",
                "srcMapUID": "{{ctx.state.params.src_map_uid}}",
                "tarMapUID": ""
            },
            "outputData": {
            },
            "deps": "js/bbrowserTableDataService"
        },

        
        "getSourceContexts": {
            "actionType": "JSFunction",
            "method": "getSourceContexts",
            "outputData": {
                "sourceContexts": ""
            },
            "deps": "js/bbrowserOneClickViewerService"
        },
        "revealSource": {
            "actionType": "dataProvider",
            "method": "getSourceContextData"
        },
        "revealSourceMapping": {
            "actionType": "JSFunction",
            "method": "getSourceMappingContexts",
            "inputData": {
                "Data" : "{{data}}"
            },
            "deps": "js/bbrowserOneClickViewerService"
        }
    },
    "dataProviders": {
        "primaryTableDataProvider": {
            "initializeAction": "loadTreeData",
            "nextAction": "loadTreePage",
            "previousAction": "loadTreePage",
            "treeLoadResult": "action.result.treeLoadResult",
            "selectionModelMode": "single",
            "inputData": {
                "accessMode": "tree"
            }
        },
        "primaryTablePropertyProvider": {
            "action": "loadPrimaryTableProperties",
            "propertyLoadResult": "action.result.propertyLoadResult"
        },
        "getSourceContextData": {
            "action": "getSourceContexts",
            "response": "{{data.sourceContexts}}",
            "selectionModelMode": "single"
        }


    },
    "grids": {
        "compareSourceTreeView": {
            "dataProvider": "primaryTableDataProvider",
            "propertyProvider": "primaryTablePropertyProvider",
            "columnProvider": "primaryTableColumnProvider",
            "addIconColumn": false,
            "gridOptions": {
                "enableGridMenu": false,
                "enablePinning": true,
                "enableSorting": false,
                "maxRowsToShow": 17
            }
        }
    },
    "columnProviders": {
        "primaryTableColumnProvider": {
            "loadColumnAction": "loadPrimaryTableColumns",
            "columns": "{{data.columns}}",
            "soaEnabled": false,
            "sortCriteria": []
        }
    },
    "i18n": {
        "tosSourceLabel" : ["bbrowserMessages"]
    }
}