{
  "name": "eda",
  "description": "",
  "type": [
    "native"
  ],
  "srcDir": "src_native",
  "pathOffset": ".",
  "skipAudit": true,
  "skipTest": true,
  "version": "5.1.0",
  "author": "Siemens Product Lifecycle Management Software Inc.",
  "aliasRegistry": {
    "typeEDA48": [
      "EDA"
    ],
    "typeEDARevision48": [
      "EDA Revision"
    ],
    "typeEDACCABase48": [
      "EDACCABase"
    ],
    "typeEDACCABaseRevision48": [
      "EDACCABaseRevision"
    ],
    "typeEDAComponent48": [
      "EDAComp"
    ],
    "typeEDAComponentRevision48": [
      "EDAComp Revision"
    ],
    "typeEDAFootprint48": [
      "EDAFootprint"
    ],
    "typeEDAFootprintRevision48": [
      "EDAFootprint Revision"
    ],
    "typeEDAPackage48": [
      "EDAPackage"
    ],
    "typeEDAPackageRevision48": [
      "EDAPackage Revision"
    ],
    "typeEDASymbol48": [
      "EDASymbol"
    ],
    "typeEDASymbolRevision48": [
      "EDASymbol Revision"
    ],
    "typeEDAFabrication48": [
      "EDAFAb"
    ],
    "typeEDAGenPCBCAD48": [
      "EDAGenPCBCAD"
    ],
    "typeEDAGenSchematic48": [
      "EDAGenSchem"
    ],
    "typeEDAIdf48": [
      "Eda0IDXIncrement"
    ],
    "typeIdxBaseline48": [
      "Eda0IDXBaseline"
    ],
    "typeEDAPadstack48": [
      "EDAPadstack"
    ],
    "typeEDAAssembly48": [
      "EDAAsm"
    ],
    "typeEcadDfx48": [
      "ECADDFX"
    ],
    "typeEcadSchematicFtaf48": [
      "SCHFATF"
    ],
    "typeEcadPcbMarkup48": [
      "PCBMarkup"
    ],
    "typeMentorDEPackage48": [
      "Epl0EDXPackage"
    ],
    "typeEcadPcbFtaf48": [
      "PCBFATF"
    ],
    "typeEdaSchematic48": [
      "EDASchem",
      "EDASchem Revision"
    ],
    "typeEcadPcbPanel48": [
      "PCBPanel",
      "PCBPanel Revision"
    ]
  },
  "commandsViewModel": {
    "commands": {
      "Eda1OpenInEdm": {
        "iconId": "cmdOpen",
        "isGroup": false,
        "title": "{{i18n.openInEdmViewCommandTitle}}"
      },
      "Eda1AddDesignToCollab": {
        "iconId": "cmdAdd",
        "isGroup": false,
        "title": "{{i18n.submitToDesignExchange}}"
      },
      "Eda1NewCollaboration": {
        "iconId": "cmdAdd",
        "isGroup": false,
        "title": "{{i18n.newCollaborationCommand}}"
      },
      "Eda1RemoveDesignFromCollab": {
        "iconId": "cmdRemove",
        "isGroup": false,
        "title": "{{i18n.removeDesign}}"
      },
      "Eda1OpenIncrementCommand": {
        "iconId": "cmdOpen",
        "title": "{{i18n.openIncrement}}"
      },
      "Eda1OpenObjectCommand": {
        "iconId": "cmdOpen",
        "title": "{{i18n.openObject}}"
      }
    },
    "commandHandlers": {
      "Eda1OpenInViewCommandHandler": {
        "id": "Eda1OpenInEdm",
        "action": "executeEda1OpenInEdmCommand",
        "activeWhen": {
          "condition": "conditions.Eda1OpenInEdm"
        },
        "visibleWhen": {
          "condition": "conditions.Eda1OpenInEdm"
        }
      },
      "Eda1AddDesignToCollabCommandHandler": {
        "id": "Eda1AddDesignToCollab",
        "action": "openSubmitToDesignExchangePanel",
        "activeWhen": {
          "condition": "conditions.Eda1AtCollabSubLocation"
        },
        "visibleWhen": {
          "condition": "conditions.Eda1AtCollabSubLocation"
        }
      },
      "Eda1RemoveDesignFromCollabCommandHandler": {
        "id": "Eda1RemoveDesignFromCollab",
        "action": "getConfirmationForRemoveDesign",
        "activeWhen": {
          "condition": "conditions.Eda1RemoveDesignFromCollab"
        },
        "visibleWhen": {
          "condition": "conditions.Eda1RemoveDesignFromCollab"
        }
      },
      "Eda1NewCollaborationCommandHandler": {
        "id": "Eda1NewCollaboration",
        "action": "newCollaborationAction",
        "activeWhen": {
          "condition": "conditions.Eda1NewCollaboration"
        },
        "visibleWhen": {
          "condition": "conditions.Eda1NewCollaboration"
        }
      },
      "Eda1OpenIncrementCommandHandler": {
        "id": "Eda1OpenIncrementCommand",
        "action": "eda0OpenIncrement",
        "activeWhen": true,
        "visibleWhen": true
      },
      "Eda1OpenObjectCommandHandler": {
        "id": "Eda1OpenObjectCommand",
        "action": "eda0OpenIncrement",
        "activeWhen": true,
        "visibleWhen": true
      }
    },
    "commandPlacements": {
      "Eda1OpenInEdmOneStep": {
        "id": "Eda1OpenInEdm",
        "uiAnchor": "aw_oneStep",
        "priority": 4,
        "parentGroupId": "Awp0OpenGroup"
      },
      "Eda1AddDesignToCollabCommandOneStep": {
        "id": "Eda1AddDesignToCollab",
        "priority": 201,
        "uiAnchor": "aw_rightWall",
        "parentGroupId": "Awp0NewGroup"
      },
      "Eda1RemoveDesignFromCollabCommandPlacement": {
        "id": "Eda1RemoveDesignFromCollab",
        "uiAnchor": "aw_rightWall",
        "priority": 210,
        "parentGroupId": "Awp0EditGroup"
      },
      "Eda1NewCollaborationPlacement": {
        "id": "Eda1NewCollaboration",
        "uiAnchor": "aw_oneStep",
        "priority": 900,
        "parentGroupId": "Awp0NewGroup"
      },
      "Eda1OpenIncrementCommandPlacement": {
        "id": "Eda1OpenIncrementCommand",
        "uiAnchor": "eda_open_increment",
        "priority": 1,
        "cellDisplay": {
          "hover": true,
          "position": "TOP_RIGHT",
          "selected": true
        }
      },
      "Eda1OpenObjectCommandPlacement": {
        "id": "Eda1OpenObjectCommand",
        "uiAnchor": "eda_open_object",
        "priority": 1,
        "cellDisplay": {
          "hover": true,
          "position": "TOP_RIGHT",
          "selected": true
        }
      }
    },
    "actions": {
      "executeEda1OpenInEdmCommand": {
        "actionType": "JSFunction",
        "method": "redirectToUrl",
        "deps": "js/Eda0OpenInViewerService"
      },
      "getConfirmationForRemoveDesign": {
        "actionType": "Event",
        "method": "Event",
        "inputData": {
          "events": [
            {
              "name": "eda1GetRemoveDesignConfirmationEvent"
            }
          ]
        }
      },
      "removeDesignFromList": {
        "actionType": "TcSoaService",
        "serviceName": "EDMDCollab-2020-04-EDMDCollaboration",
        "method": "createOrUpdateCollaboration",
        "inputData": {
          "createOrUpdateInput": {
            "collaborationToCreateOrUpdate": {
              "collabObjectUID": "{{ctx.locationContext.modelObject.uid}}"
            },
            "detachObjectsFromCollaboration": [
              "{{ctx.selected.uid}}"
            ]
          }
        },
        "events": {
          "success": [
            {
              "name": "cdm.relatedModified",
              "eventData": {
                "refreshLocationFlag": true,
                "relatedModified": [
                  "{{ctx.locationContext.modelObject}}"
                ]
              }
            }
          ]
        }
      },
      "openSubmitToDesignExchangePanel": {
        "actionType": "JSFunction",
        "method": "activateCommandPanel",
        "deps": "js/commandPanel.service",
        "inputData": {
          "commandId": "Eda0DesignCollabPanel",
          "location": "aw_toolsAndInfo",
          "context": "{{ctx.selected}}"
        }
      },
      "newCollaborationAction": {
        "actionType": "TcSoaService",
        "serviceName": "EDMDCollab-2020-04-EDMDCollaboration",
        "method": "createOrUpdateCollaboration",
        "inputData": {
          "createOrUpdateInput": {
            "collaborationToCreateOrUpdate": {
              "collabObjectUID": "",
              "objectProps": {
                "object_name": [
                  "{{function:constructCCObjectName}}"
                ]
              }
            },
            "attachObjectsToCollaboration": [
              {
                "objectUID": "{{function:getUnderlyingObjectUid}}",
                "relationName": ""
              }
            ]
          }
        },
        "outputData": {
          "collaborationUID": "collaborationObject.uid"
        },
        "events": {
          "success": [
            {
              "name": "eda1ShowCollaborationEvent"
            }
          ]
        },
        "deps": "js/Eda0UtilService"
      },
      "eda1ShowCollaborationAction": {
        "actionType": "Navigate",
        "navigateTo": "com_siemens_splm_clientfx_tcui_xrt_showObject",
        "navigationParams": {
          "uid": "{{data.collaborationUID}}"
        }
      },
      "eda0OpenIncrement": {
        "actionType": "Navigate",
        "navigateTo": "com_siemens_splm_clientfx_tcui_xrt_showObject",
        "navigationParams": {
          "uid": {
            "$adapt": "{{commandContext.vmo}}",
            "path": "uid"
          }
        }
      }
    },
    "messages": {
      "removeDesignFromCollaboration": {
        "messageType": "WARNING",
        "messageText": "{{i18n.removeDesignFromCollaboration}}",
        "messageTextParams": [
          "{{ctx.mselected[0].props.object_string.dbValues[0]}}"
        ],
        "navigationOptions": [
          {
            "option": "Cancel",
            "text": "{{i18n.CancelText}}",
            "action": ""
          },
          {
            "option": "Remove",
            "text": "{{i18n.RemoveText}}",
            "action": "removeDesignFromList"
          }
        ]
      }
    },
    "i18n": {
      "CancelText": [
        "EdaMessages"
      ],
      "RemoveText": [
        "EdaMessages"
      ],
      "openInEdmViewCommandTitle": [
        "EdaMessages"
      ],
      "submitToDesignExchange": [
        "EdaMessages"
      ],
      "removeDesign": [
        "EdaMessages"
      ],
      "removeDesignFromCollaboration": [
        "EdaMessages"
      ],
      "newCollaborationCommand": [
        "EdaMessages"
      ],
      "openIncrement": [
        "EdaMessages"
      ],
      "openObject": [
        "EdaMessages"
      ]
    },
    "conditions": {
      "Eda1OpenInEdm": {
        "expression": "ctx.selected.props.eda1IsDesignDataExist.uiValues[0] === 'True'"
      },
      "Eda1AtCollabSubLocation": {
        "expression": "ctx.locationContext['ActiveWorkspace:SubLocation'] === 'com.siemens.splm.client.eda.edmdCollabSubLocation'"
      },
      "Eda1RevisionSelectedInTypeHierachy": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf( 'ItemRevision' ) > -1"
      },
      "Eda1SingleDesignSelected": {
        "expression": "ctx.mselected.length == 1"
      },
      "Eda1RemoveDesignFromCollab": {
        "expression": "conditions.Eda1AtCollabSubLocation && conditions.Eda1RevisionSelectedInTypeHierachy && conditions.Eda1SingleDesignSelected"
      },
      "Eda1NewCollaboration": {
        "expression": {
          "$and": [
            {
              "$source": "ctx.selected.props.eda0Collaboration.dbValues[0]",
              "$query": {
                "$isNull": true
              }
            },
            {
              "$or": [
                {
                  "$source": "ctx.selected",
                  "$query": {
                    "$source": "modelType.typeHierarchyArray",
                    "$query": {
                      "$in": [
                        "Awb0Element"
                      ]
                    }
                  }
                },
                {
                  "$source": "ctx.selected",
                  "$query": {
                    "$source": "modelType.typeHierarchyArray",
                    "$query": {
                      "$in": [
                        "ItemRevision"
                      ]
                    }
                  }
                }
              ]
            }
          ]
        }
      }
    },
    "onEvent": [
      {
        "eventId": "eda1ShowCollaborationEvent",
        "action": "eda1ShowCollaborationAction"
      },
      {
        "eventId": "eda1GetRemoveDesignConfirmationEvent",
        "message": "removeDesignFromCollaboration"
      }
    ],
    "functions": {
      "constructCCObjectName": {
        "functionName": "constructCCObjectName",
        "parameters": [
          "{{ctx}}"
        ]
      },
      "getUnderlyingObjectUid": {
        "functionName": "getUnderlyingObjectUid",
        "parameters": [
          "{{ctx}}"
        ]
      }
    }
  },
  "typeProperties": {
    "typeProperties": {
      "ItemRevision": {
        "additionalProperties": [
          {
            "name": "items_tag"
          },
          {
            "name": "eda0Collaboration"
          }
        ]
      },
      "EDACCABaseRevision": {
        "additionalProperties": [
          {
            "name": "eda1IsDesignDataExist"
          }
        ]
      }
    }
  }
}
