{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-command-bar.directive",
        "js/aw-panel-section.directive"
    ],
    "actions": {
        "clearProviderSelection":{
            "actionType": "JSFunction",
            "method": "clearProviderSelection",
            "inputData": {
                "eventData": "{{data}}"
            },
            "deps": "js/Crt1SelectionService"
        },
        "editEventAction": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "plTable.editStateChange",
                        "eventData": {
                            "state": "{{data.eventData.state}}",
                            "dataSource": {
                                "dataProviders": "{{data.dataProviders}}"
                            }
                        }
                    }
                ]
            }
        },
        "addEventDataToNativeData": {
            "actionType": "Event",
            "method": "Event",
            "inputData": {
                "events": [
                    {
                        "name": "nativeDataLoadEvent",
                        "eventData": {
                            "viewModelObjects": "{{data.dataProviders.contentsTableProvider.viewModelCollection.loadedVMObjects}}"
                        }
                    }
                ]
            }
        },
        "refreshAttrsTable": {
            "actionType": "dataProvider",
            "method": "contentsTableProvider"
        },
        "changeSelection": {
            "actionType": "JSFunction",
            "method": "changeSelection",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/Crt1SelectionService"
        },
        "clearContentsTableProvider": {
            "actionType": "JSFunction",
            "method": "clearContentsTableProvider",
            "inputData": {
                "dataProvider": "{{data.dataProviders.contentsTableProvider}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "clearContentsTableProviderfromTreeTable": {
            "actionType": "JSFunction",
            "method": "clearContentsTableProviderfromTreeTable",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registerTrAndSrProviders": {
            "actionType": "JSFunction",
            "method": "registerTrAndSrProviders",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registerEventProvider": {
            "actionType": "JSFunction",
            "method": "registerEventProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registerTMProvider": {
            "actionType": "JSFunction",
            "method": "registerTMProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registerTPProvider": {
            "actionType": "JSFunction",
            "method": "registerTPProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registertestAndProdBOMTableProvider": {
            "actionType": "JSFunction",
            "method": "registertestAndProdBOMTableProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registertestEBOMTableProvider": {
            "actionType": "JSFunction",
            "method": "registertestEBOMTableProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "registershowAttrProxyTableProvider": {
            "actionType": "JSFunction",
            "method": "registershowAttrProxyTableProvider",
            "inputData": {
                "data":"{{data}}"
            },
            "deps": "js/analysisRequestUtils"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",

            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "Att1ContentsAttrTable"
                },
                "saveColumnConfigData": {
                    "clientScopeURI": "Att1ContentsAttrTable",
                    "columnConfigId": "{{data.dataProviders.contentsTableProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.contentsTableProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },
                "searchInput": {
                    "maxToLoad": 10,
                    "maxToReturn": 10,
                    "providerName": "Crt1AnalysisRequestInProvider",
                    "searchCriteria": {
                        "parentUid": "{{ctx.selected.uid}}",
                        "dcpSortByDataProvider": "true"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.contentsTableColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.contentsTableProvider.startIndex}}",
                    "columnFilters": "{{data.columnProviders.contentsTableColumnProvider.columnFilters}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.contentsTableProvider.columnConfig": "columnConfig"
            },
            "deps": "js/analysisRequestUtils"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2017-06-UiConfig",
            "method": "getOrResetUIColumnConfigs2",
            "inputData": {
                "getOrResetUiConfigsIn": [
                    {
                        "scope": "LoginUser",
                        "scopeName": "",
                        "clientName": "AWClient",
                        "resetColumnConfig": true,
                        "columnConfigQueryInfos": [
                            {
                                "clientScopeURI": "Att1ContentsAttrTable",
                                "operationType": "configured",
                                "typeNames": [
                                    "WorkspaceObject"
                                ],
                                "columnsToExclude": []
                            }
                        ],
                        "businessObjects": [
                            {}
                        ]
                    }
                ]
            },
            "outputData": {
                "dataProviders.contentsTableProvider.resetColumnConfigs": "columnConfigurations"
            },
            "deps": "js/analysisRequestUtils"
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "Att1ContentsAttrTable",
                    "operationType": "as_configured"
                },
                "searchInput": {
                    "maxToLoad": 10,
                    "maxToReturn": 10,
                    "providerName": "Crt1AnalysisRequestInProvider",
                    "searchCriteria": {
                        "parentUid": "{{ctx.xrtSummaryContextObject.uid}}",
                        "dcpSortByDataProvider": "true",
                        "excludeTypeFilter":"{{function:getExcludeTypeFilter}}"
                    },
                    "searchFilterFieldSortType": "Alphabetical",
                    "searchSortCriteria": "{{data.columnProviders.contentsTableColumnProvider.sortCriteria}}",
                    "startIndex": "{{data.dataProviders.contentsTableProvider.startIndex}}",
                    "columnFilters": "{{function:getColumnFilters1}}"
                },
                "inflateProperties": true
            },
            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "ctx.search.contentChartData":"additionalSearchInfoMap.searchTermsToHighlight",
                "dataProviders.contentsTableProvider.columnConfig": "columnConfig"
            },
            "events": {
                "success": [
                 {
                    "condition": "!ctx.filtering",
                    "name": "Crt1ChartForContentsViewModel.createChart"
                 },
                 {
                    "name": "Crt1ContentsTable.clearProviderSelection"
                 }

             ]
            },
            "deps": "js/analysisRequestUtils"
        },
        "unregisterCtx":{
            "actionType": "JSFunction",
            "method": "unRegisterVRTableSelection",
            "deps": "js/addRemoveFromAR"
        }
    },
    "functions": {
        "getColumnFilters1": {
            "functionName": "getColumnFilters1",
            "parameters": [
                "{{data}}"
            ]
        },
        "getExcludeTypeFilter": {
            "functionName": "getExcludeTypeFilter",
            "parameters": [
                "{{ctx}}"
            ]
        }
    },
    "columnProviders": {
        "contentsTableColumnProvider": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": []
        }
    },
    "dataProviders": {
        "contentsTableProvider": {
            "action": "loadData",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "multiple",
            "commandsAnchor": "Open_Content_command"
        }
    },
    "grids": {
        "contentsTable": {
            "columnProvider": "contentsTableColumnProvider",
            "dataProvider": "contentsTableProvider",
            "enableArrangeMenu": true,
            "gridOptions": {
                "enableSorting": true,
                "maxRowsToShow": 6,
                "isFilteringEnabled": true
            }
        }
    },

    "onEvent": [
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        },
        {
            "eventId": "Crt1ContentsTable.refreshTable",
            "cacheEventData": true,
            "action": "refreshAttrsTable"
        },
        {
            "eventId": "contentsTableProvider.modelObjectsUpdated",
            "cacheEventData": true,
            "action": "addEventDataToNativeData"
        },
        {
            "eventId": "editHandlerStateChange",
            "cacheEventData": true,
            "action": "editEventAction"
        },
        {
            "eventId": "ObjectSet_2_Provider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registerTrAndSrProviders"
        },
        {
            "eventId": "ObjectSet_1_Provider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registerEventProvider"
        },
        {
            "eventId": "contentsTMTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registerTMProvider"
        },
        {
            "eventId": "contentsTPTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registerTPProvider"
        },
        {
            "eventId": "appCtx.register",
            "cacheEventData": true,
            "condition": "(name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1) ) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('Crt0RunRevision') > -1) || (name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1) ) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('Crt0StudyRevision') > -1) || (name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1) ) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('IAV0TestRunRevision') > -1) || (name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1) ) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('IAV0TestStudyRevision') > -1) ||(name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1)) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && ctx.xrtSummaryContextObject && ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('Crt0VldnContractRevision') > -1 && !(ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('IAV0TestStudyRevision') > -1))",
            "action": "clearContentsTableProvider"
        },
        {
            "eventId": "appCtx.register",
            "cacheEventData": true,
            "condition": "(name === 'selected' && (!(value.props.crt1AddedToAnalysisRequest) && value.type !== 'Crt1VRContentProxy' && !(value.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1) )) || (name === 'selected' && (value.modelType.typeHierarchyArray.indexOf( 'Arm0RequirementElement' ) > -1 || value.modelType.typeHierarchyArray.indexOf( 'Arm0RequirementSpecElement' ) > -1 || value.modelType.typeHierarchyArray.indexOf( 'Arm0ParagraphElement' ) > -1 || value.modelType.typeHierarchyArray.indexOf( 'Awb0PartElement' ) > -1 || value.modelType.typeHierarchyArray.indexOf( 'Sam1AsMaintainedElement' ) > -1) && !(value.modelType.typeHierarchyArray.indexOf( 'IAV1VerifReqmtElement' ) > -1) && ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Overview' && (ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('IAV0TestStudyRevision') > -1 || ctx.xrtSummaryContextObject.modelType.typeHierarchyArray.indexOf('IAV0TestRunRevision') > -1))",
            "action": "clearContentsTableProviderfromTreeTable"
        },
        {
            "eventId": "contentsTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "changeSelection"
        },
        {
            "eventId": "testAndProdBOMTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registertestAndProdBOMTableProvider"
        },
        {
            "eventId": "testEBOMTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registertestEBOMTableProvider"
        },
        {
            "eventId": "showAttrProxyTableProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "registershowAttrProxyTableProvider"
        },
        {
            "eventId": "Crt1ContentsTable.contentUnloaded",
            "cacheEventData": true,
            "action": "unregisterCtx"
        },
        {
            "eventId": "Crt1ContentsTable.clearProviderSelection",
            "cacheEventData": true,
            "action":"clearProviderSelection"
        }
    ],

    "i18n": {
        "noContentsToDisplayChart": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "NoResult": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "Fail": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "Pass": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "Contents": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "Parameters": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "Output": [
            "AnalysisRequestCommandPanelsMessages"
        ],
        "output": [
            "AnalysisRequestCommandPanelsMessages"
        ]
    }
}
