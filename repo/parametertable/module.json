      "type": "location",
      "params": {
        "uid": null,
        "cols": null,
        "filters": null,
        "sort": null
      }
    },
    "prm1RevisionRuleCompare": {
      "data": {
        "priority": 0,
        "label": {
          "source": "/i18n/prm1ParameterTableMessages",
          "key": "RevisionRuleCompareTitle"
        },
        "clientScopeURI": "Awp0ShowObject",
        "breadcrumbConfig": {
          "type": "TODO"
        },
        "nameToken": "prm1RevisionRuleCompare",
        "viewModes": {
          "TableView": {
            "primaryWorkArea": "table",
            "secondaryWorkArea": false
          },
          "TableSummaryView": {
            "primaryWorkArea": "table",
            "secondaryWorkArea": true
          }
        },
        "defaultDisplayMode": "TableView",
        "useDeclarativeSummary": true,
        "propertyPolicy": "/policies/ParameterComparisonViewPropertyPolicy.json"
      },
      "params": {
        "sel_uids": null,
        "rv_uids": null,
        "vrs_uids": null,
        "rcp_uids": null,
        "pc_type": null,
        "l_title": null
      },
      "parent": "ParameterComparisonView",
      "type": "subLocation",
      "url": "/ParameterComparison"
    }
  },
