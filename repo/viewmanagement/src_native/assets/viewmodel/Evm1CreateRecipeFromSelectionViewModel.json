{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-xrt.directive",
        "js/aw-checkbox.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-i18n.directive"
    ],
    "data": {
        "openOnCreate": {
            "displayName": "{{i18n.addAndOpen}}",
            "type": "STRING",
            "isRequired": "false",
            "isEditable": "true",
            "dbValue": true,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        },
        "effectivityUnitSectionAllUnitsValue": {
            "uiValue": "{{i18n.effectivityUnitSectionAllUnitsValue}}",
            "displayName": "{{i18n.effectivityUnitSectionAllUnitsValue}}",
            "dbValue": "-1",
            "type": "STRING"
        },
        "occurrenceManagementTodayTitle": {
            "uiValue": "{{i18n.occurrenceManagementTodayTitle}}",
            "displayName": "{{i18n.occurrenceManagementTodayTitle}}",
            "type": "STRING"
        },
        "defaultVariantRule": {
            "displayName": "{{i18n.variantSectionSavedVariantsValue}}",
            "uiValue": "{{i18n.variantSectionSavedVariantsValue}}",
            "type": "STRING"
        }
    },
    "actions": {
        "initiateSelection": {
            "actionType": "JSFunction",
            "method": "navigateAndCreateInput",
            "inputData": {
                "data": "{{data}}"
            },

            "deps": "js/Evm1CreateRecipeFromSelection"
        },
        "reveal": {
            "actionType": "JSFunction",
            "method": "initNavigateFunction",
            "inputData": {
                "declViewModel": "{{data}}"
            },

            "deps": "js/Evm1CreateRecipeFromSelection"
        },
        "createRecipeWithBOMAction": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-ViewMgmtAW-2019-12-ViewDataManagement",
            "method": "manageRecipes3",
            "inputData": {
                "inputs": "{{function:ManageRecipesInput}}"
            },
            "policy": {
                "types": [ {
                    "name": "BusinessObject",
                    "properties": [ {
                        "name": "awp0CellProperties"
                    } ]
                } ]
            },
            "outputData": {
                "response": "{{function:ManageRecipesResponse}}"
            },
            "events": {
                "success": [ {
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                } ],
                "failure": [ {
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                } ]
            },
            "deps": "js/Evm1CreateRecipeFromSelection"
        },
        "openRecipe": {
            "actionType": "Navigate",
            "navigateTo": "com_siemens_splm_clientfx_tcui_xrt_showObject",
            "navigationParams": {
                "uid": "{{data.createdObject.uid}}"
            }
        }
    },
    "functions": {
        "ManageRecipesInput": {
            "functionName": "ManageRecipesInput",
            "parameters": [
                "{{data}}"
            ]
        },
        "ManageRecipesResponse": {
            "functionName": "ManageRecipesResponse",
            "parameters": [
                "{{data}}"
            ]
        }
    },
    "onEvent": [ {
            "eventId": "evm1OpenCreatedRecipe",
            "action": "openRecipe",
            "cacheEventData": true
        },
        {
            "eventId": "awTypeSelector.selectionChangeEvent",
            "cacheEventData": true,
            "action": "initiateSelection"
        },
        {
            "eventId": "getRecentTypesProvider.selectionChangeEvent",
            "cacheEventData": true,
            "action": "initiateSelection"
        },
        {
            "eventId": "awPanel.reveal",
            "criteria": {
                "panelId": "Evm1CreateRecipeFromSelection"
            },
            "action": "reveal"
        }
    ],
    "i18n": {
        "addAndOpen": [
            "RecipeCommandPanelsMessages"
        ],
        "Create": [
            "RecipeCommandPanelsMessages"
        ],
        "CreateRecipe": [
            "RecipeCommandPanelsMessages"
        ],
        "effectivityUnitSectionAllUnitsValue": [
            "RecipeCommandPanelsMessages"
        ],
        "occurrenceManagementTodayTitle": [
            "RecipeCommandPanelsMessages"
        ],
        "variantSectionSavedVariantsValue": [
            "RecipeCommandPanelsMessages"
        ]
    }
}
