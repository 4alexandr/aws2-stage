{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-tab-set.directive"
    ],

    "actions": {
        "clearVariantInfoSection": {
            "actionType": "dataProvider",
            "method": "clearVariantInfo"
        },

        "clearVariantInfo": {
            "actionType": "JSFunction",
            "method": "clearVariantConfigurationData",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/Evm1ConfigurationPanelService"
        }
    },

    "onEvent": [ {
        "eventId": "awPanel.navigate",
        "action": "clearVariantInfoSection",
        "criteria": {
            "destPanelId": "ConfigurationPanelFilters"
        }
    } ],

    "dataProviders": {
        "clearVariantInfo": {
            "action": "clearVariantInfo"
        }
    },

    "data": {
        "svrOwningItemTabsModel": {
            "isArray": "true",
            "dbValue": [ {
                    "panelId": "Evm1SVROwningElementPaletteTab",
                    "name": "{{i18n.paletteEndItemPresenterBtn}}",
                    "recreatePanel": true,
                    "selectedTab": true
                },
                {
                    "panelId": "Evm1SVROwningElementSearchTab",
                    "name": "{{i18n.searchEndItemPresenterBtn}}",
                    "recreatePanel": true
                }
            ]
        }
    },

    "i18n": {
        "paletteEndItemPresenterBtn": [ "RecipeCommandPanelsMessages" ],
        "searchEndItemPresenterBtn": [ "RecipeCommandPanelsMessages" ],
        "configPanelSavedVariantForSectionTitle": [ "RecipeCommandPanelsMessages" ]
    }
}
