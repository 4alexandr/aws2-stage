      "Evm1CreateRecipeDesc": [
        "RecipeCommandPanelsMessages"
      ],
      "Evm1ExecuteRecipeDesc": [
        "RecipeCommandPanelsMessages"
      ],
      "Evm1ShowRecipeDesc": [
        "RecipeCommandPanelsMessages"
      ],
      "recipeTableView": [
        "RecipeCommandPanelsMessages"
      ]
    }
  },
  "propertyRendererTemplates": {
    "include_toggle_template": {
      "grids": [
        "seedTreeGrid"
      ],
      "columns": [
        "evm1Include"
      ],
      "tooltip": [],
      "template": "",
      "templateUrl": "",
      "renderFunction": "propertyRendererFunc",
      "headerTemplateUrl": "",
      "deps": "js/Evm1PropertyRenderer",
      "dependentServices": []
    }
  },
  "saveHandlers": [
    {
      "conditions": {
        "$and": [
          {
            "selected.modelType.typeHierarchyArray": {
              "$in": [
                "Fnd0SearchRecipe"
              ]
            }
          },
          {
            "xrtSummaryContextObject.type": {
              "$eq": [
                "Fnd0SearchRecipe"
              ]
            }
          },
          {
            "recipeCtx.hasViewManagementLicense": {
              "$eq": true
            }
          }
        ]
      },
      "target": {
        "method": "getSaveHandler",
        "deps": "js/Evm1EditHandlerService"
      }
    }
  ],
  "typeIconsRegistry": [
    {
      "type": {
        "names": [
          "Evm1RecipeResultProxy"
        ],
        "prop": {
          "names": [
            "evm1UnderlyingObject"
          ],
          "type": {
            "names": [
              "BusinessObject"
            ]
          }
        }
      }
    }
  ]
