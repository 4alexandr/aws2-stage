{
    "schemaVersion" : "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-panel-body.directive",
        "js/aw-panel-section.directive",
        "js/aw-panel-footer.directive",
        "js/aw-button.directive",
        "js/aw-widget.directive",
        "js/aw-i18n.directive",
        "js/visible-when.directive",
        "js/aw-checkbox.directive"
    ],
    "data": {
        "object_name":
        {
            "displayName": "{{i18n.name}}",
            "type": "STRING",
            "isRequired": "true",
            "dbValue": ""
        },
        "object_desc":
        {
            "displayName": "{{i18n.Description}}",
            "type": "STRING",
            "dbValue": ""
        },
        "shiftDate":
        {
            "displayName": "{{i18n.shiftDate}}",
            "type": "DATE",
            "dbValue": "",
            "labelPosition": "PROPERTY_LABEL_AT_TOP"
        },
        "isRunAsync":
        {
            "displayName": "{{i18n.isRunAsync}}",
            "dbValue" : false,
            "labelPosition" : "PROPERTY_LABEL_AT_RIGHT"
        }
    },
    "actions": {
        "saveAs": {
            "actionType": "TcSoaService",
            "serviceName": "ProjectManagement-2011-06-ScheduleManagement",
            "method": "copySchedules",
            "inputData": {
                "containers": [
                    {
                        "name": "{{data.object_name.dbValue}}",
                        "description": "{{data.object_desc.dbValue}}",
                        "scheduleToCopy": "{{ctx.selected}}",
                        "options": {
                            "logicalOptions": [
                                {
                                    "name": "showAlert",
                                    "value": true
                                },
                                {
                                    "name": "relateToNewStuff",
                                    "value": true
                                },
                                {
                                    "name": "resetWork",
                                    "value": true
                                }
                            ],
                            "integerOptions": [],
                            "stringOptions": []
                        },
                        "stringValueContainer": [
                            {
                                "key": "is_template",
                                "value": "false",
                                "type": 5
                            },
                            {
                                "key": "fnd0ShiftDate",
                                "value": "{{function:getShiftDate}}",
                                "type": 1
                            }
                        ],
                        "typedAttributesContainer": [
                            {
                                "type": "ScheduleType",
                                "attributes": []
                            }
                        ]
                    }
                ]
            },
            "deps": "js/Saw1CreateScheduleFromTemplateService",
            "events": {
                "success": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    },
                    {
                        "name": "primaryWorkarea.reset"
                    },
                    {
                        "name": "cdm.relatedModified",
                        "condition": "ctx.pselected",
                        "eventData":
                        {
                            "relatedModified": [
                                "{{ctx.pselected}}"
                            ]
                        }
                   }
                ]
            },
            "actionMessages": {
                "failure": [
                    {
                        "message": "soaFailureMessage"
                    }
                ]
            }
        },
        "saveAsAsync": {
            "actionType": "TcSoaService",
            "serviceName": "ProjectManagement-2011-06-ScheduleManagement",
            "method": "copySchedulesAsyncClient",
            "inputData": {
                "schToCopy": [
                    {
                        "name": "{{data.object_name.dbValue}}",
                        "description": "{{data.object_desc.dbValue}}",
                        "scheduleToCopy": "{{ctx.selected}}",
                        "options": {
                            "logicalOptions": [
                                {
                                    "name": "showAlert",
                                    "value": true
                                },
                                {
                                    "name": "relateToNewStuff",
                                    "value": true
                                },
                                {
                                    "name": "resetWork",
                                    "value": true
                                }
                            ],
                            "integerOptions": [],
                            "stringOptions": []
                        },
                        "stringValueContainer": [
                            {
                                "key": "is_template",
                                "value": "false",
                                "type": 5
                            },
                            {
                                "key": "fnd0ShiftDate",
                                "value": "{{function:getShiftDate}}",
                                "type": 1
                            }
                        ],
                        "typedAttributesContainer": [
                            {
                                "type": "ScheduleType",
                                "attributes": []
                            }
                        ]
                    }
                ]
            },
            "deps": "js/Saw1CreateScheduleFromTemplateService",
            "events": {
                "success": [
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }
                ]
            },
            "actionMessages": {
                "failure": [
                    {
                        "message": "soaFailureMessage"
                    }
                ]
            }
        },
        "populateDefaultValuesForSaveAs":{
            "actionType": "JSFunction",
            "method": "populateDefaultValuesForSaveAs",
            "inputData":
            {
                "data":"{{data}}"
            },
            "deps": "js/Saw1CreateScheduleFromTemplateService"
        }
    },
    "preferences": [
        "SM_TEMPLATE_DATE",
        "SM_Copy_Schedule_Async"
    ],
    "functions": {
        "getShiftDate": {
            "functionName": "getShiftDate",
            "parameters": [
                "{{data.shiftDate.dateApi.dateObject}}"
            ]
        }
    },
    "conditions": {
        "isValidToShowSaveButton": {
            "expression": "data.object_name.dbValue && data.object_name.dbValue!=''"
        }
    },
    "onEvent": [
        {
            "eventId": "awPanel.reveal",
            "action": "populateDefaultValuesForSaveAs"
        },
        {
            "eventId": "primaryWorkArea.selectionChangeEvent",
            "action": "populateDefaultValuesForSaveAs"
        }
    ],
    "messages":{
        "soaFailureMessage": {
           "messageType": "ERROR",
           "messageText": "{{errorCode}}"
        }
    },
    "i18n": {
        "name": [
            "ScheduleManagerMessages",
            "BaseMessage"
        ],
        "Description": [
            "ScheduleManagerMessages"
        ],
        "saveBtnTitle": [
            "ScheduleManagerMessages"
        ],
        "shiftDate": [
            "ScheduleManagerMessages"
        ],
        "isRunAsync": [
            "ScheduleManagerMessages"
        ],
        "Saw1SaveAsCmdTitle": [
            "ScheduleManagerMessages"
        ]
    }
}
