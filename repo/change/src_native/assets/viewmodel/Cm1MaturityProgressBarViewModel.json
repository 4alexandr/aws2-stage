{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-step-progress.directive",
        "js/aw-label.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "maturityPropLoad",
            "deps": "js/Cm1MaturityProgressBarService"
        },
        "setProgressBar": {
            "actionType": "JSFunction",
            "method": "setMaturityValues",
            "inputData": {
                "data": "{{data}}",
                "filterData": {
                    "filterString": "",
                    "maxResults": 0,
                    "numberToReturn": 25,
                    "order": 1,
                    "sortPropertyName": ""
                },
                "lov": {
                    "uid": "",
                    "type": ""
                },
                "lovInput": {
                    "boName": "{{ctx.mselected[0].type}}",
                    "operationName": "ShowProgress",
                    "owningObject": {
                        "type": "{{ctx.mselected[0].type}}",
                        "uid": "{{ctx.mselected[0].uid}}"
                    },
                    "propertyValues": {}
                },
                "propertyName": "CMMaturity"
            },
            "deps": "js/Cm1MaturityProgressBarService"
        }
    },
    "data": {
        "labeProp": {
            "displayName": "{{ctx.mselected[0].modelType.propertyDescriptorsMap.CMMaturity.displayName}}",
            "dbValue": "{{ctx.mselected[0].modelType.propertyDescriptorsMap.CMMaturity.displayName}}"
        },
        "currentStep": {
            "displayName": "Elaborating",
            "type": "STRING",
            "dispValue": "Elaborating"
        }
    },
    "onEvent": [
        {
            "eventId":"Cm1MaturityProgressBar.contentLoaded",
            "action": "setProgressBar"
        }
    ]
}
