{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-command-panel.directive",
        "js/aw-command-sub-panel.directive"
    ],
    "actions": {
        "reveal": {
            "actionType": "JSFunction",
            "method": "populateReportsContext",
            "inputData": {
                "data": "{{data}}"
            },
            "deps": "js/configureReportService"
        },
        "setPin": {
            "actionType": "JSFunction",
            "method": "setPinnedToForm",
            "inputData": {
                "pinnedToForm": "{{data.pinnedToForm}}",
                "unpinnedToForm": "{{data.unpinnedToForm}}"
            },

            "outputData": {

            },

            "deps": "js/configureReportService"
        },

        "setUnPin": {
            "actionType": "JSFunction",
            "method": "setUnPinnedToForm",
            "inputData": {
                "pinnedToForm": "{{data.pinnedToForm}}",
                "unpinnedToForm": "{{data.unpinnedToForm}}"
            },

            "outputData": {

            },

            "deps": "js/configureReportService"
        }
    },

    "data": {
        "configureReportPanelPinCommands": "configureReportPanel_oneStepPinCommands",

        "pinnedToForm": {
            "type": "BOOLEAN",
            "dbValue": true
        },

        "unpinnedToForm": {
            "type": "BOOLEAN",
            "dbValue": false
        },

        "colorInternalNameList": [
            "#000000",
            "#1E1E1E",
            "#787878",
            "#BEBEBE",
            "#005F87",
            "#50BED7",
            "#EB780A",
            "#FFB900"
        ],
        "fontInternalNameList": [
            "Segoe UI",
            "Arial",
            "Arial Black",
            "Courier New",
            "Helvetica",
            "Helvetica Neue",
            "Georgia",
            "Lucida Sans Unicode",
            "Tahoma",
            "Times New Roman",
            "Trebuchet MS",
            "Verdana"
        ]
    },

    "onEvent": [ {
            "eventId": "configureReportPanelCommand.configureReportPanelSetPin",
            "action": "setPin"
        },
        {
            "eventId": "configureReportPanelCommand.configureReportPanelSetUnPin",
            "action": "setUnPin"
        }

    ],

    "preferences": [
        "WORKSPACEOBJECT_object_columns_shown",
        "WORKSPACEOBJECT_object_columns_hidden",
        "REPORT_AW_ObjectType_Properties"
    ],

    "i18n": {
        "objectStrColumnName": ["ReportChartStrings"],
        "SegoeUI":[ "ReportChartStrings" ],
        "Arial": [ "ReportChartStrings" ],
        "ArialBlack": [ "ReportChartStrings" ],
        "CourierNew": [ "ReportChartStrings" ],
        "Helvetica": [ "ReportChartStrings" ],
        "HelveticaNeue": [ "ReportChartStrings" ],
        "Georgia": [ "ReportChartStrings" ],
        "LucidaSansUnicode": [ "ReportChartStrings" ],
        "Tahoma": [ "ReportChartStrings" ],
        "TimesNewRoman": [ "ReportChartStrings" ],
        "TrebuchetMS": [ "ReportChartStrings" ],
        "Verdana": [ "ReportChartStrings" ],
        "Column": [ "ReportChartStrings" ],
        "Line": [ "ReportChartStrings" ],
        "Pie": [ "ReportChartStrings" ],
        "configurePanelTitle": [
            "ReportChartStrings"
        ],
        "Black": [
            "ReportChartStrings"
        ],
        "DarkGray": [
            "ReportChartStrings"
        ],
        "Gray": [
            "ReportChartStrings"
        ],
        "LightGray": [
            "ReportChartStrings"
        ],
        "Blue": [
            "ReportChartStrings"
        ],
        "LightBlue": [
            "ReportChartStrings"
        ],
        "Orange": [
            "ReportChartStrings"
        ],
        "Yellow": [
            "ReportChartStrings"
        ],
        "editReportTitle": [
            "ReportChartStrings"
        ]
    }

}
