    "conditions": {
      "shouldShowChartReportCommand": {
        "expression": "commandContext.vmo.type === 'ReportDefinition' && commandContext.vmo.props.rd_type.dbValues[0] === '4'"
      },
      "shouldShowSummCustomReportCommand": {
        "expression": "commandContext.vmo.type === 'ReportDefinition' && (commandContext.vmo.props.rd_type.dbValues[0] === '2' || commandContext.vmo.props.rd_type.dbValues[0] === '0')"
      },
      "isTCVersion116OrLaterInReports": {
        "expression": "(ctx.tcSessionData.tcMajorVersion > 11  || (ctx.tcSessionData.tcMajorVersion === 11 && (ctx.tcSessionData.tcMinorVersion >= 2 && ctx.tcSessionData.tcQRMNumber >= 7)))"
      },
      "isTCVersion121": {
        "expression": "(ctx.tcSessionData.tcMajorVersion === 12 && ctx.tcSessionData.tcMinorVersion ===1 && ctx.tcSessionData.tcQRMNumber === 0)"
      },
      "isSelectedObjectPOMObject": {
        "expression": "ctx.selected && ctx.sublocation.clientScopeURI !== 'Fnd0Report' && (ctx.selected.modelType.typeHierarchyArray.indexOf( 'POM_object' ) > -1) && ctx.selected.type !== 'ReportDefinition'"
      },
      "singleObjSelectPrefValueFalse": {
        "expression": "ctx.selected && ctx.mselected.length === 1 && data.preferences.REPORT_AW_Show_GenerateReport_Command_for_Multiselect[0] === 'false'"
      },
      "multipleObjSelectPrefValueTrue": {
        "expression": "ctx.selected && ctx.mselected.length >= 1 && data.preferences.REPORT_AW_Show_GenerateReport_Command_for_Multiselect[0] === 'true'"
      },
      "showGenerateReportCommand": {
        "expression": "((conditions.isSelectedObjectWSO) || ((conditions.isTCVersion116OrLaterInReports || conditions.isTCVersion121) && conditions.isSelectedObjectPOMObject)) && ( conditions.singleObjSelectPrefValueFalse || conditions.multipleObjSelectPrefValueTrue)"
      },
      "isSelectedObjectWSO": {
        "expression": "ctx.selected && ctx.sublocation.clientScopeURI !== 'Fnd0Report' && (ctx.selected.modelType.typeHierarchyArray.indexOf( 'WorkspaceObject' ) > -1 || ctx.selected.modelType.typeHierarchyArray.indexOf( 'Awb0Element' ) > -1)"
      },
      "isSelectedReportObject": {
        "expression": "ctx.selected.type === 'ReportDefinition' && ctx.selected.props.rd_source.dbValues[0] !== 'TcRA' && ctx.selected.props.rd_type.dbValues[0] !== '4'"
      },
      "isGenerateReportPanelPanelPinned": {
        "expression": "commandContext.pinnedToForm.dbValue"
      },
      "isGenerateReportPanelPanelUnPinned": {
        "expression": "commandContext.unpinnedToForm.dbValue"
      },
      "Rb0IsCommandRequiredInMyReportsLocation": {
        "expression": "(ctx.selected.type === 'CrfOutputHtml' || ctx.selected.type === 'CrfOutputExcel' || ctx.selected.type === 'CrfOutputText' || ctx.selected.type === 'CrfOutputXml')"
      },
      "Rb0IsCommandRequiredInTemplatesLocation": {
        "expression": "ctx.sublocation.nameToken === 'com.siemens.splm.reports:showReportBuilderReports'"
      },
      "hideNotApplicableReportsCommand": {
        "expression": "ctx.mselected.length >= 1 && ctx.mselected[0].modelType !== null && ctx.selected.type === 'ReportDefinition'"
      },
      "isReportDeleteAllowed": {
        "expression": "(ctx.selected.type === 'ReportDefinition') && ((ctx.selected.props.owning_user.dbValues[0] === ctx.userSession.props.user.dbValues[0])||(ctx.userSession.props.group.displayValues[0] === 'dba')) && (ctx.mselected.length === 1) && (ctx.sublocation.nameToken === 'com.siemens.splm.reports:showReportBuilderReports')"
      },
      "Rb0IsInsideTemplateWithNoSelection": {
        "expression": "ctx.mselected.length === 0 && ctx.sublocation.clientScopeURI === 'Awp0ReportBuilder' && ctx.locationContext['ActiveWorkspace:SubLocation'] !== 'showReport'"
      },
      "Rb0IsConfiguringReport": {
        "expression": "ctx.sublocation.nameToken === 'showReport' && ctx.selected === null && ctx.state.params.referenceId === 'new'"
      },
      "Rb0IsConfigureReportPanelPinned": {
        "expression": "commandContext.pinnedToForm.dbValue"
      },
      "Rb0IsConfigureReportPanelUnPinned": {
        "expression": "commandContext.unpinnedToForm.dbValue"
      },
      "AddChartsCondition": {
        "expression": "!(ctx.ReportsContext.reportParameters.ChartVisibility.chart1Visible && ctx.ReportsContext.reportParameters.ChartVisibility.chart2Visible && ctx.ReportsContext.reportParameters.ChartVisibility.chart3Visible)"
      },
      "Chart1AddCondition": {
        "expression": "commandContext.addChart1.dbValue"
      },
      "Chart1RemoveCondition": {
        "expression": "commandContext.removeChart1.dbValue"
      },
      "Chart2AddCondition": {
        "expression": "commandContext.addChart2.dbValue"
      },
      "Chart2RemoveCondition": {
        "expression": "commandContext.removeChart2.dbValue"
      },
      "Chart3AddCondition": {
        "expression": "commandContext.addChart3.dbValue"
      },
      "Chart3RemoveCondition": {
        "expression": "commandContext.removeChart3.dbValue"
      },
      "isItAdvanceChartReport": {
        "expression": "ctx.selected.type === 'ReportDefinition' && ctx.selected.props.rd_source.dbValues[0] !== 'TcRA' && ctx.selected.props.rd_type.dbValues[0] === '4'"
      },
      "isReportPinnable": {
        "expression": "ctx.visibleServerCommands.Awp0PinObject && conditions.isItAdvanceChartReport"
      },
      "shouldShowPinCommand": {
        "expression": "ctx.selected.type === 'ReportDefinition' && ctx.selected.props.rd_source.dbValues[0] === 'TcRA' && ctx.selected.props.rd_type.dbValues[0] !== '4'"
      },
      "isReportUnPinnable": {
        "expression": "ctx.visibleServerCommands.Awp0UnPinObject && conditions.isItAdvanceChartReport"
      },
      "isReportEditAllowed": {
        "expression": "(conditions.isItAdvanceChartReport && (ctx.selected.props.owning_user.dbValues[0] === ctx.userSession.props.user.dbValues[0])) || (ctx.sublocation.nameToken === 'showReport' && ctx.ReportsContext.selected.props.owning_user.dbValues[0] === ctx.userSession.props.user.dbValues[0] && ctx.state.params.referenceId === 'edit')"
      },
      "hideStartEditCommand": {
        "expression": "conditions.isStartEditAllowed && (ctx.sublocation.nameToken === 'showReport' || ctx.sublocation.nameToken === 'com.siemens.splm.reports:showMyDashboard')"
      },
      "hideCommandInMyDashboard": {
        "expression": "(ctx.selected.type === 'ReportDefinition' || ctx.pselected.type === 'ReportDefinition') && ctx.sublocation.nameToken === 'com.siemens.splm.reports:showMyDashboard'"
      },
      "shouldRemoveDashboardReport": {
        "expression": "(((ctx.selected.type === 'ReportDefinition') || (ctx.sublocation.nameToken === 'showReport')) && ((ctx.ReportsPersistCtx.MyDashboardReportList.indexOf(ctx.state.params.reportId) > -1) || (ctx.ReportsPersistCtx.MyDashboardReportList.indexOf(ctx.selected.props.rd_id.dbValues[0]) > -1)))"
      },
      "shouldAddDashboardReport": {
        "expression": "(ctx.selected.type === 'ReportDefinition' && ctx.selected.props.rd_type.dbValues[0] === '4' && (ctx.ReportsPersistCtx.MyDashboardReportList === [] || ctx.ReportsPersistCtx.MyDashboardReportList.indexOf(ctx.selected.props.rd_id.dbValues[0]) === -1)) || (ctx.sublocation.nameToken === 'showReport' && (ctx.ReportsPersistCtx.MyDashboardReportList === [] || ctx.ReportsPersistCtx.MyDashboardReportList.indexOf(ctx.state.params.reportId) === -1))"
      }
    },
    "preferences": [
      "REPORT_AW_Show_GenerateReport_Command_for_Multiselect"
    ],
