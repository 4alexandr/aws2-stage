    "conditions": {
      "checkEditModeIsOnForInterfaceTable": {
        "expression": "ctx.isInterfaceTableEditing"
      },
      "checkEditModeIsOffForInterfaceTableAndModifiable": {
        "expression": "ctx.isInterfaceTableEditing == false && ctx.isInterfaceTableEditable && conditions.hasSystemModelerLicense"
      },
      "checkEditModeIsOnForInteractionTable": {
        "expression": "ctx.isInteractionTableEditing"
      },
      "checkEditModeIsOffForInteractionTableAndModifiable": {
        "expression": "ctx.interfaceDetails.totalInteractionsFound > 0 && ctx.isInteractionTableEditing == false && ctx.isInteractionTableEditable && ctx.isAttributeTableEditing == false && !ctx.isMappingTableEditing && conditions.hasSystemModelerLicense"
      },
      "checkAddInterfaceDefinitionCommandCond": {
        "expression": "!ctx.isInterfaceTableEditing && ctx.visibleServerCommands.Ase1AddInterfaceDefinition && conditions.hasSystemModelerLicense"
      },
      "checkRemoveInterfaceDefinitionCommandCond": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf('Seg0IntfSpecRevision') > -1 && conditions.hasSystemModelerLicense"
      },
      "checkEditModeIsOffForAttributeTableAndModifiable": {
        "expression": "ctx.isAttributeTableEditing == false && ctx.isAttributeTableEditable && ctx.interfaceDetails.showAttributesTable && conditions.hasSystemModelerLicense"
      },
      "checkEditModeIsOnForAttributeTable": {
        "expression": "ctx.isAttributeTableEditing"
      },
      "checkAddMeasurableAttributeCommandCond": {
        "expression": "!ctx.isAttributeTableEditing && ctx.visibleServerCommands.Ase1AddMeasurableAttribute && conditions.hasSystemModelerLicense"
      },
      "isTcReleaseAtleast114Cond": {
        "expression": "( ctx.tcSessionData.tcMajorVersion===11 && ctx.tcSessionData.tcMinorVersion===2 && ctx.tcSessionData.tcQRMNumber >= 5 ) || ( ctx.tcSessionData.tcMajorVersion > 11 ) "
      },
      "checkRemoveMeasurableAttributeCommandCond": {
        "expression": "ctx.visibleServerCommands.Ase1RemoveMeasurableAttribute && conditions.isTcReleaseAtleast114Cond && ctx.pselected && ctx.pselected.modelType.typeHierarchyArray.indexOf('Seg0IntfSpecRevision') > -1 && conditions.hasSystemModelerLicense"
      },
      "syncInteractionsCommandVisibilityCond": {
        "expression": "ctx.architectureCtx.isModelerActive && conditions.hasSystemModelerLicense && ctx.visibleServerCommands.Ase1SyncInteractionsCommand && ctx.mselected.length === 1 && ctx.architectureCtx.diagram.selection.edgeModels.length === 1 && ctx.architectureCtx.diagram.selection.edgeModels[0].modelType.typeHierarchyArray.indexOf('Awb0Connection') > -1"
      },
      "checkDeleteInteractionsCommandCond": {
        "expression": "ctx.selected.modelType.typeHierarchyArray.indexOf('Seg0Interconnection') > -1 && conditions.hasSystemModelerLicense"
      },
      "isExportInterfaceCommandVisible": {
        "expression": "ctx.visibleServerCommands.Ase1ExportInterfaceElement"
      },
      "Ase1IsInterfacesTabActive": {
        "expression": "ctx.interfacesCtx.isInterfacesActive"
      },
      "goUpButtonVisibleCond": {
        "expression": "conditions.Ase1IsInterfacesTabActive && ctx.interfacesCtx.internalSystemsExists && conditions.Ase1HasSystemModelerLicense"
      },
      "selectShowInterfacesSplitPanelBottomCond": {
        "expression": "ctx.interfacesViewModeCtx.selectedSplitPanelLocation === 'bottom'"
      },
      "selectShowInterfacesSplitPanelRightCond": {
        "expression": "ctx.interfacesViewModeCtx.selectedSplitPanelLocation === 'right'"
      },
      "focusOnSystemCommandVisibleCond": {
        "expression": "conditions.Ase1IsInterfacesTabActive && ctx.interfacesCtx.selectedNodes.length === 1 && ctx.interfacesCtx.selectedNodes[0].uid !== ctx.interfacesCtx.systemOfInterest.nodeObject.uid && conditions.Ase1HasSystemModelerLicense"
      },
      "graphViewModeActive": {
        "expression": "ctx.interfacesViewModeCtx.viewMode === 'Ase1GraphView'"
      },
      "gridViewModeActive": {
        "expression": "ctx.interfacesViewModeCtx.viewMode === 'Ase1GridView'"
      },
      "Ase1InterfacesRemoveElementCommandCond": {
        "expression": "conditions.isRemoveCommandSupported && ctx.interfacesCtx.isInterfacesActive"
      },
      "Ase1HasSystemModelerLicense": {
        "expression": "ctx.interfacesCtx.hasSystemModelerLicense"
      },
      "Ase1IsInterfacesTabActiveAndHasSystemModelerLicense": {
        "expression": "conditions.Ase1IsInterfacesTabActive && conditions.Ase1HasSystemModelerLicense"
      },
      "Ase1AddMeasurableAttrVisibility": {
        "expression": "ctx.visibleServerCommands.Att1AddMeasurableAttrFromTable  && ctx.visibleServerCommands.Att1AddMeasurableAttrFromTable === true && (((ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_AttributesForDCP' || ctx.xrtPageContext.secondaryXrtPageID === 'tc_xrt_AttributesForDCP' || ctx.xrtPageContext.primaryXrtPageID === 'tc_xrt_Attributes' || ctx.xrtPageContext.secondaryXrtPageID === 'tc_xrt_Attributes') && ((ctx.pselected && ctx.pselected.modelType.typeHierarchyArray.indexOf('Crt0VldnContractRevision') === -1) || (ctx.pselected === undefined && ctx.selected && ctx.selected.modelType.typeHierarchyArray.indexOf('Crt0VldnContractRevision') === -1))) || (ctx.Att1ShowMappedAttribute && ctx.xrtPageContext.secondaryXrtPageID === 'Ase0ArchitectureFeature' && ctx.Att1ShowMappedAttribute.parentUids.split(' ').length === 1 && (ctx.openedARObject.modelType.typeHierarchyArray.indexOf('Crt0VldnContractRevision') === -1 || ctx.openedARObject === undefined)))"
      },
      "checkAddMeasurableAttributeAtt1CommandCond": {
        "expression": "conditions.Ase1AddMeasurableAttrVisibility && conditions.isNativeArchitectureVisible && ctx.interfaceDetails.isConnectionSelected"
      },
      "Ase1CanShowInterfacesPanelCommand": {
        "expression": "conditions.is3DViewerRevealed && ctx.awDefaultViewer.isSelectionTracelinkTraversalType && ctx.mselected.length === 1"
      },
      "Ase1AddToFavoritesActiveCond": {
        "expression": "conditions.AddToFavoritesVisibility && conditions.Ase1IsInterfacesTabActive"
      },
      "Ase1RemoveFromFavoritesActiveCond": {
        "expression": "conditions.RemoveFromFavoritesVisibility && conditions.Ase1IsInterfacesTabActive"
      }
    },
