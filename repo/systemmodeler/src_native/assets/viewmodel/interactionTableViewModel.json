{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-splm-table.directive",
        "js/aw-panel-body.directive",
        "js/aw-column.directive",
        "js/aw-toolbar.directive"
    ],

    "actions": {
        "processGraphSelection": {
            "actionType": "JSFunctionAsync",
            "method": "showInteractionTable",
            "inputData": {
                "input": "{{data.dataProviders.interactionDataProvider}}"
            },

            "events": {
                "success": [ {
                    "name": "interactionTable.plTable.reload"
                } ]
            },

            "deps": "js/interactionTableService"
        },

        "updateEditStateForInteraction": {
            "actionType": "JSFunction",
            "method": "updateEditState",
            "inputData": {
                "input": "{{data.dataProviders.interactionDataProvider}}",
                "eventData": "{{data.eventData}}"
            },

            "deps": "js/interactionTableService"
        },
        "doArrangeEvent": {
            "actionType": "JSFunctionAsync",
            "method": "arrangeColumns",
            "inputData": {
                "declViewModel": "{{data}}",
                "eventData": "{{data.eventData}}"
            },
            "deps": "js/columnArrangeService"
        },
        "resetColumnConfig": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "getOrResetUiConfigsIn": [ {
                    "scope": "LoginUser",
                    "scopeName": "",
                    "clientName": "AWClient",
                    "resetColumnConfig": false,
                    "columnConfigQueryInfos": [ {
                        "clientScopeURI": "{{ctx.interfaceDetails.clientScopeURI}}",
                        "operationType": "",
                        "typeNames": [
                            "WorkspaceObject"
                        ],

                        "columnsToExclude": [

                        ]
                    } ],

                    "businessObjects": [ {

                    } ]
                } ]
            },

            "outputData": {
                "dataProviders.interactionDataProvider.columnConfig": "columnConfigurations"
            }
        },

        "doInteractionGridDataProvider": {
            "actionType": "dataProvider",
            "method": "interactionDataProvider"
        },

        "saveColumnConfigLoadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "operationType": "as_arranged",
                    "clientScopeURI": "{{ctx.interfaceDetails.clientScopeURI}}"
                },

                "saveColumnConfigData": {
                    "clientScopeURI": "{{ctx.interfaceDetails.clientScopeURI}}",
                    "columnConfigId": "{{data.dataProviders.interactionDataProvider.columnConfig.columnConfigId}}",
                    "columns": "{{data.dataProviders.interactionDataProvider.newColumns}}",
                    "scope": "LoginUser",
                    "scopeName": ""
                },

                "searchInput": {
                    "maxToLoad": 15,
                    "maxToReturn": 15,
                    "providerName": "Ase1InteractionObjProvider",
                    "searchCriteria": {
                        "connectionUid": "{{ctx.interfaceDetails.targetModelObjectUid}}"
                    },

                    "searchFilterFieldSortType": "Alphabetical",

                    "startIndex": "{{data.dataProviders.interactionDataProvider.startIndex}}"
                },

                "inflateProperties": true
            },

            "outputData": {
                "totalFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.interactionDataProvider.columnConfig": "columnConfig"
            }
        },
        "loadData": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-AWS2-2019-06-Finder",
            "method": "performSearchViewModel4",
            "inputData": {
                "columnConfigInput": {
                    "clientName": "AWClient",
                    "clientScopeURI": "{{ctx.interfaceDetails.clientScopeURI}}"
                },
                "inflateProperties": true,
                "searchInput": {
                    "maxToLoad": 15,
                    "maxToReturn": 15,
                    "providerName": "Ase1InteractionObjProvider",
                    "searchCriteria": {
                        "connectionUid": "{{ctx.interfaceDetails.targetModelObjectUid}}"
                    },

                    "searchFilterFieldSortType": "Alphabetical",

                    "searchSortCriteria": [

                    ],

                    "startIndex": 0
                }
            },
            "policy": {
                "types": [ {
                    "name": "Ase1InteractionProxy",
                    "properties": [ {
                            "name": "ase1Interaction"
                        },
                        {
                            "name": "ase1ConnectionElement"
                        }

                    ]
                } ]
            },
            "outputData": {
                "totalFound": "totalFound",
                "ctx.interfaceDetails.totalInteractionsFound": "totalFound",
                "searchResults": "{{json:searchResultsJSON}}",
                "dataProviders.interactionDataProvider.columnConfig": "columnConfig"
            }
        },

        "initialiseContext": {
            "actionType": "JSFunction",
            "method": "initialiseContext",
            "inputData": {
                "input": "{{data.dataProviders.interactionDataProvider}}"
            },

            "events": {
                "success": [ {
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                } ]
            },

            "deps": "js/interactionTableService"
        },

        "updateAttributeMappingTable": {
            "actionType": "JSFunction",
            "method": "updateAttributeMappingTableFuntion",
            "inputData": {
                "input": "{{data.dataProviders.interactionDataProvider}}"
            },

            "deps": "js/interactionTableService"
        },

        "handleTableSelection": {
            "actionType": "JSFunction",
            "method": "handleTableSelection",
            "inputData": {
                "dataprovider": "{{data.dataProviders.interactionDataProvider}}",
                "selection": "{{data.eventData.selectedObjects}}"
            },

            "deps": "js/interactionTableService"
        },
        "processSplitPanelDeSelectEvent": {
            "actionType": "JSFunction",
            "method": "processSplitPanelDeSelectEvent",
            "deps": "js/interactionTableService"
        }
    },

    "dataProviders": {
        "interactionDataProvider": {
            "action": "loadData",
            "editContext": "INTERACTION_CONTEXT",
            "response": "{{data.searchResults}}",
            "totalFound": "{{data.totalFound}}",
            "selectionModelMode": "single",
            "commandsAnchor": "com.siemens.splm.clientfx.tcui.commands.modelObjectCellListActionCommands"
        }
    },

    "columnProviders": {
        "connectionClientScopeUI": {
            "saveColumnAndLoadAction": "saveColumnConfigLoadData",
            "resetColumnAction": "resetColumnConfig",
            "sortCriteria": [

            ]
        }
    },

    "grids": {
        "interactionTable": {
            "dataProvider": "interactionDataProvider",
            "columnProvider": "connectionClientScopeUI",
            "addIconColumn": false,
            "gridOptions": {
                "enableGridMenu": false,
                "enableSorting": false
            }
        }
    },

    "onEvent": [ {
            "eventId": "interactionDataProvider.modelObjectsUpdated",
            "action": "initialiseContext"
        },

        {
            "eventId": "gwt.GraphConnectionSelectionChangeEvent",
            "action": "processGraphSelection"
        },
        {
            "eventId": "interactionTable.gridSelection",
            "cacheEventData": true,
            "action": "handleTableSelection"
        },
        {
            "eventId": "interactionDataProvider.modelObjectsUpdated",
            "condition": "ctx.Att1ShowMappedAttribute.interactionSelected",
            "action": "updateAttributeMappingTable"
        },
        {
            "eventId": "editHandlerStateChange",
            "cacheEventData": true,
            "action": "updateEditStateForInteraction"
        },
        {
            "eventId": "GraphConnectionSelectionChangeEvent",
            "action": "processGraphSelection"
        },
        {
            "eventId": "gwt.SplitPanelDeSelectEvent",
            "action": "processSplitPanelDeSelectEvent"

        },
        {
            "eventId": "columnArrange",
            "cacheEventData": true,
            "action": "doArrangeEvent"
        }
    ],

    "i18n": {
        "interactions": [
            "SystemModelerConstants"
        ]
    }
}
