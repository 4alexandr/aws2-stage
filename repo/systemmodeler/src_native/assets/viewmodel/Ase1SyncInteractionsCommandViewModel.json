{
    "schemaVersion": "1.0.0",
    "imports": [
        "js/aw-panel-body.directive",
        "js/aw-panel-footer.directive",
        "js/aw-command-panel.directive",
        "js/aw-checkbox.directive",
        "js/aw-i18n.directive",
        "js/aw-button.directive"
    ],

    "actions": {
        "syncInteractions": {
            "actionType": "TcSoaService",
            "serviceName": "Internal-SystemsModeling-2017-12-InterfaceManagement",
            "method": "findOrCreateInteractions",
            "inputData": {
                "inputs": "{{function:getSyncInteractionsInput}}"
            },

            "events": {
                "success": [ {
                        "name": "interactionTable.plTable.reload",
                        "condition": "!ctx.archModelerContext.syncRunInBackground"
                    },
                    {
                        "name": "complete",
                        "eventData": {
                            "source": "toolAndInfoPanel"
                        }
                    }

                ],

                "failure": [ {
                    "name": "complete",
                    "eventData": {
                        "source": "toolAndInfoPanel"
                    }
                } ]
            },

            "actionMessages": {
                "success": [ {
                        "message": "syncSingleConectionMessage",
                        "condition": "ctx.mselected.length === 1 && ctx.archModelerContext.syncRunInBackground"
                    },
                    {
                        "message": "syncMultipleConectionsMessage",
                        "condition": "ctx.mselected.length > 1 && ctx.archModelerContext.syncRunInBackground"
                    }
                ]
            },

            "deps": "js/Ase1SyncInteractionsCommandService"
        }
    },

    "data": {
        "runInBackground": {
            "displayName": "{{i18n.runInBackground}}",
            "type": "STRING",
            "isRequired": "false",
            "isEditable": "true",
            "dbValue": true,
            "labelPosition": "PROPERTY_LABEL_AT_RIGHT"
        }
    },

    "functions": {
        "getSyncInteractionsInput": {
            "functionName": "getSyncInteractionsInput",
            "parameters": [
                "{{data}}"
            ]
        }
    },

    "messages": {
        "syncSingleConectionMessage": {
            "messageType": "INFO",
            "messageText": "{{i18n.syncSingleConectionMessage}}",
            "messageTextParams": [
                "{{ctx.selected.props.object_string.dbValue}}"
            ]
        },
        "syncMultipleConectionsMessage": {
            "messageType": "INFO",
            "messageText": "{{i18n.syncMultipleConectionsMessage}}",
            "messageTextParams": [
                "{{ctx.mselected.length}}"
            ]
        }
    },

    "onEvent": [ {
        "eventId": "Ase1SyncInteractionsCommand.startSyncInteractions",
        "action": "syncInteractions"
    } ],

    "i18n": {
        "synchronize": [
            "SystemModelerConstants"
        ],
        "runInBackground": [
            "SystemModelerConstants"
        ],
        "syncSingleConectionMessage": [
            "SystemModelerMessages"
        ],
        "syncMultipleConectionsMessage": [
            "SystemModelerMessages"
        ]
    }
}
